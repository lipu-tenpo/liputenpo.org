                <ITEXT CPARENT="toki pi lipu open la nimi open" FCOLOR="unu pimeja" CH="kama pona"/>
                <breakline/>
                <ITEXT CH="lon lipu tenpo!"/>
                <para ParagraphEffectOffset="0" ParagraphEffectIndent="0" DROP="0" DROPLIN="2" Bullet="0" Numeration="0"/>
                <ITEXT CH="open la kala Asi li toki"/>
                <breakline/>
                <ITEXT CH="e"/>
                <nbspace/>
                <ITEXT CH="ijo suli pi tenpo sike pini."/>
                <para ParagraphEffectOffset="0" ParagraphEffectIndent="0" DROP="0" DROPLIN="2" Bullet="0" Numeration="0"/>
                <ITEXT CH="kin la ijo mute lon lipu ni"/>
                <breakline/>
                <ITEXT CH="li len."/>
                <breakline/>
                <ITEXT CH="ni la o kama sona"/>
                <breakline/>
                <ITEXT CH="e len ma"/>
                <breakline/>
                <ITEXT CH="e open pi len jan"/>
                <breakline/>
                <ITEXT CH="e nasin len tawa pona"/>
                <breakline/>
                <ITEXT CH="e len pi akesi moli..."/>
                <para ParagraphEffectOffset="0" ParagraphEffectIndent="0" DROP="0" DROPLIN="2" Bullet="0" Numeration="0"/>
                <ITEXT CH="pini la jan Wemi"/>
                <breakline/>
                <ITEXT CH="en jan Ke Tami"/>
                <breakline/>
                <ITEXT CH="li sitelen suwi e len."/>
                <para ParagraphEffectOffset="0" ParagraphEffectIndent="0" DROP="0" DROPLIN="2" Bullet="0" Numeration="0"/>
                <ITEXT CH="o len pona"/>
                <breakline/>
