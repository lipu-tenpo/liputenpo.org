        <PAGEOBJECT XPOS="589.605988188977" YPOS="2921.00750251443" OwnPage="8" ItemID="1904074026" PTYPE="4" WIDTH="170.078543307088" HEIGHT="270.80352110762" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L170.079 0 L170.079 270.804 L0 270.804 L0 0 Z" copath="M0 0 L170.079 0 L170.079 270.804 L0 270.804 L0 0 Z" gXpos="589.605988188977" gYpos="2921.00750251443" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="1720602298" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT FONT="Andika Bold" FCOLOR="laso pimeja" FSHADE="100" CH="lon tenpo pini pi ma Mewika la,"/>
                <ITEXT CH=" pali ike suli wan li"/>
                <nbspace/>
                <ITEXT CH="lon: jan pi selo walo li"/>
                <nbspace/>
                <ITEXT CH="poki e"/>
                <nbspace/>
                <ITEXT CH="jan pi selo pimeja, li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="ni tawa ona: o"/>
                <nbspace/>
                <ITEXT CH="pali. sina pali ala la, anu sina alasa tawa weka la, mi pakala e"/>
                <nbspace/>
                <ITEXT CH="sina. jan walo li"/>
                <nbspace/>
                <ITEXT CH="pilin e"/>
                <nbspace/>
                <ITEXT CH="ni: ona li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="jan pimeja, jan pimeja li"/>
                <nbspace/>
                <ITEXT CH="ijo jo. jan pimeja li"/>
                <nbspace/>
                <ITEXT CH="pali kepeken wawa mute mute lon tenpo suli"/>
                <nbspace/>
                <ITEXT CH="a, lon seli wawa, la sijelo ona li"/>
                <nbspace/>
                <ITEXT CH="kama pakala tan pali. taso ona li"/>
                <nbspace/>
                <ITEXT CH="pini pali la, jan walo li"/>
                <nbspace/>
                <ITEXT CH="pakala e"/>
                <nbspace/>
                <ITEXT CH="ona. taso tenpo la, len la, jan pali li"/>
                <nbspace/>
                <ITEXT CH="tawa weka. pali ike suli ni li"/>
                <nbspace/>
                <ITEXT CH="lon ma seli taso pi ma Mewika, la jan pali li"/>
                <nbspace/>
                <ITEXT CH="tawa ma lete, lon weka pali."/>
                <para/>
                <ITEXT CH="taso jan pi tawa weka li"/>
                <nbspace/>
                <ITEXT CH="taso ala; jan mute pi ma lete li"/>
                <nbspace/>
                <ITEXT CH="sona e"/>
                <nbspace/>
                <ITEXT CH="ike suli pi pali ni, li"/>
                <nbspace/>
                <ITEXT CH="pali e"/>
                <nbspace/>
                <ITEXT CH="nasin len tan ma seli tawa ma lete. nasin len ni li"/>
                <nbspace/>
                <ITEXT CH="kama nimi “nasin pi anpa ma” (toki Inli: Underground Railroad), li"/>
                <nbspace/>
                <ITEXT CH="weka e"/>
                <nbspace/>
                <ITEXT CH="jan mute"/>
                <nbspace/>
                <ITEXT CH="a tan pali ike."/>
                <para/>
                <ITEXT CH="mute la, jan li"/>
                <nbspace/>
                <ITEXT CH="pini e"/>
                <nbspace/>
                <ITEXT CH="tawa ona lon nasin len lon ma tomo Kenetu (Kennett Square), lon selo pi ma Pensiwenja (Pennsylvania); selo pi ma Pensiwenja la, ma seli li"/>
                <nbspace/>
                <ITEXT CH="pini, ma lete li"/>
                <nbspace/>
                <ITEXT CH="open. tenpo la jan suli pi nasin len li"/>
                <nbspace/>
                <ITEXT CH="kama kulupu lon ma tomo Kenetu, li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="ijo pali. kin la, ma tomo Kenetu li"/>
                <nbspace/>
                <ITEXT CH="ma tomo mi."/>
                <para/>
                <ITEXT CH="jan suli wan pi nasin ni li"/>
                <nbspace/>
                <ITEXT CH="jan Ewije Taman (Harriet Tubman). open la ona li"/>
                <nbspace/>
                <ITEXT CH="lon ma seli, li"/>
                <nbspace/>
                <ITEXT CH="pali ike lon anpa pi jan walo. ona li"/>
                <nbspace/>
                <ITEXT CH="kama weka tan ike, li"/>
                <nbspace/>
                <ITEXT CH="tawa ma lete kepeken nasin pi anpa ma, taso ona li"/>
                <nbspace/>
                <ITEXT CH="kama lon ma lete la, ona li"/>
                <nbspace/>
                <ITEXT CH="pilin e"/>
                <nbspace/>
                <ITEXT CH="ni: ona o"/>
                <nbspace/>
                <ITEXT CH="tawa monsi, o"/>
                <nbspace/>
                <ITEXT CH="weka e"/>
                <nbspace/>
                <ITEXT CH="jan pali ante tan pali ike. ni la ona li"/>
                <nbspace/>
                <ITEXT CH="ni; ona li"/>
                <nbspace/>
                <ITEXT CH="kama lon kulupu pi nasin len, li"/>
                <nbspace/>
                <ITEXT CH="tawa ma seli lon tenpo sin, li"/>
                <nbspace/>
                <ITEXT CH="weka e"/>
                <nbspace/>
                <ITEXT CH="jan ante mute"/>
                <nbspace/>
                <ITEXT CH="a."/>
                <para/>
                <ITEXT CH="tenpo kama poka la, ma seli en ma lete li"/>
                <nbspace/>
                <ITEXT CH="kama utala suli tan pali ike lon ma seli. lon pini pi utala suli la, jan lawa Epejan Linkon (Abraham Lincoln) pi ma lete li"/>
                <nbspace/>
                <ITEXT CH="weka e"/>
                <nbspace/>
                <ITEXT CH="jan pimeja ale tan pali ike. ona li"/>
                <nbspace/>
                <ITEXT CH="ni la, nasin len li"/>
                <nbspace/>
                <ITEXT CH="pini."/>
                <para/>
                <ITEXT CH="ale la, nasin pi anpa ma li"/>
                <nbspace/>
                <ITEXT CH="weka e"/>
                <nbspace/>
                <ITEXT CH="jan pona mute tan pali pakala ni pi moli mute. tan ni la, jan li"/>
                <nbspace/>
                <ITEXT CH="awen pana e"/>
                <nbspace/>
                <ITEXT CH="sona pi pali pona ona."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
