                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="ale… ma Antasika kin o"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="len ala. lukin nanpa wan li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="lon sike #"/>
