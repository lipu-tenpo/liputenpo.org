        <PAGEOBJECT XPOS="217.061173342312" YPOS="5356.19622047244" OwnPage="15" ItemID="1903190346" PTYPE="4" WIDTH="276.438976164316" HEIGHT="257.271386275384" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="14.1732283464567" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L276.439 0 L276.439 257.271 L0 257.271 L0 0 Z" copath="M0 0 L276.439 0 L276.439 257.271 L0 257.271 L0 0 Z" gXpos="217.061173342314" gYpos="4720.92094488189" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CPARENT="toki wawa" FCOLOR="laso pimeja" CH="Hello!"/>
                <ITEXT FCOLOR="laso pimeja" CH=" "/>
                <ITEXT CH="You’re looking at "/>
                <ITEXT FONT="Andika Italic" CH="lipu tenpo"/>
                <ITEXT CH=","/>
                <nbspace/>
                <ITEXT CH="a magazine written in Toki Pona."/>
                <breakline/>
                <ITEXT CH="Maybe you’re new and want to know more about this lan­­guage. Great!"/>
                <breakline/>
                <ITEXT CH="This page hopes to answer some of your questions."/>
                <para/>
                <ITEXT CH="What is Toki Pona?"/>
                <para PARENT="jan pali"/>
                <ITEXT CH="Toki Pona is an elegant minimal lan­­guage. It was created by the"/>
                <breakline/>
                <ITEXT CH="Canadian linguist Sonja Lang in 2001. It has only got 14 letters and"/>
                <breakline/>
                <ITEXT CH="about 130 words."/>
                <para/>
                <ITEXT CH="Why would I learn Toki Pona?"/>
                <para PARENT="jan pali"/>
                <ITEXT CH="Despite how tiny the language is, it is still possible to describe any"/>
                <breakline/>
                <ITEXT CH="concept with it. This might fascinate you. Maybe you just want to take"/>
                <breakline/>
                <ITEXT CH="a break from the complex world we live in. Or perhaps you just want"/>
                <breakline/>
                <ITEXT CH="to talk to your friends without others knowing what you’re saying."/>
                <para/>
                <ITEXT CH="How can I learn Toki Pona, and where can I use it?"/>
                <para PARENT="jan pali"/>
                <ITEXT CH="There is the official book: "/>
                <ITEXT FONT="Andika Italic" CH="Toki Pona: The Language of Good"/>
                <ITEXT CH=" by Sonja"/>
                <breakline/>
                <ITEXT CH="Lang. It teaches how to use Toki Pona. Sonja made"/>
                <nbspace/>
                <ITEXT CH="a "/>
                <ITEXT FONT="Andika Italic" CH="Toki Pona"/>
                <breakline/>
                <ITEXT FONT="Andika Italic" CH="Dictionary"/>
                <ITEXT CH=" too. There are also several free online courses. You can"/>
                <breakline/>
                <ITEXT CH="find Toki Pona groups and learning resources on "/>
                <ITEXT CPARENT="toki wawa" FCOLOR="laso pimeja" CH="tokipona.org"/>
                <ITEXT CH=", the"/>
                <breakline/>
                <ITEXT CH="official website, as well as on our own website: "/>
                <ITEXT CPARENT="toki wawa" FCOLOR="laso pimeja" CH="liputenpo.org"/>
                <ITEXT CH="."/>
                <trail/>
            </StoryText>
        </PAGEOBJECT>
