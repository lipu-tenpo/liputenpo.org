                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="ilo telo li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="kama lukin e"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="ma ale. kulupu walo la mije Siwenson Simi³ li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="kute, li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="sitelen e"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="ale lon toki open Mali lon toki Inli kin. lipu ona la mama li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="lukin e"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="kiwen walo"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="a. ni li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="ken taso lon poka pi ma Antasika!"/>
                <para/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="taso jan ante la walo li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="kiwen ala: ma Lalotona la walo ni li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="nimi "/>
                <ITEXT CPARENT="Text127_Italic" FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="Te tai uka"/>
                <nbspace CPARENT="Text127_Italic" FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT CPARENT="Text127_Italic" FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="a pia,"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH=" anu “telo ("/>
                <ITEXT CPARENT="Text127_Italic" FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="tai"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH=") pi ko walo ("/>
                <ITEXT CPARENT="Text127_Italic" FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="uka"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH=") sama kasi Pija ("/>
                <ITEXT CPARENT="Text127_Italic" FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="a pia"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="⁴)”. ko telo ("/>
                <ITEXT CPARENT="Text127_Italic" FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="uka"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH=") la jan Simi li"/>
