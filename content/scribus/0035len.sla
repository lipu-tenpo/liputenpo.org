            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT FONT="Andika Regular" FCOLOR="Black" FSHADE="100" CH="mi kama tan kili loje jelo"/>
                <breakline/>
                <ITEXT CH="tan ona la jan li"/>
                <nbspace/>
                <ITEXT CH="pali e"/>
                <nbspace/>
                <ITEXT CH="ko"/>
                <breakline/>
                <ITEXT CH="ko li"/>
                <nbspace/>
                <ITEXT CH="lon la mi pini ala"/>
                <breakline/>
                <ITEXT CH="o"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="telo mama¹"/>
                <para/>
                <ITEXT CH="suwi ala la mi moku nasa"/>
                <breakline/>
                <ITEXT CH="ni la sina ken pana e"/>
                <nbspace/>
                <ITEXT CH="ona"/>
                <breakline/>
                <ITEXT CH="mi suwi li"/>
                <nbspace/>
                <ITEXT CH="pona tawa jan lili"/>
                <breakline/>
                <ITEXT CH="telo nasa li"/>
                <nbspace/>
                <ITEXT CH="ken lon insa mi"/>
                <para/>
                <ITEXT CH="mi ken kiwen li"/>
                <nbspace/>
                <ITEXT CH="ko li"/>
                <nbspace/>
                <ITEXT CH="telo"/>
                <breakline/>
                <ITEXT CH="mi ken pimeja anu walo"/>
                <breakline/>
                <ITEXT CH="mi mute tu tu li"/>
                <nbspace/>
                <ITEXT CH="lon insa"/>
                <breakline/>
                <ITEXT CH="pi lipu tenpo mun pona"/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
