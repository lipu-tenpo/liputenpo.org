                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="lukin e"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="kulupu mun lon sewi. lukin jan la sijelo kulupu li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="sama soweli suli Ato ("/>
                <ITEXT CPARENT="Text127_Italic" FONT="Noto Sans Italic" FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="Ἄρκτος"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="). poka Antasiko la ona li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="sona ike e"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="ma. nasa ala: kulupu Elena li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="lon weka suli, li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="ken ala lukin"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="a."/>
                <para/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="kulupu ante li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="lukin ala lukin e"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="ma? toki wan la lukin: poka ante sike la ma lili Lalotona¹ li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="lon telo seli. ona la mije lawa Tala Ale² li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="pana e"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="sona mama tan tenpo weka. kulupu mama li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="pali e"/>
