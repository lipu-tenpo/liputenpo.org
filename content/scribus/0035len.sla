        <PAGEOBJECT XPOS="178.537771653543" YPOS="2129.69349491027" OwnPage="5" ItemID="1902111066" PTYPE="4" WIDTH="170.078543307087" HEIGHT="317.093707322362" FRTYPE="0" CLIPEDIT="1" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L170.079 0 L170.079 317.094 L0 317.094 L0 0 Z" copath="M0 0 L170.079 0 L170.079 317.092 L0 317.092 L0 0 Z" gXpos="178.537771653547" gYpos="6041.50451853231" gWidth="170.078543307087" gHeight="255.72331306688" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="1721058378" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT CPARENT="Text117_Bold" FCOLOR="loje pimeja" FSHADE="100" CH="mi toki e"/>
                <nbspace CPARENT="Text117_Bold" FCOLOR="loje pimeja" FSHADE="100"/>
                <ITEXT CPARENT="Text117_Bold" FCOLOR="loje pimeja" FSHADE="100" CH="nasin mi."/>
                <ITEXT CH=" poka ni la, sina ken kama lukin e"/>
                <nbspace/>
                <ITEXT CH="nasin sina. sina kama lon nasin ante lon tenpo suli ni anu seme?"/>
                <para/>
                <ITEXT CH="toki suli mi li"/>
                <nbspace/>
                <ITEXT CH="open lon tenpo sike 2020. sina sona: jan ale li"/>
                <nbspace/>
                <ITEXT CH="kama monsuta tan jaki sijelo. mi lon ma tomo Pelin. mi pilin pona lili. kulupu jan tomo mi li"/>
                <nbspace/>
                <ITEXT CH="wile lili e"/>
                <nbspace/>
                <ITEXT CH="kulupu pi jan pona mi, li"/>
                <nbspace/>
                <ITEXT CH="wile e"/>
                <nbspace/>
                <ITEXT CH="ijo mute. “mi o"/>
                <nbspace/>
                <ITEXT CH="ni. mi o"/>
                <nbspace/>
                <ITEXT CH="ni.”"/>
                <nbspace/>
                <ITEXT CH="a! kin la, jan pona li"/>
                <nbspace/>
                <ITEXT CH="kama weka tan mi. mi pilin ike. mi kama wile tawa weka. tenpo pini la, mi wile kama sona e"/>
                <nbspace/>
                <ITEXT CH="toki Epanja. ni li"/>
                <nbspace/>
                <ITEXT CH="tenpo tawa ni! mi tawa ma suli Amelika"/>
                <nbspace/>
                <ITEXT CH="a."/>
                <para/>
                <ITEXT CH="tomo tawa kon la, mi sitelen e"/>
                <nbspace/>
                <ITEXT CH="toki pona tawa jan mi, tawa kulupu mama mi. pilin mi li"/>
                <nbspace/>
                <ITEXT CH="suli tan ni: tenpo ala la, mi weka tan ma suli Elopa. kepeken sona lili pi toki Epanja la, mi kama jo e"/>
                <nbspace/>
                <ITEXT CH="jan pona mute. ona en jan lili pi toki lili"/>
                <nbspace/>
                <ITEXT CH="a li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="sona toki tawa mi. ni"/>
                <nbspace/>
                <ITEXT CH="a li"/>
                <nbspace/>
                <ITEXT CH="nasin pona! mi jo e"/>
                <nbspace/>
                <ITEXT CH="mani lili. mi kama jo e"/>
                <nbspace/>
                <ITEXT CH="mani kepeken kalama musi. palisa pi kalama kon li"/>
                <nbspace/>
                <ITEXT CH="pona tawa jan."/>
                <para/>
                <ITEXT CH="jan pi ma Ulukawi¹ li"/>
                <nbspace/>
                <ITEXT CH="pona mute tawa jan tawa. jan li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="ni: “o"/>
                <nbspace/>
                <ITEXT CH="tawa tomo mi. o"/>
                <nbspace/>
                <ITEXT CH="pona e"/>
                <nbspace/>
                <ITEXT CH="tomo mi. mi o"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="pan e"/>
                <nbspace/>
                <ITEXT CH="tomo.” mi sona ala e"/>
                <nbspace/>
                <ITEXT CH="nasin. taso jan li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="nasin tawa mi. mi lukin li"/>
                <nbspace/>
                <ITEXT CH="pilin e"/>
                <nbspace/>
                <ITEXT CH="suno wawa, e"/>
                <nbspace/>
                <ITEXT CH="telo suli, e"/>
                <nbspace/>
                <ITEXT CH="nena ante e"/>
                <nbspace/>
                <ITEXT CH="ale pi ma Ulukawi. ale jan pi ma weka li"/>
                <nbspace/>
                <ITEXT CH="sama jan pi ma mi"/>
                <nbspace/>
                <ITEXT CH="a! mi jan tawa li"/>
                <nbspace/>
                <ITEXT CH="kama jo e"/>
                <nbspace/>
                <ITEXT CH="tomo sin lon tenpo sin, taso tenpo suli poka la, mi kama jo e"/>
                <nbspace/>
                <ITEXT CH="tomo. nasin ni li"/>
                <nbspace/>
                <ITEXT CH="pini lon poka pi mije olin mi. mi en ona li"/>
                <nbspace/>
                <ITEXT CH="olin tan ni: mi tu li"/>
                <nbspace/>
                <ITEXT CH="tan ma weka, taso mi jo e"/>
                <nbspace/>
                <ITEXT CH="pilin sama."/>
                <para/>
                <ITEXT CH="¹ toki Epanja la "/>
                <ITEXT FONT="Andika Italic" FONTSIZE="7.1" CH="Uruguay"/>
                <para PARENT="toki lili poka"/>
            </StoryText>
        </PAGEOBJECT>
