                <nbspace/>
                <ITEXT CH="ma Mata. sina ken kama sona e"/>
                <nbspace/>
                <ITEXT CH="kalama musi e"/>
                <nbspace/>
                <ITEXT CH="moku pi ma Mata lon ni lon ma tomo ante kin. mi la pan Pasi ("/>
                <ITEXT CPARENT="Text121_Italic" CH="pastizz"/>
                <ITEXT CH=") li"/>
                <nbspace/>
                <ITEXT CH="pona mute: kili anu kiwen pi telo soweli li"/>
