                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="kiwen supa lili mute; kulupu pi kiwen lili la ni taso o"/>
                <nbspace/>
                <ITEXT CH="lon:"/>
                <para/>
                <ITEXT CH="kiwen luka luka wan la, poka tu wan o"/>
                <nbspace/>
                <ITEXT CH="lon."/>
                <para PARENT="Text87_List 1"/>
                <ITEXT CH="kiwen tu la, poka tu tu o"/>
                <nbspace/>
                <ITEXT CH="lon."/>
                <para PARENT="Text87_List 1"/>
                <ITEXT CH="kiwen wan la, poka luka o"/>
                <nbspace/>
                <ITEXT CH="lon."/>
                <para PARENT="Text87_List 1"/>
                <ITEXT CH="(poka ale o"/>
                <nbspace/>
                <ITEXT CH="suli ante. o"/>
                <nbspace/>
                <ITEXT CH="lukin e"/>
                <nbspace/>
                <ITEXT CH="sitelen!)"/>
                <para/>
                <ITEXT CH="sina wan e"/>
                <nbspace/>
                <ITEXT CH="kiwen lili ale la, ona li"/>
                <nbspace/>
                <ITEXT CH="ken lon kiwen suli. taso, sina wile wan e"/>
                <nbspace/>
                <ITEXT CH="kiwen ale lon nasin pona ni la, sina utala! musi la, o"/>
                <nbspace/>
                <ITEXT CH="alasa wan e"/>
                <nbspace/>
                <ITEXT CH="kiwen ale lon supa. pini la ale o"/>
                <nbspace/>
                <ITEXT CH="supa: kiwen o"/>
                <nbspace/>
                <ITEXT CH="ken ala lon sewi pi kiwen ante. nasin mute mute"/>
                <nbspace/>
                <ITEXT CH="a li"/>
                <nbspace/>
                <ITEXT CH="ken! kin la, sina ken musi ante kepeken kiwen sama: sina nasin e"/>
                <nbspace/>
                <ITEXT CH="kiwen lili la, ona li"/>
                <nbspace/>
                <ITEXT CH="ken sama sitelen soweli, anu sitelen jan, anu sitelen tomo... anu sitelen ante. toki Elena la utala musi ni li"/>
                <nbspace/>
                <ITEXT CH="kepeken nimi 'ὀστομάχιον' ("/>
                <ITEXT CPARENT="Text121_Italic" CH="Osomakijon"/>
                <ITEXT CH=")."/>
                <para/>
                <ITEXT CH="musi ante pi nasin sama li"/>
                <nbspace/>
                <ITEXT CH="tan ma Sonko pi tenpo pini. musi Sisopan (七巧板) la o"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="ni taso lon kulupu pi kiwen lili:"/>
                <para/>
                <ITEXT CH="kiwen luka la poka tu wan pi suli sama o"/>
                <nbspace/>
                <ITEXT CH="lon."/>
                <para PARENT="Text87_List 1"/>
                <ITEXT CH="kiwen wan la poka tu tu pi suli sama o"/>
                <nbspace/>
                <ITEXT CH="lon."/>
                <para PARENT="Text87_List 1"/>
                <ITEXT CH="kiwen wan la poka tu tu pi suli sama ala o"/>
                <nbspace/>
                <ITEXT CH="lon."/>
                <para PARENT="Text87_List 1"/>
                <ITEXT CH="utala li"/>
                <nbspace/>
                <ITEXT CH="lili lon musi ni. taso, sama la, sina ken pali e"/>
                <nbspace/>
                <ITEXT CH="sitelen mute kepeken kiwen lili. o"/>
                <nbspace/>
                <ITEXT CH="musi pona!"/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
