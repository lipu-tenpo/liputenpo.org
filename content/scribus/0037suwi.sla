        <PAGEOBJECT XPOS="589.606299212598" YPOS="857.218379348151" OwnPage="2" ItemID="1574928765" PTYPE="4" WIDTH="170.078543307087" HEIGHT="204.912588458089" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L170.079 0 L170.079 204.913 L0 204.913 L0 0 Z" copath="M0 0 L170.079 0 L170.079 204.913 L0 204.913 L0 0 Z" gXpos="589.606299212598" gYpos="857.218379348151" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="1574958237" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT FONT="Andika Bold" FCOLOR="unu pimeja" FSHADE="100" CH="ma Elena pi tenpo pini la,"/>
                <ITEXT CH=" jan Akimete li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="sona mute; ona li"/>
                <nbspace/>
                <ITEXT CH="sitelen e"/>
                <nbspace/>
                <ITEXT CH="sona lon lipu la, mi pi tenpo ni li"/>
                <nbspace/>
                <ITEXT CH="ken sona e"/>
                <nbspace/>
                <ITEXT CH="ona. lipu wan la, ona li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="sona musi ni. o"/>
                <nbspace/>
                <ITEXT CH="kute:"/>
                <para/>
                <ITEXT CH="o"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="kiwen supa suli wan; supa la poka tu tu pi suli sama o"/>
                <nbspace/>
                <ITEXT CH="lon. o"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="kiwen supa lili mute; kulupu pi kiwen lili la ni taso o"/>
                <nbspace/>
                <ITEXT CH="lon:"/>
                <para/>
                <ITEXT CH="kiwen luka luka wan la, poka tu wan o"/>
                <nbspace/>
                <ITEXT CH="lon."/>
                <para PARENT="Text92_List 2"/>
                <ITEXT CH="kiwen tu la, poka tu tu o"/>
                <nbspace/>
                <ITEXT CH="lon."/>
                <para PARENT="Text92_List 2"/>
                <ITEXT CH="kiwen wan la, poka luka o"/>
                <nbspace/>
                <ITEXT CH="lon."/>
                <para PARENT="Text92_List 2"/>
                <ITEXT CH="(poka ale o"/>
                <nbspace/>
                <ITEXT CH="suli ante. o"/>
                <nbspace/>
                <ITEXT CH="lukin e"/>
                <nbspace/>
                <ITEXT CH="sitelen!)"/>
                <para/>
                <ITEXT CH="sina wan e"/>
                <nbspace/>
                <ITEXT CH="kiwen lili ale la, ona li"/>
                <nbspace/>
                <ITEXT CH="ken lon kiwen suli. taso, sina wile wan e"/>
                <nbspace/>
                <ITEXT CH="kiwen ale lon nasin pona ni la, sina utala! musi la, o"/>
                <nbspace/>
                <ITEXT CH="alasa wan e"/>
                <nbspace/>
                <ITEXT CH="kiwen ale lon supa. pini la ale o"/>
                <nbspace/>
                <ITEXT CH="supa: kiwen o"/>
                <nbspace/>
                <ITEXT CH="ken ala lon sewi pi kiwen ante. nasin mute mute"/>
                <nbspace/>
                <ITEXT CH="a li"/>
                <nbspace/>
                <ITEXT CH="ken! kin la, sina ken musi ante kepeken kiwen sama: sina nasin e"/>
                <nbspace/>
                <ITEXT CH="kiwen lili la, ona li"/>
                <nbspace/>
                <ITEXT CH="ken sama sitelen soweli, anu sitelen jan, anu sitelen tomo... anu sitelen ante. toki Elena la utala musi ni li"/>
                <nbspace/>
                <ITEXT CH="kepeken nimi 'ὀστομάχιον' ("/>
                <ITEXT CPARENT="Text92_Italic" CH="Osomakijon"/>
                <ITEXT CH=")."/>
                <para/>
                <ITEXT CH="musi ante pi nasin sama li"/>
                <nbspace/>
                <ITEXT CH="tan ma Sonko pi tenpo pini. musi Sisopan (七巧板) la o"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="ni taso lon kulupu pi kiwen lili:"/>
                <para/>
                <ITEXT CH="kiwen luka la poka tu wan pi suli sama o"/>
                <nbspace/>
                <ITEXT CH="lon."/>
                <para PARENT="Text92_List 3"/>
                <ITEXT CH="kiwen wan la poka tu tu pi suli sama o"/>
                <nbspace/>
                <ITEXT CH="lon."/>
                <para PARENT="Text92_List 3"/>
                <ITEXT CH="kiwen wan la poka tu tu pi suli sama ala o"/>
                <nbspace/>
                <ITEXT CH="lon."/>
                <para PARENT="Text92_List 3"/>
                <ITEXT CH="utala li"/>
                <nbspace/>
                <ITEXT CH="lili lon musi ni. taso, sama la, sina ken pali e"/>
                <nbspace/>
                <ITEXT CH="sitelen mute kepeken kiwen lili. o"/>
                <nbspace/>
                <ITEXT CH="musi pona!"/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
