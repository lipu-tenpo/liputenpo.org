                <nbspace/>
                <ITEXT CH="kama jo e"/>
                <nbspace/>
                <ITEXT CH="nanpa ni. tenpo ni li"/>
                <nbspace/>
                <ITEXT CH="ken tan ni taso: jan wan li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="lipu pilin ale e"/>
                <nbspace/>
                <ITEXT CH="lipu ilo pi meli lawa. ni la mi toki e"/>
                <nbspace/>
