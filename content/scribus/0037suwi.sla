                <nbspace/>
                <ITEXT CH="sike kama."/>
                <para/>
                <ITEXT CH="open sike la, jan li"/>
                <nbspace/>
                <ITEXT CH="ken ala open kepeken lipu pilin (♥️). kule open li"/>
                <nbspace/>
