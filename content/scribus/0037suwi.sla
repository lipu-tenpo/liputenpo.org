                <ITEXT CH="lon supa la, sona ona o"/>
                <nbspace/>
                <ITEXT CH="len ala. jan ale li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="lipu wan tawa supa la, sike lili li"/>
                <nbspace/>
                <ITEXT CH="pini. jan li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="lipu sewi la, ona li"/>
                <nbspace/>
                <ITEXT CH="kama jo e"/>
                <nbspace/>
                <ITEXT CH="lipu ale tan supa. taso, lipu sewi li"/>
                <nbspace/>
                <ITEXT CH="seme?"/>
                <para/>
                <ITEXT CH="kule pi lipu sewi o"/>
                <nbspace/>
