                <ITEXT CH="jan li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="nanpa ale (100) la, musi li"/>
                <nbspace/>
                <ITEXT CH="pini. jan li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="nanpa pi anpa mute la, ona li"/>
                <nbspace/>
