        <PAGEOBJECT XPOS="773.857842519685" YPOS="3041.57480314961" OwnPage="8" ItemID="1576174477" PTYPE="4" WIDTH="170.079165354331" HEIGHT="161.574803149606" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L170.079 0 L170.079 161.575 L0 161.575 L0 0 Z" copath="M0 0 L170.079 0 L170.079 161.575 L0 161.575 L0 0 Z" gXpos="773.857842519685" gYpos="3041.57480314961" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle LINESPMode="1"/>
                <ITEXT CH="waso pimeja li"/>
                <nbspace/>
                <ITEXT CH="kama jo e"/>
                <nbspace/>
                <ITEXT CH="moku suwi tan jan pi pali moku. soweli lili li"/>
                <nbspace/>
                <ITEXT CH="wile e"/>
                <nbspace/>
                <ITEXT CH="suwi ni la ona li"/>
                <nbspace/>
                <ITEXT CH="tawa waso pimeja li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="ni: “sina pana ala pana e"/>
                <nbspace/>
                <ITEXT CH="suwi lili tawa mi?” taso waso pimeja li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="ni: “pana ala.” soweli lili li"/>
                <nbspace/>
                <ITEXT CH="sona pona e"/>
                <nbspace/>
                <ITEXT CH="waso ni la ona li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="ni: “kalama musi sina li"/>
                <nbspace/>
                <ITEXT CH="wawa"/>
                <nbspace/>
                <ITEXT CH="a! mi wile kute e"/>
                <nbspace/>
                <ITEXT CH="ona!” nimi soweli li"/>
                <nbspace/>
                <ITEXT CH="pona"/>
                <nbspace/>
                <ITEXT CH="a tawa waso pimeja. ona li"/>
                <nbspace/>
                <ITEXT CH="kama kalama musi la suwi ona li"/>
                <nbspace/>
                <ITEXT CH="tawa anpa la soweli lili li"/>
                <nbspace/>
                <ITEXT CH="kama jo e"/>
                <nbspace/>
                <ITEXT CH="suwi ni."/>
                <trail PARENT="Default Paragraph Style" LINESPMode="1"/>
