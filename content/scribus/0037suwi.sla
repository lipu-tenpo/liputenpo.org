            <StoryText>
                <DefaultStyle/>
                <ITEXT FCOLOR="laso pimeja" FSHADE="100" CH="ma ante la"/>
                <breakline/>
                <ITEXT FCOLOR="laso pimeja" FSHADE="100" CH="jan li pana pona"/>
                <breakline/>
                <ITEXT FCOLOR="laso pimeja" FSHADE="100" CH="tawa mama"/>
                <breakline/>
                <ITEXT FCOLOR="laso pimeja" FSHADE="100" CH="lon tenpo ante"/>
                <trail PARENT="lawa" ALIGN="0"/>
            </StoryText>
        </PAGEOBJECT>
