        <PAGEOBJECT XPOS="589.606299212599" YPOS="875.668264185925" OwnPage="2" ItemID="433719501" PTYPE="4" WIDTH="170.078606299213" HEIGHT="273.288547792286" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L170.079 0 L170.079 273.289 L0 273.289 L0 0 Z" copath="M0 0 L170.079 0 L170.079 273.289 L0 273.289 L0 0 Z" gXpos="589.606299212598" gYpos="3483.54227993396" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="475361293" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT FONT="Andika Bold" FCOLOR="laso pimeja" FSHADE="100" CH="tomo mi li"/>
                <nbspace FONT="Andika Bold" FCOLOR="laso pimeja" FSHADE="100"/>
                <ITEXT FONT="Andika Bold" FCOLOR="laso pimeja" FSHADE="100" CH="lon ma wan."/>
                <ITEXT CH=" taso mi en mama mi li"/>
                <nbspace/>
                <ITEXT CH="tan ma ante. ma tu li"/>
                <nbspace/>
                <ITEXT CH="lon poka la, ijo mute li"/>
                <nbspace/>
                <ITEXT CH="sama"/>
                <nbspace/>
                <ITEXT CH="a. taso lon tenpo mun nanpa luka la, ijo wan li"/>
                <nbspace/>
                <ITEXT CH="ante"/>
                <nbspace/>
                <ITEXT CH="a. ona li"/>
                <nbspace/>
                <ITEXT CH="ijo lili taso, taso mi sona e"/>
                <nbspace/>
                <ITEXT CH="nasa ni lon sike ale. tenpo nanpa luka li"/>
                <nbspace/>
                <ITEXT CH="kama sin la, mi en mama mi li"/>
                <nbspace/>
                <ITEXT CH="toki sama e"/>
                <nbspace/>
                <ITEXT CH="ijo: “a, tenpo mama li"/>
                <nbspace/>
                <ITEXT CH="kama” - “a, taso ona li"/>
                <nbspace/>
                <ITEXT CH="tenpo mama pi ma seme: ma ni anu ma poka?” kulupu ma la, mi o"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="ijo tawa mama lon tenpo suno mama. taso tenpo mama li"/>
                <nbspace/>
                <ITEXT CH="lon open pi tenpo mun lon ma pi tomo mi, li"/>
                <nbspace/>
                <ITEXT CH="lon pini pi tenpo mun lon ma poka. ni la mi sona pona ala e"/>
                <nbspace/>
                <ITEXT CH="nasin la, mi kama pana ala."/>
                <para/>
                <ITEXT CH="mi kama sona: ma mute la, tenpo mama li"/>
                <nbspace/>
                <ITEXT CH="lon tenpo ante. tenpo mama wan ala kin li"/>
                <nbspace/>
                <ITEXT CH="lon. tenpo wan li"/>
                <nbspace/>
                <ITEXT CH="tawa mama meli, tenpo ante li"/>
                <nbspace/>
                <ITEXT CH="tawa mama mije, tenpo pi mama mama kin li"/>
                <nbspace/>
                <ITEXT CH="lon."/>
                <breakline/>
                <ITEXT CH="mi kama sona e"/>
                <nbspace/>
                <ITEXT CH="nasa ante: tenpo mama li"/>
                <nbspace/>
                <ITEXT CH="kama tenpo esun. jan Ene Sewe[^1] li"/>
                <nbspace/>
                <ITEXT CH="kama e"/>
                <nbspace/>
                <ITEXT CH="tenpo mama lon ma Juwese la, ma ante li"/>
                <nbspace/>
                <ITEXT CH="kama wile sama. mama pi jan ni li"/>
                <nbspace/>
                <ITEXT CH="moli la, jan li"/>
                <nbspace/>
                <ITEXT CH="wile awen e"/>
                <nbspace/>
                <ITEXT CH="mama lon pilin lon sona. ona li"/>
                <nbspace/>
                <ITEXT CH="open e"/>
                <nbspace/>
                <ITEXT CH="tenpo mama lon tomo pi kulupu suli. ona li"/>
                <nbspace/>
                <ITEXT CH="toki mute mute tawa jan pi mute suli la, lawa pi ma Juwese li"/>
                <nbspace/>
                <ITEXT CH="kama e"/>
                <nbspace/>
                <ITEXT CH="tenpo mama tawa ma Juwese. taso ni la, kulupu esun li"/>
                <nbspace/>
                <ITEXT CH="esun e"/>
                <nbspace/>
                <ITEXT CH="lipu pi tenpo mama, e"/>
                <nbspace/>
                <ITEXT CH="kasi suwi. mani li"/>
                <nbspace/>
                <ITEXT CH="tawa jan esun li"/>
                <nbspace/>
                <ITEXT CH="tawa kulupu esun, li"/>
                <nbspace/>
                <ITEXT CH="tawa ala jan Ene Sewe. ona li"/>
                <nbspace/>
                <ITEXT CH="utala e"/>
                <nbspace/>
                <ITEXT CH="ni, li"/>
                <nbspace/>
                <ITEXT CH="kama wile pini e"/>
                <nbspace/>
                <ITEXT CH="tenpo mama. tenpo mama li"/>
                <nbspace/>
                <ITEXT CH="tenpo olin taso ala, li"/>
                <nbspace/>
                <ITEXT CH="tenpo utala kin, li"/>
                <nbspace/>
                <ITEXT CH="tenpo esun kin."/>
                <para/>
                <ITEXT CH="tenpo mama li"/>
                <nbspace/>
                <ITEXT CH="awen nasa tawa mi. lon la, mi wile pana e"/>
                <nbspace/>
                <ITEXT CH="ijo tawa mama. mi pali e"/>
                <nbspace/>
                <ITEXT CH="pona lon pakala pi tomo mama lon tenpo poka. taso mi ni lon tenpo mute. mi o"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="seme tawa mama olin mi?"/>
                <para/>
                <ITEXT CH="[^1]:  Anna Jarvis"/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
