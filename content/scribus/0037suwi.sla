                <ITEXT CH="toki: &quot;mi toki tawa ona!&quot; mama meli li"/>
                <nbspace/>
                <ITEXT CH="toki sin: &quot;kon toki sina li"/>
                <nbspace/>
                <ITEXT CH="seme? sina toki tawa sina lon insa pi tenpo pimeja! mi mute li"/>
                <nbspace/>
                <ITEXT CH="wile lape!&quot; jan lili Ela li"/>
                <nbspace/>
                <ITEXT CH="sona ala e"/>
                <nbspace/>
                <ITEXT CH="ijo ale pi tenpo ni. jan Ela li"/>
                <nbspace/>
                <ITEXT CH="toki tawa ona: &quot;toki mama li"/>
                <nbspace/>
                <ITEXT CH="jo ala e"/>
                <nbspace/>
                <ITEXT CH="kon. sina lon!&quot; ona li"/>
                <nbspace/>
                <ITEXT CH="mu taso sike. jan Ela li"/>
                <nbspace/>
                <ITEXT CH="toki sin: &quot;jan suli li"/>
                <nbspace/>
                <ITEXT CH="pilin ike wawa tan sina … jan mute li"/>
                <nbspace/>
                <ITEXT CH="pilin monsuta tawa sina … ona ale li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="ni: sina lon ala. taso ona ale li"/>
                <nbspace/>
                <ITEXT CH="toki tan sina!&quot; mama meli li"/>
                <nbspace/>
                <ITEXT CH="toki lon tenpo ni: &quot;o"/>
                <nbspace/>
                <ITEXT CH="pini"/>
                <nbspace/>
                <ITEXT CH="a! jan Ela o"/>
                <nbspace/>
                <ITEXT CH="tawa e"/>
                <nbspace/>
                <ITEXT CH="sijelo sina tawa mi lon tenpo ni anu tawa mi lon tenpo ala.&quot; jan Ela li"/>
                <nbspace/>
                <ITEXT CH="open pana e"/>
                <nbspace/>
                <ITEXT CH="telo lukin. jan Ela li"/>
                <nbspace/>
                <ITEXT CH="toki lon lawa: &quot;tan seme la mama li"/>
                <nbspace/>
                <ITEXT CH="pali e"/>
                <nbspace/>
                <ITEXT CH="nasin ni?&quot; kon lete li"/>
                <nbspace/>
                <ITEXT CH="tawa. jan Ela li"/>
                <nbspace/>
                <ITEXT CH="open kepeken e"/>
                <nbspace/>
                <ITEXT CH="len lawa. mun li"/>
                <nbspace/>
                <ITEXT CH="suno lon sewi ona. jan Ela li"/>
                <nbspace/>
                <ITEXT CH="wile sona e"/>
                <nbspace/>
                <ITEXT CH="ni: tan seme la jan suli ale li"/>
                <nbspace/>
                <ITEXT CH="pilin monsuta tan ona? jan lili li"/>
                <nbspace/>
                <ITEXT CH="kama sona. jan Ela li"/>
                <nbspace/>
                <ITEXT CH="toki: &quot;mi ken ala awen lon ni. mi wile alasa e"/>
                <nbspace/>
                <ITEXT CH="kon … mi sona: ni li"/>
                <nbspace/>
                <ITEXT CH="nasa. taso mi sona kin: awen li"/>
                <nbspace/>
                <ITEXT CH="nasa mute.&quot;"/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
