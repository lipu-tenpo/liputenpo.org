            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT FONT="Andika Bold" FCOLOR="unu pimeja" FSHADE="100" CH="mi lon ma pi kasi mute."/>
                <ITEXT CH=" kiwen kasi li"/>
                <nbspace/>
                <ITEXT CH="utala e"/>
                <nbspace/>
                <ITEXT CH="mi. mi utala e"/>
                <nbspace/>
                <ITEXT CH="kasi. kalama li"/>
                <nbspace/>
                <ITEXT CH="utala lon sewi. pimeja li"/>
                <nbspace/>
                <ITEXT CH="utala e"/>
                <nbspace/>
                <ITEXT CH="walo la, kon li"/>
                <nbspace/>
                <ITEXT CH="utala e"/>
                <nbspace/>
                <ITEXT CH="telo. telo sewi lili wan li"/>
                <nbspace/>
                <ITEXT CH="utala e"/>
                <nbspace/>
                <ITEXT CH="ma suli anpa. noka mi li"/>
                <nbspace/>
                <ITEXT CH="utala e"/>
                <nbspace/>
                <ITEXT CH="tawa la, mi kama lon tomo. telo mute li"/>
                <nbspace/>
                <ITEXT CH="utala e"/>
                <nbspace/>
                <ITEXT CH="ma. telo wan li"/>
                <nbspace/>
                <ITEXT CH="kama utala e"/>
                <nbspace/>
                <ITEXT CH="lawa mi. luka mi li"/>
                <nbspace/>
                <ITEXT CH="utala e"/>
                <nbspace/>
                <ITEXT CH="sinpin tomo"/>
                <nbspace/>
                <ITEXT CH="– “jan li"/>
                <nbspace/>
                <ITEXT CH="lon ala lon insa?”"/>
                <nbspace/>
                <ITEXT CH="– kalama tomo ala en kalama sewi taso en kalama telo taso li"/>
                <nbspace/>
                <ITEXT CH="utala e"/>
                <nbspace/>
                <ITEXT CH="kute mi. telo li"/>
                <nbspace/>
                <ITEXT CH="kama mute. mi lupa e"/>
                <nbspace/>
                <ITEXT CH="sinpin tomo li"/>
                <nbspace/>
                <ITEXT CH="tawa insa."/>
                <para LINESPMode="1"/>
                <ITEXT CH="telo li"/>
                <nbspace/>
                <ITEXT CH="awen kama tan sewi li"/>
                <nbspace/>
                <ITEXT CH="kama len e"/>
                <nbspace/>
                <ITEXT CH="poka ale. kule en kalama ale pi telo ala li"/>
                <nbspace/>
                <ITEXT CH="kama weka anu seme?"/>
                <nbspace/>
                <ITEXT CH="a, ala, mi kute e"/>
                <nbspace/>
                <ITEXT CH="kalama ante wan"/>
                <nbspace/>
                <ITEXT CH="– “aaaaa”"/>
                <nbspace/>
                <ITEXT CH="–"/>
                <nbspace/>
                <ITEXT CH="a, pona, ona kalama li"/>
                <nbspace/>
                <ITEXT CH="kama: jan li"/>
                <nbspace/>
                <ITEXT CH="tawa tan len pi telo mute tawa tomo la, mi kama lukin e"/>
                <nbspace/>
                <ITEXT CH="ona. ona li"/>
                <nbspace/>
                <ITEXT CH="pilin pi pona ala lon telo. luka ona la, kili mute pi kule mute li"/>
                <nbspace/>
                <ITEXT CH="awen"/>
                <nbspace/>
                <ITEXT CH="– “a, pona, alasa sina li"/>
                <nbspace/>
                <ITEXT CH="kama e"/>
                <nbspace/>
                <ITEXT CH="ijo moku”"/>
                <nbspace/>
                <ITEXT CH="– “a, pona, alasa sina li"/>
                <nbspace/>
                <ITEXT CH="kama e"/>
                <nbspace/>
                <ITEXT CH="tomo”"/>
                <nbspace/>
                <ITEXT CH="– ona li"/>
                <nbspace/>
                <ITEXT CH="tawa insa."/>
                <para LINESPMode="1"/>
                <ITEXT CH="ona li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="kili tawa mi"/>
                <nbspace/>
                <ITEXT CH="– “o"/>
                <nbspace/>
                <ITEXT CH="moku”"/>
                <nbspace/>
                <ITEXT CH="– “kili ni li"/>
                <nbspace/>
                <ITEXT CH="pona ala pona? mi wile ala moli”"/>
                <nbspace/>
                <ITEXT CH="– “pona. mi alasa e"/>
                <nbspace/>
                <ITEXT CH="sona kili lon ilo mi. sona ilo la, kili ni li"/>
                <nbspace/>
                <ITEXT CH="pona e"/>
                <nbspace/>
                <ITEXT CH="sijelo.”"/>
                <nbspace/>
                <ITEXT CH="–  mi jo, mi moku, pilin mi li"/>
                <nbspace/>
                <ITEXT CH="kama pona"/>
                <nbspace/>
                <ITEXT CH="– “sina pona"/>
                <nbspace/>
                <ITEXT CH="a. kili ni li"/>
                <nbspace/>
                <ITEXT CH="suwi pona”"/>
                <nbspace/>
                <ITEXT CH="– “sina kin li"/>
                <nbspace/>
                <ITEXT CH="suwi. sina open e"/>
                <nbspace/>
                <ITEXT CH="tomo la, telo li"/>
                <nbspace/>
                <ITEXT CH="utala ala e"/>
                <nbspace/>
                <ITEXT CH="mi”"/>
                <nbspace/>
                <ITEXT CH="– ijo li"/>
                <nbspace/>
                <ITEXT CH="nasa tawa mi lon toki ona ni"/>
                <nbspace/>
                <ITEXT CH="– “seme? sina toki e"/>
                <nbspace/>
                <ITEXT CH="mi la, sina toki ala toki e"/>
                <nbspace/>
                <ITEXT CH="suwi?”"/>
                <nbspace/>
                <ITEXT CH="– “toki”"/>
                <nbspace/>
                <ITEXT CH="– “taso kili li"/>
                <nbspace/>
                <ITEXT CH="suwi. mi moku e"/>
                <nbspace/>
                <ITEXT CH="ona. suwi ona li"/>
                <nbspace/>
                <ITEXT CH="pona e"/>
                <nbspace/>
                <ITEXT CH="mi lon moku. mi suwi la, sina wile ala wile moku e"/>
                <nbspace/>
                <ITEXT CH="mi?”"/>
                <nbspace/>
                <ITEXT CH="– “wile ala,"/>
                <nbspace/>
                <ITEXT CH="a"/>
                <nbspace/>
                <ITEXT CH="a”"/>
                <nbspace/>
                <ITEXT CH="– “ni la, mi suwi ala”"/>
                <nbspace/>
                <ITEXT CH="– “sina suwi kin”"/>
                <nbspace/>
                <ITEXT CH="– “suwi ala”"/>
                <nbspace/>
                <ITEXT CH="– “suwi kin”"/>
                <nbspace/>
