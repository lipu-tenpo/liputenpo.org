            <PAGEOBJECT XPOS="485.086044148537" YPOS="5315.67628667672" OwnPage="15" ItemID="1569127229" PTYPE="7" WIDTH="0" HEIGHT="12.5698538727618" FRTYPE="3" CLIPEDIT="1" PWIDTH="0.515606349159804" PCOLOR="FromSVG#c2c2c2" PCOLOR2="FromSVG#000000" PLINEART="1" ANNAME=" line28" TEXTFLOWMODE="1" path="M0 12.5699 L0 0 " copath="M0 12.5699 L0 0 L0 12.5699 Z" gXpos="63.1739627543337" gYpos="0.801690738073376" gWidth="68.4939706815455" gHeight="14.1732283464398" LAYER="0"/>
            <PAGEOBJECT XPOS="488.701902000055" YPOS="5315.67628667672" OwnPage="15" ItemID="1569073549" PTYPE="7" WIDTH="0" HEIGHT="12.5698468702926" FRTYPE="3" CLIPEDIT="1" PWIDTH="0.515606349159804" PCOLOR="FromSVG#c2c2c2" PCOLOR2="FromSVG#000000" PLINEART="1" ANNAME=" line29" TEXTFLOWMODE="1" path="M0 12.5699 L0 0 " copath="M0 12.5699 L0 0 L0 12.5699 Z" gXpos="66.7898206058524" gYpos="0.801690738073376" gWidth="68.4939706815455" gHeight="14.1732283464398" LAYER="0"/>
            <PAGEOBJECT XPOS="490.148248901169" YPOS="5315.67628667672" OwnPage="15" ItemID="1569070621" PTYPE="7" WIDTH="0" HEIGHT="12.5698468702926" FRTYPE="3" CLIPEDIT="1" PWIDTH="0.515606349159804" PCOLOR="FromSVG#c2c2c2" PCOLOR2="FromSVG#000000" PLINEART="1" ANNAME=" line30" TEXTFLOWMODE="1" path="M0 12.5699 L0 0 " copath="M0 12.5699 L0 0 L0 12.5699 Z" gXpos="68.2361675069656" gYpos="0.801690738073376" gWidth="68.4939706815455" gHeight="14.1732283464398" LAYER="0"/>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="589.606299212598" YPOS="1447.29353134656" OwnPage="4" ItemID="1568688653" PTYPE="4" WIDTH="167.687232133958" HEIGHT="451.919067078641" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L167.687 0 L167.687 451.919 L0 451.919 L0 0 Z" copath="M0 0 L167.687 0 L167.687 451.919 L0 451.919 L0 0 Z" gXpos="589.606299212598" gYpos="795.325027409548" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="1569166189" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT CPARENT="Text68_Bold" CH="ma ale la kasi mute li"/>
                <nbspace CPARENT="Text68_Bold"/>
                <ITEXT CPARENT="Text68_Bold" CH="lon."/>
                <ITEXT CH=" kasi kule li"/>
                <nbspace/>
                <ITEXT CH="pona tawa lukin. kasi pan li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="moku. kasi telo li"/>
                <nbspace/>
                <ITEXT CH="lon noka pi telo suli. kasi kiki¹ li"/>
                <nbspace/>
                <ITEXT CH="awen e"/>
                <nbspace/>
                <ITEXT CH="telo lon ma seli. kasi anpa li"/>
                <nbspace/>
                <ITEXT CH="len e"/>
                <nbspace/>
                <ITEXT CH="selo ma. taso kasi ni ale la kasi palisa lon ma Kaliponja li"/>
                <nbspace/>
                <ITEXT CH="suli mute. ona li"/>
                <nbspace/>
                <ITEXT CH="sewi. ona li"/>
                <nbspace/>
                <ITEXT CH="awen lon tenpo suli. nimi ona li"/>
                <nbspace/>
                <ITEXT CH="&quot;kasi palisa loje.&quot;"/>
                <para/>
                <ITEXT CH="kasi palisa loje (toki Lasina: Sequoia sempervirens) li"/>
                <nbspace/>
                <ITEXT CH="kasi pi sewi nanpa wan lon ma ale. ona li"/>
                <nbspace/>
                <ITEXT CH="ken sewi sama tomo palisa pi supa mute luka luka luka. taso kasi palisa loje li"/>
                <nbspace/>
                <ITEXT CH="lon ma lili taso lon poka pi telo Pasipi lon ma Kaliponja. ni li"/>
                <nbspace/>
                <ITEXT CH="tan seme?"/>
                <para/>
                <ITEXT CH="ma Kaliponja la kon telo li"/>
                <nbspace/>
                <ITEXT CH="lon. ni li"/>
                <nbspace/>
                <ITEXT CH="pona tawa kasi palisa loje. sina tawa ma tomo Sanpansiko la sina ken lukin e"/>
                <nbspace/>
                <ITEXT CH="kon telo walo suli. ona li"/>
                <nbspace/>
                <ITEXT CH="kama tan seme? nanpa wan la telo Pasipi li"/>
                <nbspace/>
                <ITEXT CH="lete. telo lete li"/>
                <nbspace/>
                <ITEXT CH="kama tan ma Alaka li"/>
                <nbspace/>
                <ITEXT CH="lete e"/>
                <nbspace/>
                <ITEXT CH="telo noka. tenpo seli la kon tawa li"/>
                <nbspace/>
                <ITEXT CH="tawa e"/>
                <nbspace/>
                <ITEXT CH="telo selo. ni la telo lete li"/>
                <nbspace/>
                <ITEXT CH="kama sewi li"/>
                <nbspace/>
                <ITEXT CH="lete e"/>
                <nbspace/>
                <ITEXT CH="selo pi telo Pasipi. nanpa tu la kon tawa seli li"/>
                <nbspace/>
                <ITEXT CH="kama. kon ni li"/>
                <nbspace/>
                <ITEXT CH="tawa poka sewi pi telo lete. tan ni la ona li"/>
                <nbspace/>
                <ITEXT CH="kama lete. telo lon kon ni li"/>
                <nbspace/>
                <ITEXT CH="kulupu li"/>
                <nbspace/>
                <ITEXT CH="kama sike telo lili. ni li"/>
                <nbspace/>
                <ITEXT CH="kon telo. ona li"/>
                <nbspace/>
                <ITEXT CH="lete; taso kon pi poka sewi li"/>
                <nbspace/>
                <ITEXT CH="seli. ni la kon seli li"/>
                <nbspace/>
                <ITEXT CH="poki e"/>
                <nbspace/>
                <ITEXT CH="kon telo lon poka pi selo ma. tan ni la kon telo mute li"/>
                <nbspace/>
                <ITEXT CH="lon poka telo pi ma Kaliponja. taso tan seme la kon telo ni li"/>
                <nbspace/>
                <ITEXT CH="suli tawa kasi palisa loje?"/>
                <para/>
                <ITEXT CH="kasi palisa loje li"/>
                <nbspace/>
                <ITEXT CH="wile suli e"/>
                <nbspace/>
                <ITEXT CH="telo. lon la kasi ale li"/>
                <nbspace/>
                <ITEXT CH="wile e"/>
                <nbspace/>
                <ITEXT CH="telo. linja pi noka kasi li"/>
                <nbspace/>
                <ITEXT CH="lanpan e"/>
                <nbspace/>
                <ITEXT CH="telo tan ma. telo ni li"/>
                <nbspace/>
                <ITEXT CH="tawa lon insa sijelo kasi tawa lipu. pini la lipu kasi li"/>
                <nbspace/>
                <ITEXT CH="pali e"/>
                <nbspace/>
                <ITEXT CH="wawa kepeken telo, kepeken suno, kepeken kon. kasi ale li"/>
                <nbspace/>
                <ITEXT CH="wile e"/>
                <nbspace/>
                <ITEXT CH="wawa ni tawa kama suli. ni la telo li"/>
                <nbspace/>
                <ITEXT CH="suli mute tawa suli pi kasi ale. taso kasi li"/>
                <nbspace/>
                <ITEXT CH="kama sewi la lipu li"/>
                <nbspace/>
                <ITEXT CH="kama weka tan linja noka. ni la telo li"/>
                <nbspace/>
                <ITEXT CH="ken ala tawa lipu. ike! kasi palisa loje li"/>
                <nbspace/>
                <ITEXT CH="ante. ona li"/>
                <nbspace/>
                <ITEXT CH="lanpan e"/>
                <nbspace/>
                <ITEXT CH="telo tan kon. kasi pi mute lili li"/>
                <nbspace/>
                <ITEXT CH="ken ni. seme la kasi palisa loje li"/>
                <nbspace/>
                <ITEXT CH="kepeken telo kon?"/>
                <para/>
                <ITEXT CH="kasi palisa loje li"/>
                <nbspace/>
                <ITEXT CH="moku e"/>
                <nbspace/>
                <ITEXT CH="telo tan kon kepeken nasin tu wan. nanpa wan la ona li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="“lipu telo.” mute la lipu kasi li"/>
                <nbspace/>
                <ITEXT CH="pali e"/>
                <nbspace/>
                <ITEXT CH="wawa kepeken suno. kasi palisa loje li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="lipu ni. taso ona li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="lipu ante kin. lipu ante ni li"/>
                <nbspace/>
                <ITEXT CH="pali e"/>
                <nbspace/>
                <ITEXT CH="wawa lili li"/>
                <nbspace/>
                <ITEXT CH="lanpan e"/>
                <nbspace/>
                <ITEXT CH="telo mute. tan ni la ona li"/>
                <nbspace/>
                <ITEXT CH="lipu telo. nanpa tu la, selo kin pi kasi palisa loje li"/>
                <nbspace/>
                <ITEXT CH="ken lanpan e"/>
                <nbspace/>
                <ITEXT CH="telo. kasi ale la telo li"/>
                <nbspace/>
                <ITEXT CH="ken tawa lon insa sijelo. taso kasi mute la telo li"/>
                <nbspace/>
                <ITEXT CH="ken ala tawa insa tan selo. ante la selo pi kasi palisa loje li"/>
                <nbspace/>
                <ITEXT CH="ken tawa e"/>
                <nbspace/>
                <ITEXT CH="telo. telo li"/>
                <nbspace/>
                <ITEXT CH="lon selo la ona li"/>
                <nbspace/>
                <ITEXT CH="ken tawa insa. wawa! nanpa tu wan la kon telo li"/>
                <nbspace/>
                <ITEXT CH="tawa anpa. kon telo li"/>
                <nbspace/>
                <ITEXT CH="kama lon kasi palisa loje la ona li"/>
                <nbspace/>
                <ITEXT CH="kulupu. telo ni li"/>
                <nbspace/>
                <ITEXT CH="kama anpa tawa supa ma. linja noka pi kasi palisa loje li"/>
                <nbspace/>
                <ITEXT CH="ken lanpan e"/>
                <nbspace/>
                <ITEXT CH="telo ni. kama la telo ni li"/>
                <nbspace/>
                <ITEXT CH="tawa lon insa sijelo kasi tawa lipu suno."/>
                <para/>
                <ITEXT CH="ale la tenpo li"/>
                <nbspace/>
                <ITEXT CH="tawa; taso kasi li"/>
                <nbspace/>
                <ITEXT CH="awen. ona li"/>
                <nbspace/>
                <ITEXT CH="awen lon seli lon lete, lon suno lon telo, lon open lon pini. suli nanpa wan la kasi palisa loje li"/>
                <nbspace/>
                <ITEXT CH="awen lon kon telo pi ma Kaliponja."/>
                <para/>
                <ITEXT CH="¹  kiki la selo kasi li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="palisa lili. ijo li"/>
                <nbspace/>
                <ITEXT CH="luka e"/>
                <nbspace/>
                <ITEXT CH="palisa la palisa li"/>
                <nbspace/>
                <ITEXT CH="pakala e"/>
                <nbspace/>
                <ITEXT CH="ona."/>
                <para PARENT="toki lili poka"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="771.647961726303" YPOS="1360.62992125984" OwnPage="4" ItemID="1569166189" PTYPE="4" WIDTH="172.289046147713" HEIGHT="538.582677165354" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L172.289 0 L172.289 538.583 L0 538.583 L0 0 Z" copath="M0 0 L172.289 0 L172.289 538.583 L0 538.583 L0 0 Z" gXpos="771.647961726302" gYpos="708.661417322834" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="-1" BACKITEM="1568688653"/>
        <PAGEOBJECT XPOS="178.582677165354" YPOS="1828.77165354331" OwnPage="3" ItemID="1569193069" PTYPE="4" WIDTH="354.330708661417" HEIGHT="51.0236220472436" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="3" COLGAP="14.1732283464567" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L354.331 0 L354.331 51.0236 L0 51.0236 L0 0 Z" copath="M0 0 L354.331 0 L354.331 51.0236 L0 51.0236 L0 0 Z" gXpos="598.110236220472" gYpos="1176.8031496063" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="1569087357" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT CH="pona"/>
                <nbspace/>
                <ITEXT CH="a,"/>
                <breakline/>
                <ITEXT CH="tenpo pi suno open,"/>
                <breakline/>
                <ITEXT CH="tenpo pi kalama ala."/>
                <breakline/>
                <ITEXT CH="mi taso li"/>
                <nbspace/>
                <ITEXT CH="lape ala,"/>
                <breakline/>
                <ITEXT CH="jan ante li"/>
                <nbspace/>
                <ITEXT CH="lape awen."/>
                <breakline/>
                <para/>
                <ITEXT CH="telo wawa pimeja li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="kon nena,"/>
                <breakline/>
                <ITEXT CH="kin ale li"/>
                <nbspace/>
                <ITEXT CH="tawa ala."/>
                <para/>
                <ITEXT CH="taso. a! ike! mi kute e"/>
                <nbspace/>
                <ITEXT CH="kalama tan tomo lape."/>
                <trail ALIGN="1"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="178.582677165354" YPOS="1879.79527559055" OwnPage="3" ItemID="1569087357" PTYPE="4" WIDTH="354.330708661417" HEIGHT="18.6632114023719" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L354.331 0 L354.331 18.6632 L0 18.6632 L0 0 Z" copath="M0 0 L354.331 0 L354.331 18.6632 L0 18.6632 L0 0 Z" gXpos="598.110236220471" gYpos="1227.82677165354" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="-1" BACKITEM="1569193069"/>
