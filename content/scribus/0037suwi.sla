        <PAGEOBJECT XPOS="589.606299212598" YPOS="2669.51799063092" OwnPage="8" ItemID="390019869" PTYPE="6" WIDTH="151.358118209907" HEIGHT="78.9975082228644" FRTYPE="3" CLIPEDIT="1" PWIDTH="0.803556884789528" PCOLOR="laso walo" PLINEART="1" ANNAME="Copy of  path21 (2)" TEXTFLOWMODE="1" path="M0.237296 38.4273 C-0.864338 50.3977 1.50213 62.9713 15.1924 69.7539 C28.8825 76.5364 53.8955 77.5274 77.8313 78.4193 C101.767 79.3113 124.623 80.104 137.296 73.2189 C149.965 66.3339 152.449 51.7716 150.983 39.7474 C149.518 27.723 144.103 18.2379 129.834 11.559 C115.566 4.88001 92.4467 1.00794 71.0781 0.169781 C49.7098 -0.668381 30.0947 1.52732 18.0018 8.3088 C5.90862 15.0902 1.33894 26.457 0.237296 38.4273 L0.237296 38.4273 Z" copath="M0.237296 38.4273 C-0.864338 50.3977 1.50213 62.9713 15.1924 69.7539 C28.8825 76.5364 53.8955 77.5274 77.8313 78.4193 C101.767 79.3113 124.623 80.104 137.296 73.2189 C149.965 66.3339 152.449 51.7716 150.983 39.7474 C149.518 27.723 144.103 18.2379 129.834 11.559 C115.566 4.88001 92.4467 1.00794 71.0781 0.169781 C49.7098 -0.668381 30.0947 1.52732 18.0018 8.3088 C5.90862 15.0902 1.33894 26.457 0.237296 38.4273 L0.237296 38.4273 Z" fillRule="0" gXpos="-615.968503937007" gYpos="1957.73846307186" gWidth="143.230906275112" gHeight="62.2305727060714" LAYER="0"/>
        <PAGEOBJECT XPOS="589.606299212598" YPOS="2790.04006777634" OwnPage="8" ItemID="442517197" PTYPE="4" WIDTH="170.078543307087" HEIGHT="413.109538522875" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L170.079 0 L170.079 413.11 L0 413.11 L0 0 Z" copath="M0 0 L170.079 0 L170.079 413.11 L0 413.11 L0 0 Z" gXpos="1009.13385826772" gYpos="3442.00857171334" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="477563629" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT CPARENT="Text99_Bold" FCOLOR="laso pimeja" FSHADE="100" CH="tenpo pini la"/>
                <ITEXT CH=" mi toki e"/>
                <nbspace/>
                <ITEXT CH="ma Wasikano e"/>
                <nbspace/>
                <ITEXT CH="ma Monako e"/>
                <nbspace/>
                <ITEXT CH="ma Samalino. ona li"/>
                <nbspace/>
                <ITEXT CH="ma lawa pi lili mute lon ma suli Elopa. tenpo ni la, mi wile toki e"/>
                <nbspace/>
                <ITEXT CH="ma Lisensan e"/>
                <nbspace/>
                <ITEXT CH="ma Mata. ona li"/>
                <nbspace/>
                <ITEXT CH="ma pi lili mute kin. o"/>
                <nbspace/>
                <ITEXT CH="kama sona e"/>
                <nbspace/>
                <ITEXT CH="pona ona."/>
                <para/>
                <ITEXT CH="ma Lisensan"/>
                <para PARENT="jan pali"/>
                <ITEXT CH="ma Elopa la ma Lisensan li"/>
                <nbspace/>
                <ITEXT CH="ma lawa pi lili nanpa tu tu. ona li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="nena suli mute. ona li"/>
                <nbspace/>
                <ITEXT CH="lon ala poka pi telo suli. ma taso li"/>
                <nbspace/>
                <ITEXT CH="lon poka ona. ma lawa pi poka ona kin li"/>
                <nbspace/>
                <ITEXT CH="lon ala poka pi telo suli. ma ale la ma lawa ante wan taso li"/>
                <nbspace/>
                <ITEXT CH="sama."/>
                <para/>
                <ITEXT CH="ma tomo Watu li"/>
                <nbspace/>
                <ITEXT CH="lawa e"/>
                <nbspace/>
                <ITEXT CH="ma Lisensan. tomo pi jan lawa li"/>
                <nbspace/>
                <ITEXT CH="lon poka ona. tenpo suno luka luka luka lon mun luka tu wan li"/>
                <nbspace/>
                <ITEXT CH="sewi e"/>
                <nbspace/>
                <ITEXT CH="ma. tenpo ni la jan ale li"/>
                <nbspace/>
                <ITEXT CH="ken kama tawa ma kasi lon poka tomo pi jan lawa. ona li"/>
                <nbspace/>
                <ITEXT CH="ken kute e"/>
                <nbspace/>
                <ITEXT CH="jan lawa li"/>
                <nbspace/>
                <ITEXT CH="ken moku e"/>
                <nbspace/>
                <ITEXT CH="telo nasa lili. ni li"/>
                <nbspace/>
                <ITEXT CH="wile e"/>
                <nbspace/>
                <ITEXT CH="lipu taso e"/>
                <nbspace/>
                <ITEXT CH="mani ala. tenpo pimeja la jan li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="suno wawa pi kule mute tawa sewi."/>
                <para/>
                <ITEXT CH="ma Lisensan li"/>
                <nbspace/>
                <ITEXT CH="ma pi esun wawa. nasa la, sitelen pi tomo mani pi ma Lisensan li"/>
                <nbspace/>
                <ITEXT CH="sama sitelen pona ‘tu sina’ tawa lukin!"/>
                <para/>
                <ITEXT CH="ma Mata"/>
                <para PARENT="jan pali"/>
                <ITEXT CH="ma Elopa la ma Mata li"/>
                <nbspace/>
                <ITEXT CH="ma pi lili nanpa luka. telo li"/>
                <nbspace/>
                <ITEXT CH="sike e"/>
                <nbspace/>
                <ITEXT CH="ona. suno en tawa telo li"/>
                <nbspace/>
                <ITEXT CH="pona tawa sina la ma ni li"/>
                <nbspace/>
                <ITEXT CH="pona mute tawa sina!"/>
                <para/>
                <ITEXT CH="sike suno MMMMLA pini la jan open li"/>
                <nbspace/>
                <ITEXT CH="kama lon ma ni. jan li"/>
                <nbspace/>
                <ITEXT CH="pali e"/>
                <nbspace/>
                <ITEXT CH="tomo kiwen pi suli mute. tenpo ni la, tomo ni li"/>
                <nbspace/>
                <ITEXT CH="majuna mute, taso ona li"/>
                <nbspace/>
                <ITEXT CH="awen lon"/>
                <nbspace/>
                <ITEXT CH="a!"/>
                <para/>
                <ITEXT CH="tenpo pini la, ma Mata li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="waso walo pi suli mute ("/>
                <ITEXT CPARENT="Text121_Italic" CH="Cygnus falconeri"/>
                <ITEXT CH=") e"/>
                <nbspace/>
                <ITEXT CH="soweli pi lili mute pi nena linja ("/>
                <ITEXT CPARENT="Text121_Italic" CH="Palaeoloxodon falconeri"/>
                <ITEXT CH=") e"/>
                <nbspace/>
                <ITEXT CH="soweli ante mute. ike la, ona ale li"/>
                <nbspace/>
                <ITEXT CH="moli. taso sina awen ken lukin e"/>
                <nbspace/>
                <ITEXT CH="kiwen ona li"/>
                <nbspace/>
                <ITEXT CH="ken kama sona e"/>
                <nbspace/>
                <ITEXT CH="ona lon lupa Atalan ("/>
