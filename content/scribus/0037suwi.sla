            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT CH="open"/>
                <para PARENT="jan pali"/>
                <ITEXT CH="musi lipu pi meli pimeja (toki Inli la “Black Lady”) la, sina wile kama ala jo e"/>
                <nbspace/>
                <ITEXT CH="lipu tan supa! tan seme? sina wile weka tan lipu pilin (♥️) tan lipu ilo pi meli lawa (Q♠️)"/>
                <nbspace/>
                <ITEXT CH="a! musi ni li"/>
                <nbspace/>
                <ITEXT CH="lon nasin ilo Winto lon tenpo pini. nimi ante pi musi ni li"/>
                <nbspace/>
                <ITEXT CH="musi lipu pilin (toki Inli la “Hearts”)."/>
                <para/>
                <ITEXT CH="musi ni li"/>
                <nbspace/>
                <ITEXT CH="kepeken lipu Kanse. lipu li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="kule (kasi: ♣️, ilo: ♠️, pilin: ♥️, kiwen: ♦️) e"/>
                <nbspace/>
                <ITEXT CH="nanpa (A, K, Q, J, 10, 9, 8, 7, 6, 5, 4, 3, 2). musi ni la, lipu pi jan musi (Joker) li"/>
                <nbspace/>
                <ITEXT CH="lon ala. jan tu tu li"/>
                <nbspace/>
                <ITEXT CH="musi li"/>
                <nbspace/>
                <ITEXT CH="lon nasin sike lon supa. ona li"/>
                <nbspace/>
                <ITEXT CH="wile kama jo e"/>
                <nbspace/>
                <ITEXT CH="nanpa pi lili mute. jan li"/>
                <nbspace/>
                <ITEXT CH="sitelen e"/>
                <nbspace/>
                <ITEXT CH="nanpa lon lipu ante."/>
                <para/>
                <ITEXT CH="sike"/>
                <para PARENT="jan pali"/>
                <ITEXT CH="open sike la, jan wan li"/>
                <nbspace/>
                <ITEXT CH="nasa e"/>
                <nbspace/>
                <ITEXT CH="lipu ale. ona li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="lipu luka luka tu wan (13) tawa jan ale tawa ona sama. jan ale li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="lipu tu wan tawa jan ante."/>
                <para/>
                <ITEXT CH="sike nanpa wan (1) la, jan li"/>
                <nbspace/>
                <ITEXT CH="pana tawa jan soto."/>
                <para PARENT="Text74_List 2"/>
                <ITEXT CH="sike nanpa tu (2) la, jan li"/>
                <nbspace/>
                <ITEXT CH="pana tawa jan teje."/>
                <para PARENT="Text74_List 2"/>
                <ITEXT CH="sike nanpa tu wan (3) la, jan li"/>
                <nbspace/>
                <ITEXT CH="pana tawa jan pi poka ante supa."/>
                <para PARENT="Text74_List 2"/>
                <ITEXT CH="sike nanpa tu tu (4) la, jan li"/>
                <nbspace/>
                <ITEXT CH="pana ala."/>
                <para PARENT="Text74_List 2"/>
                <ITEXT CH="sike pana ni li"/>
                <nbspace/>
                <ITEXT CH="awen sin lon sike kama."/>
                <para PARENT="Text74_List 2"/>
                <ITEXT CH="jan pi lipu kasi nanpa tu (2♣️) o"/>
