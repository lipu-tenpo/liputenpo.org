                <nbspace/>
                <ITEXT CH="sitelen e"/>
                <nbspace/>
                <ITEXT CH="toki “telo li"/>
                <nbspace/>
                <ITEXT CH="tawa lon insa mi.” ken la telo li"/>
                <nbspace/>
                <ITEXT CH="lon insa ona li"/>
                <nbspace/>
                <ITEXT CH="tawa, ken la insa ona li"/>
                <nbspace/>
                <ITEXT CH="lon ma la, telo li"/>
                <nbspace/>
                <ITEXT CH="lon sewi pi insa ona. mi lukin e"/>
                <nbspace/>
                <ITEXT CH="ni la mi ken ala toki e"/>
                <nbspace/>
                <ITEXT CH="ni: o"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="sona sin tawa mi."/>
                <para/>
                <ITEXT CH="taso, kepeken sitelen sin mi la mi sona pona e"/>
                <nbspace/>
                <ITEXT CH="sitelen ale pi jan ante. sitelen sin mi la, jan li"/>
                <nbspace/>
                <ITEXT CH="sitelen e"/>
                <nbspace/>
                <ITEXT CH="toki wan ni lon nasin ante tu."/>
                <para/>
                <ITEXT CH="sina wile ala wile kama sona e"/>
                <nbspace/>
                <ITEXT CH="sitelen leko? wile la o"/>
                <nbspace/>
                <ITEXT CH="lukin e"/>
                <nbspace/>
                <ITEXT CH="lipu mi¹. mi wile e"/>
                <nbspace/>
                <ITEXT CH="ijo ala tan sina li"/>
                <nbspace/>
                <ITEXT CH="wile pana taso e"/>
                <nbspace/>
                <ITEXT CH="sona pi sitelen mi."/>
                <para/>
