                <nbspace/>
                <ITEXT CH="kama nasa tawa ona kin"/>
                <nbspace/>
                <ITEXT CH="– “lon la, sina suwi. taso mi sona tan seme? kili ni la, mi kama sona kepeken uta”"/>
