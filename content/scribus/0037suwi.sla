        <PAGEOBJECT XPOS="178.580883085815" YPOS="3427.13385826772" OwnPage="9" ItemID="1576558013" PTYPE="4" WIDTH="170.078543307087" HEIGHT="416.692913385825" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L170.079 0 L170.079 416.693 L0 416.693 L0 0 Z" copath="M0 0 L170.079 0 L170.079 416.693 L0 416.693 L0 0 Z" gXpos="598.108442140934" gYpos="2775.1653543307" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="1576631933" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT FONT="Andika Bold" FCOLOR="laso pimeja" FSHADE="100" CH="sina moku la, sijelo sina li"/>
                <nbspace FONT="Andika Bold" FCOLOR="laso pimeja" FSHADE="100"/>
                <ITEXT FONT="Andika Bold" FCOLOR="laso pimeja" FSHADE="100" CH="kama wawa tan suwi moku."/>
                <ITEXT CH=" tawa ni la, sijelo o"/>
                <nbspace/>
                <ITEXT CH="lawa e"/>
                <nbspace/>
                <ITEXT CH="suwi sijelo kepeken ijo. nasin sijelo pi pakala moku la, insa wan li"/>
                <nbspace/>
                <ITEXT CH="pali e"/>
                <nbspace/>
                <ITEXT CH="ijo ni. insa ni li"/>
                <nbspace/>
                <ITEXT CH="lawa e"/>
                <nbspace/>
                <ITEXT CH="mute suwi lon telo loje, li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="ijo mute tawa telo loje. tenpo mute la, ale li"/>
                <nbspace/>
                <ITEXT CH="pona. taso, tenpo la, insa ni li"/>
                <nbspace/>
                <ITEXT CH="pakala. jan sona li"/>
                <nbspace/>
                <ITEXT CH="sona pona ala e"/>
                <nbspace/>
                <ITEXT CH="tan pi pakala ni."/>
                <para/>
                <ITEXT CH="kule tu"/>
                <para PARENT="jan pali"/>
                <ITEXT CH="pakala pi insa ni la, kule suli tu li"/>
                <nbspace/>
                <ITEXT CH="lon. kule nanpa tu la, insa li"/>
                <nbspace/>
                <ITEXT CH="pali mute li"/>
                <nbspace/>
                <ITEXT CH="kama wawa ala. tenpo mute la, jan li"/>
                <nbspace/>
                <ITEXT CH="lon kulupu ni la, jan pi kulupu mama ona kin li"/>
                <nbspace/>
                <ITEXT CH="sama ni. kin, tenpo mute la, insa ni jan li"/>
                <nbspace/>
                <ITEXT CH="pakala la, kule li"/>
                <nbspace/>
                <ITEXT CH="nanpa tu. (kulupu pi pakala ni li"/>
                <nbspace/>
                <ITEXT CH="lon la, jan luka tu tu li"/>
                <nbspace/>
                <ITEXT CH="kule nanpa tu; jan wan li"/>
                <nbspace/>
                <ITEXT CH="kule nanpa wan)."/>
                <para/>
                <ITEXT CH="pakala insa pi kule nanpa wan li"/>
                <nbspace/>
                <ITEXT CH="seme? sijelo li"/>
                <nbspace/>
                <ITEXT CH="utala e"/>
                <nbspace/>
                <ITEXT CH="jaki. taso tenpo mute la, ike la, sijelo li"/>
                <nbspace/>
                <ITEXT CH="utala pakala e"/>
                <nbspace/>
                <ITEXT CH="sijelo li"/>
                <nbspace/>
                <ITEXT CH="pakala e"/>
                <nbspace/>
                <ITEXT CH="ona. sijelo li"/>
                <nbspace/>
                <ITEXT CH="utala e"/>
                <nbspace/>
                <ITEXT CH="insa pi lawa suwi la, kule nanpa wan li"/>
                <nbspace/>
                <ITEXT CH="lon. mi lon kulupu ni. mi lili la, insa ni li"/>
                <nbspace/>
                <ITEXT CH="pakala."/>
                <para/>
                <ITEXT CH="mute la, pakala insa li"/>
                <nbspace/>
                <ITEXT CH="sama kule nanpa tu. insa li"/>
                <nbspace/>
                <ITEXT CH="ken ala pali mute e"/>
                <nbspace/>
                <ITEXT CH="ijo pi lawa suwi. taso, mute la, ona li"/>
                <nbspace/>
                <ITEXT CH="sama ala. tenpo mute la, kule nanpa tu li"/>
                <nbspace/>
                <ITEXT CH="kama lon tenpo pi suli jan. tenpo mute la, kule nanpa wan li"/>
                <nbspace/>
                <ITEXT CH="kama lon tenpo pi lili jan anu suli lili. kin, kule nanpa tu la, insa li"/>
                <nbspace/>
                <ITEXT CH="awen pali lili e"/>
                <nbspace/>
                <ITEXT CH="ijo lawa. kule nanpa wan la, insa li"/>
                <nbspace/>
                <ITEXT CH="pali ala e"/>
                <nbspace/>
                <ITEXT CH="ijo ni. jan pi kule nanpa wan li"/>
                <nbspace/>
                <ITEXT CH="wile kama jo e"/>
                <nbspace/>
                <ITEXT CH="ijo lawa tan misikeke lon tenpo ale. tenpo la, kulupu pi kule nanpa tu li"/>
                <nbspace/>
                <ITEXT CH="ken kepeken misikeke ante tawa lawa pi suwi sijelo."/>
                <para/>
                <ITEXT CH="ijo lawa"/>
                <para PARENT="jan pali"/>
                <ITEXT CH="tenpo pini la, jan li"/>
                <nbspace/>
                <ITEXT CH="kule nanpa wan la, ale la, jan li"/>
                <nbspace/>
                <ITEXT CH="moli. ken la, ona li"/>
                <nbspace/>
                <ITEXT CH="awen lon sike wan anu sike tu li"/>
                <nbspace/>
                <ITEXT CH="pilin ike li"/>
                <nbspace/>
                <ITEXT CH="ken ala moku mute. taso, lon tenpo sike nanpa luka luka luka tu tu ale mute wan (1921) la, jan Petewi Pansin (Frederick Banting) en jan ante li"/>
                <nbspace/>
                <ITEXT CH="kama sona e"/>
                <nbspace/>
                <ITEXT CH="nasin tawa ni: jan li"/>
                <nbspace/>
                <ITEXT CH="ken kama jo e"/>
                <nbspace/>
                <ITEXT CH="ijo lawa tan insa soweli. ona li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="ijo tawa jan pi kule nanpa wan la, ona li"/>
                <nbspace/>
                <ITEXT CH="moli ala. ni li"/>
                <nbspace/>
                <ITEXT CH="pona mute"/>
                <nbspace/>
                <ITEXT CH="a!"/>
                <para/>
                <ITEXT CH="taso, tenpo mute la, jaki li"/>
                <nbspace/>
                <ITEXT CH="lon ijo ni soweli. jan li"/>
                <nbspace/>
                <ITEXT CH="sona pona ala e"/>
                <nbspace/>
                <ITEXT CH="ni: ona li"/>
                <nbspace/>
                <ITEXT CH="ken kama jo e"/>
                <nbspace/>
                <ITEXT CH="ijo ni tan insa soweli kepeken seme? jaki la, jan li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="ijo tawa jan pi kule nanpa wan la, sijelo ona li"/>
                <nbspace/>
                <ITEXT CH="pilin ike li"/>
                <nbspace/>
                <ITEXT CH="ken kama moli. ni li"/>
                <nbspace/>
                <ITEXT CH="ike. kepeken sike mute la, sona li"/>
                <nbspace/>
                <ITEXT CH="kama pona lon nasin pi kama jo. taso, nasin pi pona mute li"/>
                <nbspace/>
                <ITEXT CH="kama."/>
                <para/>
                <ITEXT CH="sike nanpa luka luka luka tu tu ale mute mute mute luka luka luka tu wan (1978) la, jan sona li"/>
                <nbspace/>
                <ITEXT CH="pali e"/>
                <nbspace/>
                <ITEXT CH="ijo ni kepeken ijo jaki pi lili mute. ijo jaki ni li"/>
                <nbspace/>
                <ITEXT CH="lon insa moku pi sijelo ale. kepeken nasin ni la, jan li"/>
                <nbspace/>
                <ITEXT CH="ken kama jo e"/>
                <nbspace/>
                <ITEXT CH="ijo ni pi mute suli kepeken pali lili. kin, ona li"/>
                <nbspace/>
                <ITEXT CH="jaki ala li"/>
                <nbspace/>
                <ITEXT CH="sama ijo ni tan insa jan. ni la, sijelo pi jan pi kule nanpa wan li"/>
                <nbspace/>
                <ITEXT CH="kama ala pilin ike. taso, jan ni li"/>
                <nbspace/>
                <ITEXT CH="wile awen pona la, ona o"/>
                <nbspace/>
                <ITEXT CH="awen pana e"/>
                <nbspace/>
                <ITEXT CH="ijo ni kepeken palisa lili tawa telo sijelo ona lon tenpo moku ale. ni li"/>
                <nbspace/>
                <ITEXT CH="pali mute."/>
                <para/>
                <ITEXT CH="ilo sin"/>
                <para PARENT="jan pali"/>
                <ITEXT CH="tenpo poka la, ilo pana ante li"/>
                <nbspace/>
                <ITEXT CH="kama lon. ilo ni li"/>
                <nbspace/>
                <ITEXT CH="awen e"/>
                <nbspace/>
                <ITEXT CH="telo lon ona lon suno tu wan li"/>
                <nbspace/>
                <ITEXT CH="awen pana e"/>
                <nbspace/>
                <ITEXT CH="telo lili tawa sijelo lon tenpo ale. ni la, mute pi telo ni li"/>
                <nbspace/>
                <ITEXT CH="ken ante lon tenpo ante. jan li"/>
                <nbspace/>
                <ITEXT CH="ken lawa pona e"/>
                <nbspace/>
                <ITEXT CH="suwi ona li"/>
                <nbspace/>
                <ITEXT CH="wile ala kepeken palisa lili mute lon tenpo moku ale."/>
                <para/>
                <ITEXT CH="kin, tenpo pini la, ona li"/>
                <nbspace/>
                <ITEXT CH="wile sona e"/>
                <nbspace/>
                <ITEXT CH="mute suwi lon telo sijelo lon tenpo ale la, ona li"/>
                <nbspace/>
                <ITEXT CH="wile pana e"/>
                <nbspace/>
                <ITEXT CH="telo jelo jaki lon lipu. ni la, ona li"/>
                <nbspace/>
                <ITEXT CH="sona lili e"/>
                <nbspace/>
                <ITEXT CH="suwi ona. taso nasin sin li"/>
                <nbspace/>
                <ITEXT CH="kama lon. nasin ni la, jan li"/>
                <nbspace/>
                <ITEXT CH="ken kepeken telo loje li"/>
                <nbspace/>
                <ITEXT CH="ken sona pona e"/>
                <nbspace/>
                <ITEXT CH="mute suwi ona. nasin ni li"/>
                <nbspace/>
                <ITEXT CH="wawa."/>
                <para/>
                <ITEXT CH="tenpo kama la, nasin pi wawa mute li"/>
                <nbspace/>
                <ITEXT CH="kama lon. ni li"/>
                <nbspace/>
                <ITEXT CH="ilo pi sona suwi pi tenpo ale (ilo CGM). tenpo suli ala la, ilo ni li"/>
                <nbspace/>
                <ITEXT CH="lon. taso, mi ale pi pakala ni la, ona li"/>
                <nbspace/>
                <ITEXT CH="ante mute e"/>
                <nbspace/>
                <ITEXT CH="lon. kepeken ilo ni la, jan li"/>
                <nbspace/>
                <ITEXT CH="ken lukin e"/>
                <nbspace/>
                <ITEXT CH="mute suwi ona lon tenpo ale kepeken ala telo loje ona. ona li"/>
                <nbspace/>
                <ITEXT CH="ken pana e"/>
                <nbspace/>
                <ITEXT CH="sona ni tawa jan misikeke ona tawa kulupu poka ona. suwi sijelo li"/>
                <nbspace/>
                <ITEXT CH="kama lili la, jan li"/>
                <nbspace/>
                <ITEXT CH="ken sona e"/>
                <nbspace/>
                <ITEXT CH="ni tan ilo li"/>
                <nbspace/>
                <ITEXT CH="ken suli e"/>
                <nbspace/>
                <ITEXT CH="suwi kepeken moku suwi. suwi sijelo li"/>
                <nbspace/>
                <ITEXT CH="kama mute ike la, jan li"/>
                <nbspace/>
                <ITEXT CH="ken sona e"/>
                <nbspace/>
                <ITEXT CH="ni kin tan ilo li"/>
                <nbspace/>
                <ITEXT CH="ken lili e"/>
                <nbspace/>
                <ITEXT CH="suwi kepeken ijo pi lawa suwi. tenpo pini la, jan li"/>
                <nbspace/>
                <ITEXT CH="ken sona e"/>
                <nbspace/>
                <ITEXT CH="suwi sijelo tan pilin anu ilo pi telo loje taso."/>
                <para/>
                <ITEXT CH="tenpo poka la, ilo pana en ilo pi sona suwi li"/>
                <nbspace/>
                <ITEXT CH="ken ala toki. ni la, jan o"/>
                <nbspace/>
                <ITEXT CH="pali mute. taso, ilo sin li"/>
                <nbspace/>
                <ITEXT CH="kama lon li"/>
                <nbspace/>
                <ITEXT CH="kepeken nasin kon &quot;laso&quot; pi toki ilo (nasin Bluetooth). ilo ni li"/>
                <nbspace/>
                <ITEXT CH="sona e"/>
                <nbspace/>
                <ITEXT CH="suwi tan ilo pi sona suwi li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="ni tawa ilo pana: o"/>
                <nbspace/>
                <ITEXT CH="ante e"/>
                <nbspace/>
                <ITEXT CH="pana sina. ni la, ilo li"/>
                <nbspace/>
                <ITEXT CH="lawa pona e"/>
                <nbspace/>
                <ITEXT CH="suwi sijelo. kulupu esun li"/>
                <nbspace/>
                <ITEXT CH="pana ala e"/>
                <nbspace/>
                <ITEXT CH="ilo ni. jan pi kule nanpa wan en jan poka ona li"/>
                <nbspace/>
                <ITEXT CH="pali e"/>
                <nbspace/>
                <ITEXT CH="ilo ni. mi kepeken ilo toki ni. ona li"/>
                <nbspace/>
                <ITEXT CH="pona mute tawa mi li"/>
                <nbspace/>
                <ITEXT CH="lili e"/>
                <nbspace/>
                <ITEXT CH="pali mi li"/>
                <nbspace/>
                <ITEXT CH="lawa pona e"/>
                <nbspace/>
                <ITEXT CH="suwi mi. tenpo ni la, esun mute li"/>
                <nbspace/>
                <ITEXT CH="pali e"/>
                <nbspace/>
                <ITEXT CH="ilo sama ni. ni la, jan mute li"/>
                <nbspace/>
                <ITEXT CH="ken kepeken ilo sama ni. taso, mi awen kepeken ilo pi esun ala."/>
                <para/>
                <ITEXT CH="mani mute"/>
                <para PARENT="jan pali"/>
                <ITEXT CH="ijo ale ni li"/>
                <nbspace/>
                <ITEXT CH="pona, taso, ijo ike li"/>
                <nbspace/>
                <ITEXT CH="awen lon tenpo poka. esun pi sona sijelo li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="ijo ni e"/>
                <nbspace/>
                <ITEXT CH="ilo ni la, ma Mewika la, tenpo suli la, ona li"/>
                <nbspace/>
                <ITEXT CH="wile e"/>
                <nbspace/>
                <ITEXT CH="mani pi mute wawa. tenpo la, jan li"/>
                <nbspace/>
                <ITEXT CH="moli tan ni: ona li"/>
                <nbspace/>
                <ITEXT CH="ken ala esun e"/>
                <nbspace/>
                <ITEXT CH="ijo ni. ni li"/>
                <nbspace/>
                <ITEXT CH="ken sama tenpo pini weka, lon tenpo pi ijo ni ala. tenpo la, ona li"/>
                <nbspace/>
                <ITEXT CH="kepeken ijo pi pona lili, ni li"/>
                <nbspace/>
                <ITEXT CH="lili ike e"/>
                <nbspace/>
                <ITEXT CH="suwi ona. ante la, ona li"/>
                <nbspace/>
                <ITEXT CH="kepeken ala ijo ni la, suwi ona li"/>
                <nbspace/>
                <ITEXT CH="awen mute ike la, sijelo ona li"/>
                <nbspace/>
                <ITEXT CH="kama pakala. ma mute la, lipu lawa li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="ni: ijo ni o"/>
                <nbspace/>
                <ITEXT CH="wile ala e"/>
                <nbspace/>
                <ITEXT CH="mani mute. ijo ni li"/>
                <nbspace/>
                <ITEXT CH="suli tawa sijelo. tenpo poka la, lawa pi ma Mewika li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="ni kin. ni li"/>
                <nbspace/>
                <ITEXT CH="pona mute"/>
                <nbspace/>
                <ITEXT CH="a! taso, ijo mute li"/>
                <nbspace/>
                <ITEXT CH="awen wile e"/>
                <nbspace/>
