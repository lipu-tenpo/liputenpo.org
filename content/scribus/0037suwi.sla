                <ITEXT CH="lukin e"/>
                <nbspace/>
                <ITEXT CH="sitelen. sitelen seme li"/>
                <nbspace/>
                <ITEXT CH="pona tawa sina? sitelen pona li"/>
                <nbspace/>
                <ITEXT CH="pona tawa jan mute. sitelen sitelen li"/>
                <nbspace/>
                <ITEXT CH="pona tawa jan mute ante. taso, lon tenmpo pini la mi wile pali e"/>
                <nbspace/>
                <ITEXT CH="sitelen sin… e"/>
                <nbspace/>
                <ITEXT CH="sitelen mi. tan ni la mi pali e"/>
                <nbspace/>
                <ITEXT CH="sitelen sin. nimi ona la mi toki e"/>
                <nbspace/>
                <ITEXT CH="sitelen leko anu sitelen Kuwi!"/>
                <para/>
                <ITEXT CH="mi pali e"/>
                <nbspace/>
                <ITEXT CH="sitelen sin tan seme? n… mi toki e"/>
                <nbspace/>
                <ITEXT CH="ni lon lawa mi: tenpo ale ala la mi sona pona e"/>
                <nbspace/>
                <ITEXT CH="toki pi jan ante. o"/>
                <nbspace/>
                <ITEXT CH="lukin e"/>
                <nbspace/>
