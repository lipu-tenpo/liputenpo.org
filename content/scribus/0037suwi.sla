                <nbspace/>
                <ITEXT CH="– “aaa”"/>
                <nbspace/>
                <ITEXT CH="– “aa. o"/>
                <nbspace/>
                <ITEXT CH="kute. sina wile ala e"/>
                <nbspace/>
                <ITEXT CH="nimi suwi lon sina la, mi kepeken ala nimi suwi lon sina”"/>
