        <PAGEOBJECT XPOS="173.149439823165" YPOS="2022.44803149606" OwnPage="5" ItemID="1828050049" PTYPE="6" WIDTH="178.582708661417" HEIGHT="55.3484401475134" FRTYPE="3" CLIPEDIT="1" PWIDTH="1.3277485984483" PCOLOR="laso walo" PLINEART="1" ANNAME="Copy of  path4 (3)" TEXTFLOWMODE="1" path="M157.926 6.67242 C144.231 2.04355 119.927 0.271569 92.418 0.0287857 C64.9096 -0.214057 34.1999 1.07248 18.1005 4.15892 C2.00125 7.24536 0.514278 12.1315 0.0984119 19.6452 C-0.318345 27.1588 0.335286 37.2993 7.22692 43.7759 C14.1182 50.2526 27.246 53.065 53.8197 54.461 C80.3932 55.8572 120.411 55.8371 143.852 52.7104 C167.293 49.5839 174.158 43.3515 176.939 38.154 C179.719 32.9565 178.631 29.4821 176.208 23.0148 C173.782 16.5472 171.621 11.3012 157.926 6.67242 L157.926 6.67242 Z" copath="M20.6568 6.67242 C34.3517 2.04355 58.6563 0.271569 86.1647 0.0287857 C113.673 -0.214057 144.382 1.07248 160.482 4.15892 C176.581 7.24536 178.068 12.1315 178.484 19.6452 C178.901 27.1588 178.248 37.2993 171.356 43.7759 C164.465 50.2526 151.336 53.065 124.763 54.461 C98.1895 55.8572 58.1717 55.8371 34.7303 52.7104 C11.289 49.5839 4.42513 43.3515 1.64438 38.154 C-1.13641 32.9565 -0.0489617 29.4821 2.37562 23.0148 C4.80021 16.5472 6.96171 11.3012 20.6568 6.67242 L20.6568 6.67242 Z" fillRule="0" gXpos="411.543140610568" gYpos="2606.4440944882" gWidth="100.270256084543" gHeight="35.5770367324822" LAYER="0"/>
        <PAGEOBJECT XPOS="178.488187854665" YPOS="2116.82776836439" OwnPage="5" ItemID="1828057409" PTYPE="4" WIDTH="170.409283464565" HEIGHT="434.353333997808" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L170.409 0 L170.409 434.353 L0 434.353 L0 0 Z" copath="M0 0 L170.409 0 L170.409 434.353 L0 434.353 L0 0 Z" gXpos="598.015746909782" gYpos="2768.79627230142" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="1829818257" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT FONT="Andika Bold" FCOLOR="laso pimeja" FSHADE="100" CH="tenpo sike 1548 la,"/>
                <ITEXT CH=" lon ma tomo Napoli la, jan Jotano Puno (Giordano Bruno) li"/>
                <nbspace/>
                <ITEXT CH="kama lon. jan Jotano Puno li"/>
                <nbspace/>
                <ITEXT CH="kama suli la, ona li"/>
                <nbspace/>
                <ITEXT CH="kama sona e"/>
                <nbspace/>
                <ITEXT CH="nasin sewi, e"/>
                <nbspace/>
                <ITEXT CH="nasin isipin². ona li"/>
                <nbspace/>
                <ITEXT CH="tawa mute lon ma Elopa."/>
                <para/>
                <ITEXT CH="tenpo pimeja la, lukin sewi la, jan Jotano Puno li"/>
                <nbspace/>
                <ITEXT CH="kama jo e"/>
                <nbspace/>
                <ITEXT CH="sona ni: nanpa wan la, ma sewi li"/>
                <nbspace/>
                <ITEXT CH="jo ala e"/>
                <nbspace/>
                <ITEXT CH="pini. nanpa tu la, sike suno mute pi ma sewi li"/>
                <nbspace/>
                <ITEXT CH="lili ala, li"/>
                <nbspace/>
                <ITEXT CH="suli sama sike suno Sola, taso ona li"/>
                <nbspace/>
                <ITEXT CH="lon weka mute. ken la, sike suno mute li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="mun. ken la, konwe¹ li"/>
                <nbspace/>
                <ITEXT CH="ken lon selo mun. jan Jotano Puno li"/>
                <nbspace/>
                <ITEXT CH="toki insa e"/>
                <nbspace/>
                <ITEXT CH="ni: ma ante mute li"/>
                <nbspace/>
                <ITEXT CH="lon ma sewi."/>
                <para/>
                <ITEXT CH="ike la, sona sin pi jan Jotano Puno li"/>
                <nbspace/>
                <ITEXT CH="awen ala lon insa lawa ona. jan Jotano Puno li"/>
                <nbspace/>
                <ITEXT CH="wile e"/>
                <nbspace/>
                <ITEXT CH="ni: jan ante li"/>
                <nbspace/>
                <ITEXT CH="kama sona e"/>
                <nbspace/>
                <ITEXT CH="isipin sin. jan Jotano Puno li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="sona ona, li"/>
                <nbspace/>
                <ITEXT CH="sitelen e"/>
                <nbspace/>
                <ITEXT CH="sona ona.  taso kulupu lawa pi nasin sewi Katoli li"/>
                <nbspace/>
                <ITEXT CH="pilin ike tan sona sin, li"/>
                <nbspace/>
                <ITEXT CH="wile e"/>
                <nbspace/>
                <ITEXT CH="ni: jan Jotano Puno li"/>
                <nbspace/>
                <ITEXT CH="pini toki. ni la, kulupu lawa li"/>
                <nbspace/>
                <ITEXT CH="lawa e"/>
                <nbspace/>
                <ITEXT CH="ni: jan Jotano Puno li"/>
                <nbspace/>
                <ITEXT CH="awen lon tomo awen. tenpo sike 1600 la, jan li"/>
                <nbspace/>
                <ITEXT CH="seli e"/>
                <nbspace/>
                <ITEXT CH="jan Jotano Puno lon ma tomo Loma (Roma), kepeken seli pi palisa kasi. ni la, jan Jotano Puno li"/>
                <nbspace/>
                <ITEXT CH="moli."/>
                <para/>
                <ITEXT CH="tenpo kama la, jan Kalijo Kalije (Galileo Galilei) en jan Jowane Kepa (Johannes Kepler) en jan Isake Nuton (Isaac Newton) en jan sona ante li"/>
                <nbspace/>
                <ITEXT CH="pali e"/>
                <nbspace/>
                <ITEXT CH="sona sin. kulupu lawa pi nasin sewi Katoli li"/>
                <nbspace/>
                <ITEXT CH="pilin pona ala tan sona ona, taso li"/>
                <nbspace/>
                <ITEXT CH="moli ala e"/>
                <nbspace/>
                <ITEXT CH="ona."/>
                <para/>
                <ITEXT CH="jan mute li"/>
                <nbspace/>
                <ITEXT CH="awen wile sona e"/>
                <nbspace/>
                <ITEXT CH="ni: ma ante mute li"/>
                <nbspace/>
                <ITEXT CH="lon ala lon ma sewi"/>
                <nbspace/>
                <ITEXT CH="? konwe li"/>
                <nbspace/>
                <ITEXT CH="lon mun mi, taso konwe li"/>
                <nbspace/>
                <ITEXT CH="lon ala lon mun ante? sitelen tawa mute li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="ni: konwe li"/>
                <nbspace/>
                <ITEXT CH="lon mun ante. taso jan sona li"/>
                <nbspace/>
                <ITEXT CH="sona ala."/>
                <para/>
                <ITEXT CH="tenpo sike 1995 la, jan Mike Mejo (Michel Mayor) en jan Tite Kelo (Didier Queloz) li"/>
                <nbspace/>
                <ITEXT CH="pali e"/>
                <nbspace/>
                <ITEXT CH="sona sin: sike suno pi nimi &quot;51 Pegasi"/>
                <nbspace/>
                <ITEXT CH="a&quot; li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="mun! pona la, jan sona mute li"/>
                <nbspace/>
                <ITEXT CH="isipin e"/>
                <nbspace/>
                <ITEXT CH="nasin lukin sin li"/>
                <nbspace/>
                <ITEXT CH="pali e"/>
                <nbspace/>
                <ITEXT CH="ilo lukin sin"/>
                <nbspace/>
                <ITEXT CH=": ilo lukin Kepa (Kepler) en ilo lukin Tese (TESS) li"/>
                <nbspace/>
                <ITEXT CH="kama lukin e"/>
                <nbspace/>
                <ITEXT CH="mun sin mute."/>
                <para/>
                <ITEXT CH="tenpo sike 2025 la, jan li"/>
                <nbspace/>
                <ITEXT CH="sona e"/>
                <nbspace/>
                <ITEXT CH="mun ante mute"/>
                <nbspace/>
                <ITEXT CH=": nanpa pi mun ni li"/>
                <nbspace/>
                <ITEXT CH="sama 5600. mun li"/>
                <nbspace/>
                <ITEXT CH="ken seli anu lete, li"/>
                <nbspace/>
                <ITEXT CH="ken suli anu lili, li"/>
                <nbspace/>
                <ITEXT CH="ken tawa sike wawa anu lili. ken la, konwe li"/>
                <nbspace/>
                <ITEXT CH="lon mun wan! jan sona li"/>
                <nbspace/>
                <ITEXT CH="isipin e"/>
                <nbspace/>
                <ITEXT CH="ni: mun pi konwe mute en mun pi konwe ala li"/>
                <nbspace/>
                <ITEXT CH="jo ala e"/>
                <nbspace/>
                <ITEXT CH="kon sama. ken la, ilo lukin li"/>
                <nbspace/>
                <ITEXT CH="lukin e"/>
                <nbspace/>
                <ITEXT CH="kon la, jan li"/>
                <nbspace/>
                <ITEXT CH="ken sona e"/>
                <nbspace/>
                <ITEXT CH="ni: konwe li"/>
                <nbspace/>
                <ITEXT CH="lon ala lon mun wan."/>
                <para/>
                <ITEXT CH="mi wile sona e"/>
                <nbspace/>
                <ITEXT CH="ni: jan li"/>
                <nbspace/>
                <ITEXT CH="alasa e"/>
                <nbspace/>
                <ITEXT CH="konwe sin la, mi moli ala moli? mi wile e"/>
                <nbspace/>
                <ITEXT CH="ni: mi moli ala, mi ken sona e"/>
                <nbspace/>
                <ITEXT CH="konwe sin!"/>
                <para/>
                <ITEXT CH="¹ konwe: soweli en pipi en kasi li"/>
                <nbspace/>
                <ITEXT CH="konwe, taso kiwen en ma en telo li"/>
                <nbspace/>
                <ITEXT CH="konwe ala."/>
                <breakline/>
                <ITEXT CH="² isipin: pali pi insa lawa."/>
                <para PARENT="toki lili poka"/>
            </StoryText>
        </PAGEOBJECT>
