        <PAGEOBJECT XPOS="589.606299212597" YPOS="1460.9835542709" OwnPage="4" ItemID="1826752113" PTYPE="4" WIDTH="170.078543307087" HEIGHT="293.662115020432" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L170.079 0 L170.079 293.662 L0 293.662 L0 0 Z" copath="M0 0 L170.079 0 L170.079 293.662 L0 293.662 L0 0 Z" gXpos="589.606299212598" gYpos="2112.95205820791" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="1826836113" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT CPARENT="Text74_Bold" FCOLOR="loje pimeja" FSHADE="100" CH="toki mute li"/>
                <nbspace CPARENT="Text74_Bold" FCOLOR="loje pimeja" FSHADE="100"/>
                <ITEXT CPARENT="Text74_Bold" FCOLOR="loje pimeja" FSHADE="100" CH="lon ma."/>
                <ITEXT CH=" mi wile toki e"/>
                <nbspace/>
                <ITEXT CH="toki la mi kepeken nimi ona. mi pana e"/>
                <nbspace/>
                <ITEXT CH="nimi Toki e"/>
                <nbspace/>
                <ITEXT CH="nimi Inli la sina sona e"/>
                <nbspace/>
                <ITEXT CH="ni: mi toki e"/>
                <nbspace/>
                <ITEXT CH="toki Inli e"/>
                <nbspace/>
                <ITEXT CH="toki ante ala. nimi Inli en nimi Tosi en nimi Kanse en nimi Sonko en nimi ante mute li"/>
                <nbspace/>
                <ITEXT CH="ken e"/>
                <nbspace/>
                <ITEXT CH="nasin ni. taso toki pona la seme? toki mute li"/>
                <nbspace/>
                <ITEXT CH="pona tawa mi. ona ale li"/>
                <nbspace/>
                <ITEXT CH="toki pona anu seme? nasin seme la mi o"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="toki pona wan taso?"/>
                <para/>
                <ITEXT CH="ni li"/>
                <nbspace/>
                <ITEXT CH="nasa tawa jan mute. “nimi ala li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="toki pona! pakala suli"/>
                <nbspace/>
                <ITEXT CH="a! toki pona o"/>
                <nbspace/>
                <ITEXT CH="nimi.” ona li"/>
                <nbspace/>
                <ITEXT CH="ante lili e"/>
                <nbspace/>
                <ITEXT CH="toki ona. mi toki pona la ona li"/>
                <nbspace/>
                <ITEXT CH="toki Toki Pona. anu la ona li"/>
                <nbspace/>
                <ITEXT CH="toki Pona. anu la ona li"/>
                <nbspace/>
                <ITEXT CH="toki Tokipona. mi la nasa ike. toki Inli la nimi "/>
                <ITEXT CPARENT="Text74_BoldItalic" CH="Toki Pona"/>
                <ITEXT CH=" li"/>
                <nbspace/>
                <ITEXT CH="lon li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="toki wan taso. toki pona la ala. ni li"/>
                <nbspace/>
                <ITEXT CH="nasa anu seme?"/>
                <para/>
                <ITEXT CH="mi la nasa ala"/>
                <nbspace/>
                <ITEXT CH="a! tenpo mute la ijo li"/>
                <nbspace/>
                <ITEXT CH="suli tawa kulupu la ijo ni li"/>
                <nbspace/>
                <ITEXT CH="jo ala e"/>
                <nbspace/>
                <ITEXT CH="nimi. o"/>
                <nbspace/>
                <ITEXT CH="lukin e"/>
                <nbspace/>
                <ITEXT CH="lipu pi ma ale. ma Apika la ma seli suli li"/>
                <nbspace/>
                <ITEXT CH="lon. toki Inli la nimi ona li"/>
                <nbspace/>
                <ITEXT CH="ma Sawala. toki Alapi la seme? toki Alapi la nimi Sawala li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="ma seli. taso ma seli ale"/>
                <nbspace/>
                <ITEXT CH="a li"/>
                <nbspace/>
                <ITEXT CH="kepeken nimi Sawala! toki Alapi la ma Sawala li"/>
                <nbspace/>
                <ITEXT CPARENT="Text74_BoldItalic" CH="ma seli suli"/>
                <ITEXT CH=". nimi ala li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="ma Sawala taso."/>
                <para/>
                <ITEXT CH="o"/>
                <nbspace/>
                <ITEXT CH="lukin kin e"/>
                <nbspace/>
                <ITEXT CH="ma Oseja. ma Oseja la kulupu Mulinpata li"/>
                <nbspace/>
                <ITEXT CH="lon. kulupu Mulinpata li"/>
                <nbspace/>
                <ITEXT CH="toki Inli li"/>
                <nbspace/>
                <ITEXT CH="toki Mulinpata. nimi Mulinpata li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="toki wan taso lon toki Mulinpata anu seme? ala. nimi Mulin li"/>
                <nbspace/>
                <ITEXT CH="nimi Toki lon toki ona. nimi Pata li"/>
                <nbspace/>
                <ITEXT CH="nimi Pona. ni la ona la toki ona li"/>
                <nbspace/>
                <ITEXT CPARENT="Text74_BoldItalic" CH="toki pona"/>
                <ITEXT CH=". sama kulupu mi"/>
                <nbspace/>
                <ITEXT CH="a."/>
                <para/>
                <ITEXT CH="sina kama sona e"/>
                <nbspace/>
                <ITEXT CH="ni: nasa ni li"/>
                <nbspace/>
                <ITEXT CH="kama lon toki ante. ni li"/>
                <nbspace/>
                <ITEXT CH="ike ala tawa kulupu ona. taso toki pona la mi o"/>
                <nbspace/>
                <ITEXT CH="seme? ken la tenpo la mi wile toki e"/>
                <nbspace/>
                <ITEXT CH="ike pi toki mi. taso nimi ona li"/>
                <nbspace/>
                <ITEXT CH="toki pona. mi toki e"/>
                <nbspace/>
                <ITEXT CPARENT="Text74_BoldItalic" CH="ike pi toki pona"/>
                <ITEXT CH=" la ni li"/>
                <nbspace/>
                <ITEXT CH="nasa wawa tawa jan kute. nasin seme la mi ken tu e"/>
                <nbspace/>
                <ITEXT CH="kon pi toki pona (ale) e"/>
                <nbspace/>
                <ITEXT CH="kon pi toki pona (ni taso)?"/>
                <para/>
                <ITEXT CH="o"/>
                <nbspace/>
                <ITEXT CH="lukin e"/>
                <nbspace/>
                <ITEXT CH="toki mi. toki Inli la ni li"/>
                <nbspace/>
                <ITEXT CPARENT="Text74_BoldItalic" CH="Toki Pona"/>
                <ITEXT CH=". taso mi la ni li"/>
                <nbspace/>
                <ITEXT CH="toki mi"/>
                <nbspace/>
                <ITEXT CH="a. kin la ona li"/>
                <nbspace/>
                <ITEXT CH="toki lon sitelen ni. kin la ona li"/>
                <nbspace/>
                <ITEXT CH="toki pi lipu tenpo. sina lukin e"/>
                <nbspace/>
                <ITEXT CH="toki mi la sina sona. mi toki e"/>
                <nbspace/>
                <ITEXT CH="toki wan taso. nasin pona."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
