            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="178.582740157484" YPOS="3994.01574803149" OwnPage="11" ItemID="485110379" PTYPE="4" WIDTH="170.078543307087" HEIGHT="80.1953553274188" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="14.1732283464567" TEXTRA="14.1732283464567" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L170.079 0 L170.079 80.1954 L0 80.1954 L0 0 Z" copath="M0 0 L170.079 0 L170.079 80.1954 L0 80.1954 L0 0 Z" gXpos="-453.543244094484" gYpos="3240" gWidth="170.078543307087" gHeight="94.9606299212599" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
