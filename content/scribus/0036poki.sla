                <nbspace/>
                <ITEXT CH="ken ala pana e"/>
                <nbspace/>
                <ITEXT CH="jaki moli tawa ona. moku ona en len ona en mani ona li"/>
                <nbspace/>
                <ITEXT CH="ken awen lon tenpo suli. tomo la ona li"/>
                <nbspace/>
                <ITEXT CH="ken weka pona e"/>
                <nbspace/>
                <ITEXT CH="jaki tan sijelo ona tan len ona. tomo li"/>
                <nbspace/>
                <ITEXT CH="suli"/>
                <nbspace/>
                <ITEXT CH="a tawa jan. kulupu olin li"/>
                <nbspace/>
                <ITEXT CH="ken lon tomo wan. mama en jan lili ona kin li"/>
