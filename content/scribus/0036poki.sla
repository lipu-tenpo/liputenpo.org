                <nbspace/>
                <ITEXT CH="luka sina: o"/>
                <nbspace/>
                <ITEXT CH="anpa e"/>
                <nbspace/>
                <ITEXT CH="sewi luka, o"/>
                <nbspace/>
                <ITEXT CH="sewi e"/>
                <nbspace/>
                <ITEXT CH="anpa luka. tan ni la, sina lukin e"/>
                <nbspace/>
                <ITEXT CH="pimeja lon sewi lipu e"/>
                <nbspace/>
                <ITEXT CH="walo lon anpa lipu. sewi lipu la, walo li"/>
                <nbspace/>
                <ITEXT CH="lon monsi. insa lipu la, lipu li"/>
                <nbspace/>
                <ITEXT CH="tawa sike li"/>
                <nbspace/>
                <ITEXT CH="kama ante tan walo tawa pimeja. o"/>
                <nbspace/>
                <ITEXT CH="tawa e"/>
                <nbspace/>
                <ITEXT CH="sewi lipu pimeja tawa anpa lipu. o"/>
                <nbspace/>
                <ITEXT CH="sike lili e"/>
                <nbspace/>
                <ITEXT CH="ona tawa anpa."/>
                <breakline/>
                <ITEXT CH="o"/>
                <nbspace/>
                <ITEXT CH="wan e"/>
                <nbspace/>
                <ITEXT CH="pimeja pi sewi lipu lon walo pi anpa lipu. ni kin la, sina kama pali e"/>
                <nbspace/>
                <ITEXT CH="sike kepeken lipu - taso ona li"/>
                <nbspace/>
                <ITEXT CH="nasa lili. pipi li"/>
                <nbspace/>
                <ITEXT CH="open e"/>
                <nbspace/>
                <ITEXT CH="tawa lon insa pi selo sike lon poka sina la, ona li"/>
                <nbspace/>
                <ITEXT CH="awen tawa la, ona li"/>
                <nbspace/>
                <ITEXT CH="kama sin lon poka sina - taso ona li"/>
                <nbspace/>
                <ITEXT CH="kama lon insa ala pi selo sike. ona li"/>
                <nbspace/>
                <ITEXT CH="awen tawa la, ona li"/>
                <nbspace/>
                <ITEXT CH="kama sin lon poka sina lon insa lon open pi tawa ona. jan Mepiju (Möbius) li"/>
                <nbspace/>
                <ITEXT CH="kama sona e"/>
                <nbspace/>
                <ITEXT CH="sike nasa ni."/>
                <para/>
                <ITEXT CH="jan Kalin (Klein) li"/>
                <nbspace/>
                <ITEXT CH="kama sona e"/>
                <nbspace/>
                <ITEXT CH="poki pi toki open mi: o"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="sike tu pi jan Mepiju. pini lipu pi sike ni wan li"/>
                <nbspace/>
                <ITEXT CH="kama lon pini lipu pi sike sama la, ona tu li"/>
                <nbspace/>
                <ITEXT CH="wan, li"/>
                <nbspace/>
                <ITEXT CH="ijo sin. ijo sin ni la pini tu li"/>
                <nbspace/>
                <ITEXT CH="kama wan la, ni li"/>
                <nbspace/>
                <ITEXT CH="poki nasa pi jan Kalin. o"/>
                <nbspace/>
                <ITEXT CH="sona: sina wile ni kepeken lipu sina la, sina ken ala"/>
                <nbspace/>
                <ITEXT CH="a! lipu li"/>
                <nbspace/>
                <ITEXT CH="wile kama tawa insa lipu li"/>
                <nbspace/>
                <ITEXT CH="kama wile lupa e"/>
                <nbspace/>
                <ITEXT CH="selo. ike la, mi pali e"/>
                <nbspace/>
                <ITEXT CH="ijo la, ijo li"/>
                <nbspace/>
                <ITEXT CH="suli pi nasin tu wan. poki nasa li"/>
                <nbspace/>
                <ITEXT CH="wile e"/>
                <nbspace/>
                <ITEXT CH="suli pi nasin tu tu li"/>
                <nbspace/>
                <ITEXT CH="lupa ala e"/>
                <nbspace/>
                <ITEXT CH="selo."/>
                <para/>
                <ITEXT CH="mi en sina la, ona li"/>
                <nbspace/>
                <ITEXT CH="poki pi ken ala. mi wile pali e"/>
                <nbspace/>
                <ITEXT CH="ona la, lupa li"/>
                <nbspace/>
                <ITEXT CH="lon ona - taso ona li"/>
                <nbspace/>
                <ITEXT CH="ijo pi lupa ala. awen la, ona li"/>
                <nbspace/>
                <ITEXT CH="ijo musi tawa jan sona. jan pi sona nasa nanpa la poki ni li"/>
                <nbspace/>
                <ITEXT CH="pona. ni la, ona li"/>
                <nbspace/>
                <ITEXT CH="pali e"/>
                <nbspace/>
                <ITEXT CH="sijelo pi sama ona. ante pi wan taso la, lupa li"/>
                <nbspace/>
                <ITEXT CH="lon. tan ni la, insa en insa ala li"/>
                <nbspace/>
                <ITEXT CH="lon ona. ona li"/>
                <nbspace/>
                <ITEXT CH="ken jo e"/>
                <nbspace/>
                <ITEXT CH="telo lon insa. jan sona pi mute ala li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="poki ni li"/>
                <nbspace/>
                <ITEXT CH="ken jo e"/>
                <nbspace/>
                <ITEXT CH="telo lon insa. poki li"/>
                <nbspace/>
                <ITEXT CH="nasa tawa lukin la, lupa li"/>
                <nbspace/>
                <ITEXT CH="lon anpa poki. telo li"/>
                <nbspace/>
                <ITEXT CH="wile lon insa la, anpa poki o"/>
                <nbspace/>
                <ITEXT CH="lon sewi. ni la, telo li"/>
                <nbspace/>
                <ITEXT CH="ken open e"/>
                <nbspace/>
                <ITEXT CH="tawa. anpa poki li"/>
                <nbspace/>
                <ITEXT CH="kama anpa sin tan sewi la, telo li"/>
                <nbspace/>
                <ITEXT CH="ken awen lon insa."/>
                <para/>
            </StoryText>
