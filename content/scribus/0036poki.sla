        <PAGEOBJECT XPOS="589.606299212598" YPOS="3490.09448818898" OwnPage="10" ItemID="509835435" PTYPE="4" WIDTH="170.078543307087" HEIGHT="302.661217980663" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L170.079 0 L170.079 302.661 L0 302.661 L0 0 Z" copath="M0 0 L170.079 0 L170.079 302.661 L0 302.661 L0 0 Z" gXpos="1009.13385826772" gYpos="882.220472440945" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="510565083" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT FONT="Andika Bold" FCOLOR="unu pimeja" FSHADE="100" CH="ona li"/>
                <nbspace FONT="Andika Bold" FCOLOR="unu pimeja" FSHADE="100"/>
                <ITEXT FONT="Andika Bold" FCOLOR="unu pimeja" FSHADE="100" CH="jan ala."/>
                <ITEXT FONT="Andika Bold" CH=" "/>
                <ITEXT CH="ona li"/>
                <nbspace/>
                <ITEXT CH="soweli ala. ona li"/>
                <nbspace/>
                <ITEXT CH="ijo nasa. jan ala li"/>
                <nbspace/>
                <ITEXT CH="wile utala e"/>
                <nbspace/>
                <ITEXT CH="ona. jan mute li"/>
                <nbspace/>
                <ITEXT CH="pilin monsuta tan ona. ona li"/>
                <nbspace/>
                <ITEXT CH="seme? jan ala li"/>
                <nbspace/>
                <ITEXT CH="sona. nasin la, jan li"/>
                <nbspace/>
                <ITEXT CH="lukin ala e"/>
                <nbspace/>
                <ITEXT CH="ona. suno li"/>
                <nbspace/>
                <ITEXT CH="pini la, ona li"/>
                <nbspace/>
                <ITEXT CH="tawa ma kulupu jan. jan ale li"/>
                <nbspace/>
                <ITEXT CH="sona e"/>
                <nbspace/>
                <ITEXT CH="ni: ona li"/>
                <nbspace/>
                <ITEXT CH="tawa ma tomo lili lon tenpo pimeja. tan ni la, jan ale li"/>
                <nbspace/>
                <ITEXT CH="pini e"/>
                <nbspace/>
                <ITEXT CH="lupa ale. taso jan wan lili li"/>
                <nbspace/>
                <ITEXT CH="pilin ala e"/>
                <nbspace/>
                <ITEXT CH="monsuta tan ona. jan lili wan li"/>
                <nbspace/>
                <ITEXT CH="open e"/>
                <nbspace/>
                <ITEXT CH="lupa tomo. jan lili li"/>
                <nbspace/>
                <ITEXT CH="tawa wawa e"/>
                <nbspace/>
                <ITEXT CH="lawa tan pilin monsuta. ijo monsuta li"/>
                <nbspace/>
                <ITEXT CH="lon ma seme? ona li"/>
                <nbspace/>
                <ITEXT CH="awen lon seme? jan lili li"/>
                <nbspace/>
                <ITEXT CH="sona ala. taso jan lili li"/>
                <nbspace/>
                <ITEXT CH="kama sona lon tenpo lili. jan lili li"/>
                <nbspace/>
                <ITEXT CH="tawa lon sike. ona li"/>
                <nbspace/>
                <ITEXT CH="lukin e"/>
                <nbspace/>
                <ITEXT CH="ona! jan lili li"/>
                <nbspace/>
                <ITEXT CH="toki wawa: “jan sewi"/>
                <nbspace/>
                <ITEXT CH="a!” ona li"/>
                <nbspace/>
                <ITEXT CH="kute e"/>
                <nbspace/>
                <ITEXT CH="kalama. taso ona li"/>
                <nbspace/>
                <ITEXT CH="tawa ala. jan lili li"/>
                <nbspace/>
                <ITEXT CH="tawa ona. jan lili li"/>
                <nbspace/>
                <ITEXT CH="toki: “sina monsuta ala. sina ijo nasa. taso sina monsuta ala!” ona li"/>
                <nbspace/>
                <ITEXT CH="mu taso. jan ante ale li"/>
                <nbspace/>
                <ITEXT CH="tawa tan tomo ona. mama meli pi jan lili Ela li"/>
                <nbspace/>
                <ITEXT CH="toki wawa: “jan Ela"/>
                <nbspace/>
                <ITEXT CH="o! sina seme?” jan Ela li"/>
                <nbspace/>
                <ITEXT CH="toki: “mi toki tawa ona!” mama meli li"/>
                <nbspace/>
                <ITEXT CH="toki sin: “kon toki sina li"/>
                <nbspace/>
                <ITEXT CH="seme? sina toki tawa sina lon insa pi tenpo pimeja! mi mute li"/>
                <nbspace/>
                <ITEXT CH="wile lape!” jan lili Ela li"/>
                <nbspace/>
                <ITEXT CH="sona ala e"/>
                <nbspace/>
                <ITEXT CH="ijo ale pi tenpo ni. jan Ela li"/>
                <nbspace/>
                <ITEXT CH="toki tawa ona: “toki mama li"/>
                <nbspace/>
                <ITEXT CH="jo ala e"/>
                <nbspace/>
                <ITEXT CH="kon. sina lon!” ona li"/>
                <nbspace/>
                <ITEXT CH="mu taso sike. jan Ela li"/>
                <nbspace/>
                <ITEXT CH="toki sin: “jan suli li"/>
                <nbspace/>
                <ITEXT CH="pilin ike wawa tan sina"/>
                <nbspace/>
                <ITEXT CH="… jan mute li"/>
                <nbspace/>
                <ITEXT CH="pilin monsuta tawa sina"/>
                <nbspace/>
                <ITEXT CH="… ona ale li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="ni: sina lon ala. taso ona ale li"/>
                <nbspace/>
                <ITEXT CH="toki tan sina!” mama meli li"/>
                <nbspace/>
                <ITEXT CH="toki lon tenpo ni: “o"/>
                <nbspace/>
                <ITEXT CH="pini"/>
                <nbspace/>
                <ITEXT CH="a! jan Ela o"/>
                <nbspace/>
                <ITEXT CH="tawa e"/>
                <nbspace/>
                <ITEXT CH="sijelo sina tawa mi lon tenpo ni anu tawa mi lon tenpo ala.” jan Ela li"/>
                <nbspace/>
                <ITEXT CH="open pana e"/>
                <nbspace/>
                <ITEXT CH="telo lukin. jan Ela li"/>
                <nbspace/>
                <ITEXT CH="toki lon lawa: “tan seme la mama li"/>
                <nbspace/>
                <ITEXT CH="pali e"/>
                <nbspace/>
                <ITEXT CH="nasin ni?” kon lete li"/>
                <nbspace/>
                <ITEXT CH="tawa. jan Ela li"/>
                <nbspace/>
                <ITEXT CH="open kepeken e"/>
                <nbspace/>
                <ITEXT CH="len lawa. mun li"/>
                <nbspace/>
                <ITEXT CH="suno lon sewi ona. jan Ela li"/>
                <nbspace/>
                <ITEXT CH="wile sona e"/>
                <nbspace/>
                <ITEXT CH="ni: tan seme la jan suli ale li"/>
                <nbspace/>
                <ITEXT CH="pilin monsuta tan ona? jan lili li"/>
                <nbspace/>
                <ITEXT CH="kama sona. jan Ela li"/>
                <nbspace/>
                <ITEXT CH="toki: “mi ken ala awen lon ni. mi wile alasa e"/>
                <nbspace/>
                <ITEXT CH="kon"/>
                <nbspace/>
                <ITEXT CH="… mi sona: ni li"/>
                <nbspace/>
                <ITEXT CH="nasa. taso mi sona kin: awen li"/>
                <nbspace/>
                <ITEXT CH="nasa mute.”"/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
