.0103992 6.51485 0.18561 6.64638 C0.621274 6.97344 2.51778 7.00087 3.59462 6.99997 C4.56468 6.99929 5.97819 7.00866 6.36018 6.70842 C6.53982 6.56725 6.51057 6.24309 6.5407 6.15007 C6.51057 6.05702 6.53998 5.73321 6.36018 5.59202 C6.04353 5.34313 5.01979 5.30762 4.12566 5.30207 C4.15195 4.79911 4.13398 4.21352 4.13313 3.7456 C4.13204 3.20302 4.13241 2.46991 4.08266 1.83105 C5.09861 1.79858 6.09273 1.70251 6.37712 1.47938 C6.56419 1.33263 6.51341 1.01512 6.54072 0.922305 C6.51341 0.829496 6.56419 0.512298 6.37712 0.365554 C6.00178 0.0710599 4.39001 -0.00249854 3.12356 6.40258e-05 L3.12354 4.00766e-05 Z" fillRule="0" gXpos="722.150575502333" gYpos="4649.3667407654" gWidth="0" gHeight="0" LAYER="0"/>
        <PAGEOBJECT XPOS="178.582677165354" YPOS="4111.0614970597" OwnPage="11" ItemID="1840987889" PTYPE="4" WIDTH="170.078606299213" HEIGHT="363.664706468658" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L170.079 0 L170.079 363.665 L0 363.665 L0 0 Z" copath="M0 0 L170.079 0 L170.079 363.665 L0 363.665 L0 0 Z" gXpos="-240.944881889764" gYpos="4763.03000099671" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="1841102337" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT CH="tenpo ale la jan li"/>
                <nbspace/>
                <ITEXT CH="sitelen e"/>
                <nbspace/>
                <ITEXT CH="lipu musi lili."/>
                <para/>
                <ITEXT CH="lipu ni la, linja mute li"/>
                <nbspace/>
                <ITEXT CH="pini kepeken kalama sama."/>
                <para/>
                <ITEXT CH="kin la nanpa kalama li"/>
                <nbspace/>
                <ITEXT CH="suli lon lipu ni."/>
                <para/>
                <ITEXT CH="toki pona la, lipu musi ni li"/>
                <nbspace/>
                <ITEXT CH="lili."/>
                <para/>
                <ITEXT CH="leko nimi li"/>
                <nbspace/>
                <ITEXT CH="suli mute lon toki pona. taso, sitelen pi sijelo pi toki ante li"/>
                <nbspace/>
                <ITEXT CH="nanpa lili lili."/>
                <para/>
                <ITEXT CH="mi wile toki e"/>
                <nbspace/>
                <ITEXT CH="sitelen musi Soneto tawa sina."/>
                <para/>
                <ITEXT CH="sitelen musi ni li"/>
                <nbspace/>
                <ITEXT CH="kama tan ma Italija, li"/>
                <nbspace/>
                <ITEXT CH="musi mute tawa mi, tawa jan mute."/>
                <para/>
                <ITEXT CH="jan Jakopo tan ma Lensini (Jacopo da Lentini) li"/>
                <nbspace/>
                <ITEXT CH="open e"/>
                <nbspace/>
                <ITEXT CH="nasin sitelen ni lon tomo lawa pi jan lawa suli Peteliko nanpa tu lon ma Sisilija (Sicily)."/>
                <para/>
                <ITEXT CH="lon tenpo pini la, jan mute pi ma mute li"/>
                <nbspace/>
                <ITEXT CH="open e"/>
                <nbspace/>
                <ITEXT CH="sitelen lipu Soneto. sijelo mute pi sitelen Soneto li"/>
                <nbspace/>
                <ITEXT CH="kama lon. mi wile toki e"/>
                <nbspace/>
                <ITEXT CH="lipu Soneto kepeken nasin pi jan Petalaka (Petrarch)."/>
                <para/>
                <ITEXT CH="sina wile sitelen e"/>
                <nbspace/>
                <ITEXT CH="lipu Soneto ni pi tenpo pini la, o"/>
                <nbspace/>
                <ITEXT CH="sona e"/>
                <nbspace/>
                <ITEXT CH="lawa ni:"/>
                <para/>
                <ITEXT CH="lawa ale pi sitelen musi Soneto pi ma Italija"/>
                <para PARENT="jan pali"/>
                <ITEXT CH="lawa pi linja nanpa li"/>
                <nbspace/>
                <ITEXT CH="ni: lipu musi ni li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="kipisi nanpa tu tu. kipisi nanpa wan en kipisi nanpa tu li"/>
                <nbspace/>
                <ITEXT CH="poki e"/>
                <nbspace/>
                <ITEXT CH="linja nanpa tu tu, taso kipisi nanpa tu wan en kipisi nanpa tu tu li"/>
                <nbspace/>
                <ITEXT CH="poki e"/>
                <nbspace/>
                <ITEXT CH="linja nanpa tu wan."/>
                <para/>
                <ITEXT CH="lawa pi kalama nanpa li"/>
                <nbspace/>
                <ITEXT CH="ni: linja ale li"/>
                <nbspace/>
                <ITEXT CH="poki e"/>
                <nbspace/>
                <ITEXT CH="kalama nanpa luka luka wan. lawa pi kalama pini li"/>
                <nbspace/>
                <ITEXT CH="ni:"/>
                <para/>
                <ITEXT CH="lawa lili nanpa wan: linja nanpa wan en linja nanpa tu tu o"/>
                <nbspace/>
                <ITEXT CPARENT="Text101_Bold" CH="kalama"/>
                <ITEXT CH=" sama lon pini."/>
                <para PARENT="Text220_List 2"/>
                <ITEXT CH="lawa lili nanpa tu: linja nanpa tu en linja nanpa tu wan o"/>
                <nbspace/>
                <ITEXT CPARENT="Text101_Bold" CH="kalama"/>
                <ITEXT CH=" sama lon pini."/>
                <para PARENT="Text220_List 2"/>
                <ITEXT CH="lawa lili nanpa tu wan: linja nanpa luka en linja nanpa luka tu wan o"/>
                <nbspace/>
                <ITEXT CPARENT="Text101_Bold" CH="kalama"/>
                <ITEXT CH=" sama lon pini."/>
                <para PARENT="Text220_List 2"/>
                <ITEXT CH="lawa lili nanpa tu tu: linja nanpa luka wan en linja nanpa luka tu o"/>
                <nbspace/>
                <ITEXT CPARENT="Text101_Bold" CH="kalama"/>
                <ITEXT CH=" sama lon pini."/>
                <para PARENT="Text220_List 2"/>
                <ITEXT CH="lawa lili nanpa luka: linja nanpa luka tu tu en linja nanpa luka luka tu o"/>
                <nbspace/>
                <ITEXT CPARENT="Text101_Bold" CH="kalama"/>
                <ITEXT CH=" sama lon pini.."/>
                <para PARENT="Text220_List 2"/>
                <ITEXT CH="lawa lili nanpa luka wan: linja nanpa luka luka en linja nanpa luka luka tu wan o"/>
                <nbspace/>
                <ITEXT CPARENT="Text101_Bold" CH="kalama"/>
                <ITEXT CH=" sama lon pini.."/>
                <para PARENT="Text220_List 2"/>
                <ITEXT CH="lawa lili nanpa luka tu: linja nanpa luka luka wan en linja nanpa luka luka tu tu o"/>
                <nbspace/>
                <ITEXT CPARENT="Text101_Bold" CH="kalama"/>
                <ITEXT CH=" sama lon pini.."/>
                <para PARENT="Text220_List 2"/>
                <ITEXT CH="lawa lili nanpa luka tu wan: "/>
                <ITEXT CPARENT="Text101_Bold" CH="kalama"/>
                <ITEXT CH=" pi lawa lili nanpa wan en "/>
                <ITEXT CPARENT="Text101_Bold" CH="kalama"/>
                <ITEXT CH=" pi lawa lili nanpa tu wan o"/>
                <nbspace/>
                <ITEXT CH="sama."/>
                <para PARENT="Text220_List 2"/>
                <ITEXT CH="lawa lili nanpa luka tu tu: "/>
                <ITEXT CPARENT="Text101_Bold" CH="kalama"/>
                <ITEXT CH=" pi lawa lili nanpa tu en "/>
                <ITEXT CPARENT="Text101_Bold" CH="kalama"/>
                <ITEXT CH=" pi lawa lili nanpa tu tu o"/>
                <nbspace/>
                <ITEXT CH="sama."/>
                <para PARENT="Text220_List 2"/>
                <ITEXT CH="sina ken kama sona e"/>
                <nbspace/>
                <ITEXT CH="ni la sina ken kepeken e"/>
                <nbspace/>
                <ITEXT CH="toki ni &quot;aiia-aiia-oue-oue&quot;. sina ken awen e"/>
                <nbspace/>
                <ITEXT CH="sona ni kepeken toki ni: &quot;ali li"/>
                <nbspace/>
                <ITEXT CH="kama lili la o"/>
                <nbspace/>
                <ITEXT CH="kute! moku ken&quot;"/>
                <para/>
                <ITEXT CH="taso, sina sitelen e"/>
                <nbspace/>
                <ITEXT CH="toki pona la, lawa mute ni li"/>
                <nbspace/>
                <ITEXT CH="ike. mi wile pana e"/>
                <nbspace/>
                <ITEXT CH="lawa ante ni tawa sina:"/>
                <para/>
                <ITEXT CH="lawa ante pi lawa lili nanpa luka tu wan: "/>
                <ITEXT CPARENT="Text101_Bold" CH="sitelen"/>
                <ITEXT CH=" pi lawa lili nanpa wan en "/>
                <ITEXT CPARENT="Text101_Bold" CH="sitelen"/>
                <ITEXT CH=" pi lawa lili nanpa luka li"/>
                <nbspace/>
                <ITEXT CH="sama."/>
                <para PARENT="Text220_List 2"/>
                <ITEXT CH="lawa ante pi lawa lili nanpa luka tu tu: "/>
                <ITEXT CPARENT="Text101_Bold" CH="sitelen"/>
                <ITEXT CH=" pi lawa lili nanpa tu en "/>
                <ITEXT CPARENT="Text101_Bold" CH="sitelen"/>
                <ITEXT CH=" pi lawa lili nanpa luka wan li"/>
                <nbspace/>
                <ITEXT CH="sama."/>
                <para PARENT="Text220_List 2"/>
                <ITEXT CH="lawa sin: wan pi lawa ni li"/>
                <nbspace/>
                <ITEXT CH="ken lon."/>
                <para PARENT="Text220_List 2"/>
                <ITEXT CH="kepeken nasin ni la, toki musi musi li"/>
                <nbspace/>
                <ITEXT CH="ken kama lon. sina wile toki e"/>
                <nbspace/>
                <ITEXT CH="pilin suli, e"/>
                <nbspace/>
                <ITEXT CH="pilin seli, e"/>
                <nbspace/>
                <ITEXT CH="ma kasi, e"/>
                <nbspace/>
                <ITEXT CH="telo tawa, e"/>
                <nbspace/>
                <ITEXT CH="ijo nasa la sina ken pali e"/>
                <nbspace/>
                <ITEXT CH="sitelen musi Soneto."/>
                <para/>
                <ITEXT CH="mi wile pana e"/>
                <nbspace/>
                <ITEXT CH="toki wan ni tawa sina."/>
                <para/>
                <ITEXT CH="lon lipu musi ni la mi kepeken e"/>
                <nbspace/>
                <ITEXT CH="lawa sewi, taso jan li"/>
                <nbspace/>
                <ITEXT CH="ken kepeken e"/>
                <nbspace/>
                <ITEXT CH="lawa ante kin."/>
                <para/>
                <ITEXT CH="sina olin ala olin e"/>
                <nbspace/>
                <ITEXT CH="sitelen musi Soneto? sina olin mute e"/>
                <nbspace/>
                <ITEXT CH="sijelo ni anu seme? o"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="toki insa sina!"/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="362.834283464574" YPOS="3968.50393700787" OwnPage="11" ItemID="1841102337" PTYPE="4" WIDTH="170.079102362205" HEIGHT="505.219974085521" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L170.079 0 L170.079 505.22 L0 505.22 L0 0 Z" copath="M0 0 L170.079 0 L170.079 505.22 L0 505.22 L0 0 Z" gXpos="-56.6932755905435" gYpos="4620.47244094488" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="1841092865" BACKITEM="1840987889"/>
