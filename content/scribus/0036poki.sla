        <PAGEOBJECT XPOS="589.606330708661" YPOS="1002.05940396691" OwnPage="2" ItemID="1825283505" PTYPE="4" WIDTH="170.078606299213" HEIGHT="245.184690521279" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L170.079 0 L170.079 245.185 L0 245.185 L0 0 Z" copath="M0 0 L170.079 0 L170.079 245.185 L0 245.185 L0 0 Z" gXpos="170.078771653543" gYpos="4913.87042758896" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style (4)" LAYER="0" NEXTITEM="1826858337" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style (4)" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT CH="toki pona li jo ala e kulupu lawa. jan Sonja li pali e toki, taso ona li toki ala e nasin pona pi toki pona li lawa ala e toki pona. ni la, jan li ken toki lon toki pona kepeken nasin ona pi jan wan. taso seme la nasin ale ni li ante?"/>
                <para/>
                <ITEXT CH="nasin toki wan pi ken ante li mute nimi. jan li ken kepeken nimi pi lipu pu taso, li ken kepeken nimi ku suli kin, li ken kepeken nimi ale pi lipu ku, li ken kepeken nimi ale pi lipu ala a! taso, jan li kepeken nimi pi mute suli la, ni li ken ike tan ni: jan li kepeken nimi pi sona mute ala la, jan mute li sona ala e toki pi jan ni. ni la, jan mute li kepeken nimi sama. taso, sina ken kepeken nimi ante ni tan ni: jan ala li lawa e toki la, jan ale li ken kepeken nimi pi wile ona!"/>
                <para/>
                <ITEXT CH="nasin ante pi ken ante li nasin pali pi kulupu nimi. nasin wan la, jan mute li kepeken nasin nimi “kepeken e”. mi kepeken nasin ni ala, taso jan mute li kepeken ona. jan wan li ken toki e ni: “mi kepeken ilo”. jan ante li ken toki e ni: “mi kepeken e ilo”. nasin tu ni li pona! sama la, jan mute li kepeken nasin nanpa ante. jan li ken kepeken nasin nanpa pu li ken kepeken nasin nanpa pona li ken kepeken nasin nanpa ante mute a! jan pi nasin nanpa pu li toki e nanpa 523 sama “ale ale ale ale ale mute tu wan”. jan pi nasin nanpa pona li toki e nanpa ni sama “luka ale mute tu wan”. nasin tu ni li pona kin!"/>
                <para/>
                <ITEXT CH="toki pona li jo ala e kulupu lawa la, jan mute li kepeken nasin toki ante. ona ale li pona. ni la, toki pona li toki pi musi mute! sina ken kepeken nasin pi wile sina, taso o toki ala e ni: jan ale o kepeken nasin toki sina."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
