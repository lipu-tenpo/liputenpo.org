        <PAGEOBJECT XPOS="368.740353208993" YPOS="2012.52677165354" OwnPage="5" ItemID="1829729281" PTYPE="2" WIDTH="170.078543307087" HEIGHT="94.9606299212603" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="0.196199648597645" LOCALSCY="0.196199648597645" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="0" RATIO="1" Pagenumber="0" PFILE="../img/0035-nanpa-len/mun-kule.png" IRENDER="0" EMBEDDED="0" path="M0 0 L170.079 0 L170.079 94.9606 L0 94.9606 L0 0 Z" copath="M0 0 L170.079 0 L170.079 94.9606 L0 94.9606 L0 0 Z" gXpos="788.267912264112" gYpos="2664.49527559056" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="589.606299212598" YPOS="2103.72331306689" OwnPage="6" ItemID="1831291313" PTYPE="4" WIDTH="170.078606299213" HEIGHT="447.457789295322" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L170.079 0 L170.079 447.458 L0 447.458 L0 0 Z" copath="M0 0 L170.079 0 L170.079 447.458 L0 447.458 L0 0 Z" gXpos="170.07874015748" gYpos="4711.59732881492" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="1831355185" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT CPARENT="Text101_Bold" CH="ma suli Elopa"/>
                <ITEXT CH=" li jo e ma mute. ona li jo e ma lili mute kin. ma lili li pona mute tawa mi tan ni: ona li ken nasa. ijo en lawa ona li ken ante mute tawa ma ante. jan mute li sona ala anu sona lili e ona. o kama sona e ma Wasikano e ma Monako e ma Samalino."/>
                <para/>
                <ITEXT CH="ma Wasikano"/>
                <para PARENT="jan pali"/>
                <ITEXT CH="ma ale la ma Wasikano li ma pi lili nanpa wan. ona li lon insa pi ma tomo Loma (lon ma Italija). ma ante ala li lon insa pi ma tomo. ona li musi tan ni:"/>
                <para/>
                <ITEXT CH="jan lawa pi nasin sewi Katolika li lon ona. sina kama lon tenpo suno esun nanpa wan la ken la sina lukin e ona!"/>
                <para PARENT="Text220_List 2"/>
                <ITEXT CH="ona li jo e sitelen mute pi pona lukin."/>
                <para PARENT="Text220_List 2"/>
                <ITEXT CH="sina wile kama jo e mani tan ilo mani la sina ken ni kepeken toki Lasina"/>
                <para PARENT="Text220_List 2"/>
                <ITEXT CH="ma Monako"/>
                <para PARENT="jan pali"/>
                <ITEXT CH="ma ale la ma Monako li ma pi lili nanpa tu. ma Kanse li lon poka ona. jan pi ma Monako li jo e mani mute. jan mute li kama lon ma Monako tan ni: ona li wile tawa tomo musi mani Kasinotemontekalo. nasa la lawa li toki e ni: jan pi ma Monako li ken ala tawa ona! jan mute li kama tan ni kin: ona li wile lukin e utala musi pi tomo tawa wawa. ma Monako la, tomo mute pi ken tawa li lon telo. ona li pona tawa lukin.. kin la, ona li jo e tomo lukin. tomo la, jan li ken lukin e sona telo e sona kala."/>
                <para/>
                <ITEXT CH="ma Samalino"/>
                <para PARENT="jan pali"/>
                <ITEXT CH="ma Elopa la ma Samalino li ma pi lili nanpa tu wan (ma ale la, ona li ma pi lili nanpa luka). ma Italija li sike e ona. tenpo sike nanpa ale ale ale wan la jan Malinu li pali e tomo lon nena Sitano. jan ante li kama lon poka ona. ma Samalino li kama tan kulupu tomo ni. ona li musi tan ni:"/>
                <para/>
                <ITEXT CH="nasin lawa ma li ni: jan li ken toki e jan lawa pi wile ona. ma Samalino li awen kepeken nasin lawa ni lon tenpo pi suli nanpa wan."/>
                <para PARENT="Text220_List 2"/>
                <ITEXT CH="tomo tawa la jan pi ma Samalino li jo mute e ona. jan luka luka li jo e tomo tawa luka luka luka wan! ma ante ale la mute pi tomo tawa li suli lon ma Samalino."/>
                <para PARENT="Text220_List 2"/>
                <ITEXT CH="tomo palisa tu wan pi majuna mute li lon nena Sitano. ona li pona lukin mute. sitelen ona li lon lipu ma."/>
                <para PARENT="Text220_List 2"/>
                <ITEXT CH="ma lili ante li lon ma suli Elopa. tenpo kama la mi toki e ma Lisensan e ma Mata. sona la, ma suli ante li jo e ma lili. sina sona e ona la o toki e ona!"/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
