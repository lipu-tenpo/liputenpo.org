        <PAGEOBJECT XPOS="589.606299212598" YPOS="2734.80633908103" OwnPage="8" ItemID="493187547" PTYPE="4" WIDTH="170.078606299213" HEIGHT="468.343267218188" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L170.079 0 L170.079 468.343 L0 468.343 L0 0 Z" copath="M0 0 L170.079 0 L170.079 468.343 L0 468.343 L0 0 Z" gXpos="170.07874015748" gYpos="4690.71185089205" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="493316651" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT CPARENT="Text99_Bold" FCOLOR="laso pimeja" FSHADE="100" CH="ma suli Elopa"/>
                <ITEXT FCOLOR="laso pimeja" FSHADE="100" CH=" "/>
                <ITEXT CH="li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="ma lawa lili mute. ma lili li"/>
                <nbspace/>
                <ITEXT CH="pona mute tawa mi tan ni: ona li"/>
                <nbspace/>
                <ITEXT CH="ken nasa. ijo en lawa ona li"/>
                <nbspace/>
                <ITEXT CH="ken ante mute tawa ma ante. jan mute li"/>
                <nbspace/>
                <ITEXT CH="sona ala anu sona lili e"/>
                <nbspace/>
                <ITEXT CH="ona. o"/>
                <nbspace/>
                <ITEXT CH="kama sona e"/>
                <nbspace/>
                <ITEXT CH="ma Wasikano e"/>
                <nbspace/>
                <ITEXT CH="ma Monako e"/>
                <nbspace/>
                <ITEXT CH="ma Samalino."/>
                <para/>
                <ITEXT CH="ma Wasikano"/>
                <para PARENT="jan pali"/>
                <ITEXT CH="ma ale la ma Wasikano li"/>
                <nbspace/>
                <ITEXT CH="ma lawa pi lili nanpa wan. ona li"/>
                <nbspace/>
                <ITEXT CH="lon insa pi ma tomo Loma (lon ma Italija). ma ante ala li"/>
                <nbspace/>
                <ITEXT CH="lon insa pi ma tomo. ona li"/>
                <nbspace/>
                <ITEXT CH="musi tan ni:"/>
                <para/>
                <ITEXT CH="jan lawa pi nasin sewi Katolika li"/>
                <nbspace/>
                <ITEXT CH="lon ona. sina kama lon tenpo suno esun nanpa wan la ken la sina lukin e"/>
                <nbspace/>
                <ITEXT CH="ona!"/>
                <para PARENT="List"/>
                <ITEXT CH="ona li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="sitelen mute pi pona lukin."/>
                <para PARENT="List"/>
                <ITEXT CH="sina wile kama jo e"/>
                <nbspace/>
                <ITEXT CH="mani tan ilo mani la sina ken ni kepeken toki Lasina."/>
                <para PARENT="List"/>
                <ITEXT CH="ma Monako"/>
                <para PARENT="jan pali"/>
                <ITEXT CH="ma ale la ma Monako li"/>
                <nbspace/>
                <ITEXT CH="ma lawa pi lili nanpa tu. ma Kanse li"/>
                <nbspace/>
                <ITEXT CH="lon poka ona. jan pi ma Monako li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="mani mute. jan mute li"/>
                <nbspace/>
                <ITEXT CH="kama lon ma Monako tan ni: ona li"/>
                <nbspace/>
                <ITEXT CH="wile tawa tomo musi mani Kasinotemontekalo. nasa la lawa li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="ni: jan pi ma Monako li"/>
                <nbspace/>
                <ITEXT CH="ken ala tawa ona!"/>
                <para/>
                <ITEXT CH="jan mute li"/>
                <nbspace/>
                <ITEXT CH="kama tan ni kin: ona li"/>
                <nbspace/>
                <ITEXT CH="wile lukin e"/>
                <nbspace/>
                <ITEXT CH="utala musi pi tomo tawa wawa."/>
                <para/>
                <ITEXT CH="ma Monako la, tomo mute pi ken tawa li"/>
                <nbspace/>
                <ITEXT CH="lon telo. ona li"/>
                <nbspace/>
                <ITEXT CH="pona tawa lukin. kin la, ona li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="tomo lukin. tomo la, jan li"/>
                <nbspace/>
                <ITEXT CH="ken lukin e"/>
                <nbspace/>
                <ITEXT CH="sona telo e"/>
                <nbspace/>
                <ITEXT CH="sona kala."/>
                <para/>
                <ITEXT CH="ma Samalino"/>
                <para PARENT="jan pali"/>
                <ITEXT CH="ma Elopa la ma Samalino li"/>
                <nbspace/>
                <ITEXT CH="ma lawa pi lili nanpa tu wan (ma ale la, ona li"/>
                <nbspace/>
                <ITEXT CH="ma pi lili nanpa luka). ma Italija li"/>
                <nbspace/>
                <ITEXT CH="sike e"/>
                <nbspace/>
                <ITEXT CH="ona. tenpo sike nanpa ale ale ale wan la jan Malinu li"/>
                <nbspace/>
                <ITEXT CH="pali e"/>
                <nbspace/>
                <ITEXT CH="tomo lon nena Sitano. jan ante li"/>
                <nbspace/>
                <ITEXT CH="kama lon poka ona. ma Samalino li"/>
                <nbspace/>
                <ITEXT CH="kama tan kulupu tomo ni. ona li"/>
                <nbspace/>
                <ITEXT CH="musi tan ni:"/>
                <para/>
                <ITEXT CH="nasin lawa ma li"/>
                <nbspace/>
                <ITEXT CH="ni: jan li"/>
                <nbspace/>
                <ITEXT CH="kama jan lawa tan wile kulupu pi jan ale. ma Samalino li"/>
                <nbspace/>
                <ITEXT CH="awen kepeken nasin lawa ni lon tenpo pi suli nanpa wan."/>
                <para PARENT="List"/>
                <ITEXT CH="tomo tawa la jan pi ma Samalino li"/>
                <nbspace/>
                <ITEXT CH="jo mute e"/>
                <nbspace/>
                <ITEXT CH="ona. jan luka luka li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="tomo tawa luka luka luka wan! ma ante ale la mute pi tomo tawa li"/>
                <nbspace/>
                <ITEXT CH="suli lon ma Samalino."/>
                <para PARENT="List"/>
                <ITEXT CH="tomo palisa tu wan pi majuna mute li"/>
                <nbspace/>
                <ITEXT CH="lon nena Sitano. ona li"/>
                <nbspace/>
                <ITEXT CH="pona lukin mute. sitelen ona li"/>
                <nbspace/>
                <ITEXT CH="lon lipu ma."/>
                <para PARENT="List"/>
                <ITEXT CH="ma lawa lili ante li"/>
                <nbspace/>
                <ITEXT CH="lon ma suli Elopa. tenpo kama la mi toki e"/>
                <nbspace/>
                <ITEXT CH="ma Lisensan e"/>
                <nbspace/>
                <ITEXT CH="ma Mata. sona la, ma suli ante li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="ma lawa lili. sina sona e"/>
                <nbspace/>
                <ITEXT CH="ona la o"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="ona!"/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
