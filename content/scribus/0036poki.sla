        <PAGEOBJECT XPOS="178.582740157484" YPOS="4071.37645768962" OwnPage="11" ItemID="1842666801" PTYPE="4" WIDTH="170.078543307087" HEIGHT="25.511811023622" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" ANNAME="Copy of lawa_2 (19)" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="14.1732283464567" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L170.079 0 L170.079 25.5118 L0 25.5118 L0 0 Z" copath="M0 0 L170.079 0 L170.079 25.5118 L0 25.5118 L0 0 Z" gXpos="-453.543244094484" gYpos="3317.36070965813" gWidth="170.078543307087" gHeight="94.9606299212599" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="tan "/>
                <ITEXT CPARENT="jan pali la nimi" CH="jan Samele"/>
                <para PARENT="jan pali"/>
                <ITEXT CH="sitelen li tan "/>
                <ITEXT CPARENT="jan sitelen la nimi" CH="jan sitelen"/>
                <trail PARENT="jan sitelen"/>
