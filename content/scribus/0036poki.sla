                <nbspace/>
                <ITEXT CH="suli tan anpa tawa sewi o"/>
                <nbspace/>
                <ITEXT CH="lili tan poka wan tawa poka ante. ni la ona li"/>
                <nbspace/>
                <ITEXT CH="sama linja anu palisa li"/>
                <nbspace/>
                <ITEXT CH="sama ala ma. o"/>
                <nbspace/>
                <ITEXT CH="wan e"/>
                <nbspace/>
                <ITEXT CH="sewi lipu e"/>
                <nbspace/>
                <ITEXT CH="anpa lipu: o"/>
                <nbspace/>
