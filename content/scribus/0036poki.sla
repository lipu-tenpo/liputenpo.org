                <nbspace CPARENT="Text82_Bold"/>
                <ITEXT CPARENT="Text82_Bold" CH="kulupu wan taso."/>
                <ITEXT CH=" insa pi tomo tu la, ma kasi o"/>
                <nbspace/>
                <ITEXT CH="lon. ni li"/>
                <nbspace/>
