                <ITEXT CH="lipu la, sina sitelen lon ona la, suli sitelen li"/>
                <nbspace/>
                <ITEXT CH="tan anpa tawa sewi, li"/>
                <nbspace/>
                <ITEXT CH="tan poka wan tawa poka ante. sitelen lipu li"/>
                <nbspace/>
                <ITEXT CH="suli pi nasin tu."/>
                <para/>
                <ITEXT CH="sina jo e"/>
                <nbspace/>
                <ITEXT CH="poki lon luka sina la, sijelo ona li"/>
                <nbspace/>
                <ITEXT CH="sama sijelo sina: suli pi sijelo sina li"/>
                <nbspace/>
                <ITEXT CH="tan anpa tawa sewi, li"/>
                <nbspace/>
                <ITEXT CH="tan monsi tawa sinpin, li"/>
                <nbspace/>
                <ITEXT CH="tan poka wan tawa poka ante. sijelo sina li"/>
                <nbspace/>
                <ITEXT CH="suli pi nasin tu wan. poki pi luka sina li"/>
                <nbspace/>
                <ITEXT CH="suli pi nasin tu wan. taso sijelo ale"/>
                <nbspace/>
                <ITEXT CH="a li"/>
                <nbspace/>
                <ITEXT CH="sama ni. taso poki nasa pi toki mi li"/>
                <nbspace/>
                <ITEXT CH="suli pi nasin tu tu. nasa: suli ona li"/>
                <nbspace/>
                <ITEXT CH="tan anpa tawa sewi, li"/>
                <nbspace/>
                <ITEXT CH="tan monsi tawa sinpin, li"/>
                <nbspace/>
                <ITEXT CH="tan poka wan tawa poka ante... li"/>
                <nbspace/>
                <ITEXT CH="tan nasin ante wan tawa poka ante pi nasin ante ni. nasin seme? ni li"/>
                <nbspace/>
                <ITEXT CH="nasa ona, ona li"/>
                <nbspace/>
                <ITEXT CH="kepeken nasin ante wan, li"/>
                <nbspace/>
                <ITEXT CH="sama ala ijo lon. jan li"/>
                <nbspace/>
                <ITEXT CH="pali e"/>
                <nbspace/>
                <ITEXT CH="ijo nasa tawa sona pi nasin nanpa."/>
                <para/>
                <ITEXT CH="ni la, ijo li"/>
                <nbspace/>
                <ITEXT CH="lon insa lawa taso pi jan sona anu seme? sina"/>
                <nbspace/>
                <ITEXT CH="a ken ala ken sona e"/>
                <nbspace/>
                <ITEXT CH="poki nasa? ona li"/>
                <nbspace/>
                <ITEXT CH="sama seme tawa lukin? mi wile pana e"/>
                <nbspace/>
                <ITEXT CH="ken, taso open la, mi o"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="sona pi ijo ante."/>
                <para/>
                <ITEXT CH="o"/>
