                <nbspace/>
                <ITEXT CH="sewi lipu, o"/>
                <nbspace/>
                <ITEXT CH="tawa e"/>
                <nbspace/>
                <ITEXT CH="ona tawa anpa lipu, o"/>
                <nbspace/>
                <ITEXT CH="sike lili e"/>
                <nbspace/>
                <ITEXT CH="ona tawa anpa. sewi lipu la, sina lukin e"/>
                <nbspace/>
                <ITEXT CH="pimeja. walo li"/>
                <nbspace/>
                <ITEXT CH="lon anpa. o"/>
                <nbspace/>
                <ITEXT CH="wan e"/>
                <nbspace/>
                <ITEXT CH="walo pi sewi lipu ni lon walo pi anpa lipu. sina kama pali e"/>
                <nbspace/>
                <ITEXT CH="sike pona kepeken lipu. sike taso. nasa ala. pipi li"/>
                <nbspace/>
                <ITEXT CH="tawa lon selo insa pi sike lipu ni, li"/>
                <nbspace/>
                <ITEXT CH="awen tawa la, ona li"/>
                <nbspace/>
                <ITEXT CH="awen lon insa. ona li"/>
                <nbspace/>
                <ITEXT CH="tawa lon selo pi insa ala li"/>
                <nbspace/>
                <ITEXT CH="awen tawa la, ona li"/>
                <nbspace/>
                <ITEXT CH="awen lon insa ala. nasa ala"/>
                <nbspace/>
                <ITEXT CH="a."/>
                <para/>
                <ITEXT CH="ni la o"/>
                <nbspace/>
                <ITEXT CH="pali e"/>
                <nbspace/>
                <ITEXT CH="ijo nasa. o"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="lipu. sama la lipu o"/>
