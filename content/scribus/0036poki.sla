            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT CPARENT="Text101_Bold" FCOLOR="laso pimeja" CH="mi ale li"/>
                <nbspace CPARENT="Text101_Bold" FCOLOR="laso pimeja"/>
                <ITEXT CPARENT="Text101_Bold" FCOLOR="laso pimeja" CH="sitelen"/>
                <ITEXT CH=" li"/>
                <nbspace/>
                <ITEXT CH="lukin e"/>
                <nbspace/>
                <ITEXT CH="sitelen. sitelen seme li"/>
                <nbspace/>
                <ITEXT CH="pona tawa sina? sitelen pona li"/>
                <nbspace/>
                <ITEXT CH="pona tawa jan mute. sitelen sitelen li"/>
                <nbspace/>
                <ITEXT CH="pona tawa jan mute ante. taso, lon tenmpo pini la mi wile pali e"/>
                <nbspace/>
                <ITEXT CH="sitelen sin… e"/>
                <nbspace/>
                <ITEXT CH="sitelen mi. tan ni la mi pali e"/>
                <nbspace/>
                <ITEXT CH="sitelen sin. nimi ona la mi toki e"/>
                <nbspace/>
                <ITEXT CH="sitelen leko anu sitelen Kuwi!"/>
                <para/>
                <ITEXT CH="mi pali e"/>
                <nbspace/>
                <ITEXT CH="sitelen sin tan seme? n… mi toki e"/>
                <nbspace/>
                <ITEXT CH="ni lon lawa mi: tenpo ale ala la mi sona pona e"/>
                <nbspace/>
                <ITEXT CH="toki pi jan ante. o"/>
                <nbspace/>
                <ITEXT CH="lukin e"/>
                <nbspace/>
                <ITEXT CH="ni: jan li"/>
                <nbspace/>
                <ITEXT CH="sitelen e"/>
                <nbspace/>
                <ITEXT CH="toki “telo li"/>
                <nbspace/>
                <ITEXT CH="tawa lon insa mi.” ken la telo li"/>
                <nbspace/>
                <ITEXT CH="lon insa ona li"/>
                <nbspace/>
                <ITEXT CH="tawa, ken la insa ona li"/>
                <nbspace/>
                <ITEXT CH="lon ma la, telo li"/>
                <nbspace/>
                <ITEXT CH="lon sewi pi insa ona. mi lukin e"/>
                <nbspace/>
                <ITEXT CH="ni la mi ken ala toki e"/>
                <nbspace/>
                <ITEXT CH="ni: o"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="sona sin tawa mi."/>
                <para/>
                <ITEXT CH="taso, kepeken sitelen sin mi la mi sona pona e"/>
                <nbspace/>
                <ITEXT CH="sitelen ale pi jan ante. sitelen sin mi la, jan li"/>
                <nbspace/>
                <ITEXT CH="sitelen e"/>
                <nbspace/>
                <ITEXT CH="toki wan ni lon nasin ante tu."/>
                <para/>
                <ITEXT CH="sina wile ala wile kama sona e"/>
                <nbspace/>
                <ITEXT CH="sitelen leko? wile la o"/>
                <nbspace/>
                <ITEXT CH="lukin e"/>
                <nbspace/>
                <ITEXT CH="lipu mi¹. mi wile e"/>
                <nbspace/>
                <ITEXT CH="ijo ala tan sina li"/>
                <nbspace/>
                <ITEXT CH="wile pana taso e"/>
                <nbspace/>
                <ITEXT CH="sona pi sitelen mi."/>
                <para/>
                <ITEXT CH="sina wile ala wile lukin e"/>
                <nbspace/>
                <ITEXT CH="sitelen leko? wile la o"/>
                <nbspace/>
                <ITEXT CH="lukin! o"/>
                <nbspace/>
                <ITEXT CH="kama sona e"/>
                <nbspace/>
