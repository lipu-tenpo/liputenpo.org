            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT FONT="Noto Sans Armenian Bold" FCOLOR="unu pimeja" CH="մա Այա "/>
                <ITEXT FONT="Noto Sans Bold" FCOLOR="unu pimeja" CH="("/>
                <ITEXT FONT="Noto Sans Armenian Bold" FCOLOR="unu pimeja" CH="Հայաստանի"/>
                <ITEXT FONT="Noto Sans Bold" FCOLOR="unu pimeja" CH="),"/>
                <ITEXT FONT="Noto Sans Armenian Regular" CH=" լի լոն պոկա պի կօլօպօ նէնա Կովկաս"/>
                <ITEXT FONT="Noto Sans Regular" CH=","/>
                <ITEXT FONT="Noto Sans Armenian Regular" CH=" լի լոն պոկա պի նէնա սօլի Արարատ։ մա Կաթէլո էն մա Թօկի էն մա Իլան էն մա Ասէպասան լի լոն պոկա պի մա նի։ կօլօպօ յան Այա լի մայօնա ա"/>
                <ITEXT FONT="Noto Sans Regular" CH=","/>
                <ITEXT FONT="Noto Sans Armenian Regular" CH=" սամա մա սօլի Ասորեստան"/>
                <ITEXT FONT="Noto Sans Regular" CH=","/>
                <ITEXT FONT="Noto Sans Armenian Regular" CH=" սամա կօլօպօ Էլին։ յան սոնա լա կօլօպօ Այա լի կէն լոն թէնպո պի մա Պիյանի "/>
                <ITEXT FONT="Noto Sans Regular" CH="("/>
                <ITEXT FONT="Noto Sans Armenian Regular" CH="Վանի"/>
                <ITEXT FONT="Noto Sans Regular" CH="),"/>
                <ITEXT FONT="Noto Sans Armenian Regular" CH=" թան նի"/>
                <ITEXT FONT="Noto Sans Regular" CH="․"/>
                <ITEXT FONT="Noto Sans Armenian Regular" CH=" նիմի պի թոկի Պիյանի լի ավէն ա լոն թոկի Այա։ թոկի լա ոնա լի թան կօլօպօ Ինթո֊Էլոպա"/>
                <ITEXT FONT="Noto Sans Regular" CH=","/>
                <ITEXT FONT="Noto Sans Armenian Regular" CH=" թասո ոնա լի կամա լոն մա նի լոն նասին սէ՞մէ։ յան լի ավէն սոնա պոնա ալա։"/>
                <para/>
                <ITEXT FONT="Noto Sans Armenian Regular" CH="կօլօպօ Այա լի լիլի թավա կօլօպօ անթէ։ նի լա կօլօպօ անթէ լի լավա է ոնա լոն թէնպո մօթէ։ մօթէ լա կօլօպօ Իլան լի լավա է ոնա։ մօթէ լիլի լա կօլօպօ Լոմա կին լի վիլէ է մա Այա"/>
                <ITEXT FONT="Noto Sans Regular" CH=","/>
                <ITEXT FONT="Noto Sans Armenian Regular" CH=" լի օթալա է լավա Իլան թավա նի։ թասո"/>
                <ITEXT FONT="Noto Sans Regular" CH=","/>
                <ITEXT FONT="Noto Sans Armenian Regular" CH=" նէնա մօթէ լի լոն մա լա"/>
                <ITEXT FONT="Noto Sans Regular" CH="․"/>
                <ITEXT FONT="Noto Sans Armenian Regular" CH=" կօլօպօ Այա լի կէն լավա լիլի լոն անպա պի լավա անթէ"/>
                <ITEXT FONT="Noto Sans Regular" CH=","/>
                <ITEXT FONT="Noto Sans Armenian Regular" CH=" լի կէն լավա պի անպա ալա։ ոնա լի կէն ավէն լոն նասին ոնա։"/>
                <para/>
                <ITEXT FONT="Noto Sans Armenian Regular" CH="նի լա նասին ոնա լի անթէ լոն սէ՞մէ։ վան լա ոնա լի մա նանպա վան պի նասին սէվի Կոլիսօ։ լավա ոնա լի կամա լոն նասին նի լա լավա պի մա անթէ լի ավէն լոն նասին նի ալա։ թէնպո լոն լա"/>
                <ITEXT FONT="Noto Sans Regular" CH=","/>
                <ITEXT FONT="Noto Sans Armenian Regular" CH=" նէնա լի վէկա է ոնա թան կօլօպօ անթէ պի նասին սէվի սամա լա"/>
                <ITEXT FONT="Noto Sans Regular" CH="․"/>
                <ITEXT FONT="Noto Sans Armenian Regular" CH=" կօլօպօ Այա էն կօլօպօ անթէ լի ավէն վան ալա։ անթէ լա նասին սիթէլէն թոկի լի լոն թավա թոկի Այա թասո։ նի լի թան յան Մեսրոպ Մաշտոց"/>
                <ITEXT FONT="Noto Sans Regular" CH=","/>
                <ITEXT FONT="Noto Sans Armenian Regular" CH=" լի թան պանա ոնա պի նասին սէվի։ ոնա լի վիլէ թոկի է նասին սէվի է լիպօ սէվի թավա կօլօպօ կէպէկէն թոկի Այա։ նի լա"/>
                <ITEXT FONT="Noto Sans Regular" CH="․"/>
                <ITEXT FONT="Noto Sans Armenian Regular" CH=" ոնա լի պալի է նասին սիթէլէն թոկի նի՜։ լօկին լա ոնա էն սիթէլէն Էլին լի սամա լիլի"/>
                <ITEXT FONT="Noto Sans Regular" CH=","/>
                <ITEXT FONT="Noto Sans Armenian Regular" CH=" թասո սիթէլէն լի մօթէ"/>
                <ITEXT FONT="Noto Sans Regular" CH=","/>
                <ITEXT FONT="Noto Sans Armenian Regular" CH=" լի պանա է կալամա անթէ։ պալի ոնա լի ոպէն է սիթէլէն Այա լի վավա թէնպո է թոկի Այա։ նի լա ոնա լի կամա մամա պի թոկի լիպօ Այա թավա կօլօպօ։"/>
                <para/>
                <ITEXT FONT="Noto Sans Armenian Regular" CH="կօլօպօ Այա լի կէն ավէն է թոկի ոնա"/>
                <ITEXT FONT="Noto Sans Regular" CH=","/>
                <ITEXT FONT="Noto Sans Armenian Regular" CH=" թասո ոնա լի ավէն վավա ալա"/>
                <ITEXT FONT="Noto Sans Regular" CH=","/>
                <ITEXT FONT="Noto Sans Armenian Regular" CH=" լի ավէն անպա լոն մօթէ։ կօլօպօ Ալապի էն լավա Լոմա սին էն կօլօպօ Թօկի էն լավա Կաթէլո էն լավա Իլան սին էն լավա Լօսի լի կամա լավա է մա Այա։ թէնպո լիլի թասո լա կօլօպօ Այա լի կէն լավա է մա ոնա։ լավա պի մա սօլի լա ոնա լի թավա մա անթէ կին"/>
