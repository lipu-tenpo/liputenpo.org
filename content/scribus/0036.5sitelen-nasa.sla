        <PAGEOBJECT XPOS="589.606299212598" YPOS="2960.95843180172" OwnPage="8" ItemID="1522540978" PTYPE="4" WIDTH="128.89815608492" HEIGHT="242.191174497493" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L128.898 0 L128.898 242.191 L0 242.191 L0 0 Z" copath="M0 0 L128.898 0 L128.898 242.191 L0 242.191 L0 0 Z" gXpos="170.07874015748" gYpos="3612.92693573872" gWidth="0" gHeight="0" PSTYLE="smaller par gap" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="smaller par gap" FONTSIZE="13.5"/>
                <ITEXT FONT="sitelen leko  Regular" FONTSIZE="13.5" FCOLOR="unu pimeja" CH="janmute "/>
                <ITEXT FONT="sitelen leko  Regular" FONTSIZE="13.5" CH="lianu-- esitelen-pi_nimi-sitelenpona tanni: sitelenni lipona-liikeala. tokipona lijo- e_nimimutemutemutela sitelenpona lijo- esitelenlilipinanpasama."/>
                <para PARENT="smaller par gap"/>
                <ITEXT FONT="sitelen leko  Regular" FONTSIZE="13.5" CH="janmute lianu-- eona- tanni: sitelenlilipisitelenpona lipona-tawa-lukin-. jan- likenkamasonapona eona-."/>
                <para PARENT="smaller par gap"/>
                <ITEXT FONT="sitelen leko  Regular" FONTSIZE="13.5" CH="janmute lianu-- eona- tanni: ona- lilon-maale. jan- liwilelukin eona-la jan- likenlukin eona-."/>
                <para PARENT="smaller par gap"/>
                <ITEXT FONT="sitelen leko  Regular" FONTSIZE="13.5" CH="janmute lianu-- eona- tanni: ona- lisitelenpona."/>
                <para PARENT="smaller par gap"/>
                <ITEXT FONT="sitelen leko  Regular" FONTSIZE="13.5" CH="janmute lianu-- esitelen-pi_nimi-sitelensuwi. ona- lianu-- eona- tanni: ona- lipona- limusi-tawa-lukin-"/>
                <para PARENT="smaller par gap"/>
                <ITEXT FONT="sitelen leko  Regular" FONTSIZE="13.5" CH="janmute lianu-- eona- tanni: jan- liwilesitelen kepeken-nasinmusila jan- likensitelen kepeken-nasinni."/>
                <para PARENT="smaller par gap"/>
                <ITEXT FONT="sitelen leko  Regular" FONTSIZE="13.5" CH="janmute lianu-- eona- tanni: sitelenmajunapitoki-MAYAla sitelensuwi lisama-tawa-lukin-."/>
                <para PARENT="smaller par gap"/>
                <ITEXT FONT="sitelen leko  Regular" FONTSIZE="13.5" CH="janmute lianu-- eona- tanni: jan- likenkule eona-!"/>
                <para PARENT="smaller par gap"/>
                <ITEXT FONT="sitelen leko  Regular" FONTSIZE="13.5" CH="jan-pinanpalili en mi- lianu-- esitelenante. mianu- esitelenmi. mianu- esitelenkuwi."/>
                <trail PARENT="smaller par gap"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="751.639148481439" YPOS="2935.11481573474" OwnPage="8" ItemID="1522928370" PTYPE="4" WIDTH="192.297859392576" HEIGHT="268.034790564475" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L192.298 0 L192.298 268.035 L0 268.035 L0 0 Z" copath="M0 0 L192.298 0 L192.298 268.035 L0 268.035 L0 0 Z" gXpos="332.11158942632" gYpos="3587.08331967174" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle LINESPMode="1"/>
                <ITEXT FONT="Andika Bold" CH="jan li anu e sitelen seme?"/>
                <breakline/>
                <ITEXT CH="tan jan Kuwi"/>
                <para PARENT="transcript"/>
                <ITEXT CH="jan mute li anu e"/>
                <nbspace/>
                <ITEXT CH="sitelen pi nimi Sitelen Pona tan ni: sitelen ni li"/>
                <nbspace/>
                <ITEXT CH="pona li"/>
                <nbspace/>
                <ITEXT CH="ike ala. toki pona li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="nimi mute mute mute la sitelen pona li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="sitelen lili pi nanpa sama."/>
                <para PARENT="transcript"/>
                <ITEXT CH="jan mute li"/>
                <nbspace/>
                <ITEXT CH="anu e"/>
                <nbspace/>
                <ITEXT CH="ona tan ni: sitelen lili pi sitelen pona li"/>
                <nbspace/>
                <ITEXT CH="pona tawa lukin. jan li"/>
                <nbspace/>
                <ITEXT CH="ken kama sona pona e"/>
                <nbspace/>
                <ITEXT CH="ona."/>
                <para PARENT="transcript"/>
                <ITEXT CH="jan mute li"/>
                <nbspace/>
                <ITEXT CH="anu e"/>
                <nbspace/>
                <ITEXT CH="ona tan ni: ona li"/>
                <nbspace/>
                <ITEXT CH="lon ma ale. jan li"/>
                <nbspace/>
                <ITEXT CH="wile lukin e"/>
                <nbspace/>
                <ITEXT CH="ona la jan li"/>
                <nbspace/>
                <ITEXT CH="ken lukin e"/>
                <nbspace/>
                <ITEXT CH="ona."/>
                <para PARENT="transcript"/>
                <ITEXT CH="jan mute li"/>
                <nbspace/>
                <ITEXT CH="anu e"/>
                <nbspace/>
                <ITEXT CH="ona tan ni: ona li"/>
                <nbspace/>
                <ITEXT CH="sitelen pona."/>
                <para PARENT="transcript"/>
                <ITEXT CH="jan mute li"/>
                <nbspace/>
                <ITEXT CH="anu e"/>
                <nbspace/>
                <ITEXT CH="sitelen pi nimi Sitelen Suwi. ona li"/>
                <nbspace/>
                <ITEXT CH="anu e"/>
                <nbspace/>
                <ITEXT CH="ona tan ni: ona li"/>
                <nbspace/>
                <ITEXT CH="pona li"/>
                <nbspace/>
                <ITEXT CH="musi tawa lukin."/>
                <para PARENT="transcript"/>
                <ITEXT CH="jan mute li"/>
                <nbspace/>
                <ITEXT CH="anu e"/>
                <nbspace/>
                <ITEXT CH="ona tan ni: jan li"/>
                <nbspace/>
                <ITEXT CH="wile sitelen kepeken nasin musi la jan ni li"/>
                <nbspace/>
                <ITEXT CH="ken sitelen kepeken nasin ni."/>
                <para PARENT="transcript"/>
                <ITEXT CH="jan mute li"/>
                <nbspace/>
                <ITEXT CH="anu e"/>
                <nbspace/>
                <ITEXT CH="ona tan ni: sitelen majuna pi toki Maya la sitelen suwi li"/>
                <nbspace/>
                <ITEXT CH="sama tawa lukin."/>
                <para PARENT="transcript"/>
                <ITEXT CH="jan mute li"/>
                <nbspace/>
                <ITEXT CH="anu e"/>
                <nbspace/>
                <ITEXT CH="ona tan ni: jan li"/>
                <nbspace/>
                <ITEXT CH="ken kule e"/>
                <nbspace/>
                <ITEXT CH="ona!"/>
                <para PARENT="transcript"/>
                <ITEXT CH="jan pi nanpa lili en mi li"/>
                <nbspace/>
                <ITEXT CH="anu e"/>
                <nbspace/>
                <ITEXT CH="sitelen ante… mi anu e"/>
                <nbspace/>
                <ITEXT CH="sitelen mi. mi anu e"/>
                <nbspace/>
                <ITEXT CH="sitelen pi nimi Sitelen Kuwi."/>
                <para PARENT="transcript"/>
            </StoryText>
        </PAGEOBJECT>
