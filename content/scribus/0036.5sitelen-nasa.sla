        <PAGEOBJECT XPOS="589.606299212598" YPOS="2464.32283464567" OwnPage="6" ItemID="1562317170" PTYPE="4" WIDTH="354.330708661417" HEIGHT="72.6850393700779" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="14.1732283464567" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L354.331 0 L354.331 72.685 L0 72.685 L0 0 Z" copath="M0 0 L354.331 0 L354.331 72.685 L0 72.685 L0 0 Z" gXpos="589.606299212598" gYpos="2464.32283464567" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle KERN="0"/>
                <ITEXT KERN="0" CH="¹ mi lon ala kulupu Aja, li"/>
                <nbspace KERN="0"/>
                <ITEXT KERN="0" CH="poka ala tawa jan ni anu ma ona, taso nasin sitelen ona li"/>
                <nbspace KERN="0"/>
                <ITEXT KERN="0" CH="pona mute"/>
                <nbspace KERN="0"/>
                <ITEXT KERN="0" CH="a tawa mi. lipu musi li"/>
                <nbspace KERN="0"/>
                <ITEXT KERN="0" CH="kama li"/>
                <nbspace KERN="0"/>
                <ITEXT KERN="0" CH="ken e"/>
                <nbspace KERN="0"/>
                <ITEXT KERN="0" CH="mi la mi wile toki lon sitelen ni. nasin mi pi toki pona la kalama wan li"/>
                <nbspace KERN="0"/>
                <ITEXT KERN="0" CH="kepeken sitelen wan taso. lukin la sitelen wan o"/>
                <nbspace KERN="0"/>
                <ITEXT KERN="0" CH="sama ala sitelen ante. ni la kalama sitelen pi toki Aja li"/>
                <nbspace KERN="0"/>
                <ITEXT KERN="0" CH="ken sama ala kalama pi toki pona. ni li"/>
                <nbspace KERN="0"/>
                <ITEXT KERN="0" CH="nasin mi taso. kin la mi alasa sona e"/>
                <nbspace KERN="0"/>
                <ITEXT KERN="0" CH="nasin pi namako nimi, taso sona lili li"/>
                <nbspace KERN="0"/>
                <ITEXT KERN="0" CH="lon ma ilo la mi ken pakala. sina sona toki "/>
                <ITEXT FONT="Noto Sans Armenian Regular" KERN="0" CH="Հայերեն"/>
                <ITEXT KERN="0" CH=" li"/>
                <nbspace KERN="0"/>
                <ITEXT KERN="0" CH="wile pona e"/>
                <nbspace KERN="0"/>
                <ITEXT KERN="0" CH="nasin mi lon pali sina la o"/>
                <nbspace KERN="0"/>
                <ITEXT KERN="0" CH="ni!"/>
                <para PARENT="toki lili poka"/>
