        <PAGEOBJECT XPOS="825.059247340917" YPOS="1714.51417322834" OwnPage="4" ItemID="1558457218" PTYPE="4" WIDTH="118.877760533099" HEIGHT="184.698425196857" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L118.878 0 L118.878 184.698 L0 184.698 L0 0 Z" copath="M0 0 L118.878 0 L118.878 184.698 L0 184.698 L0 0 Z" gXpos="825.059247340917" gYpos="3670.41968503937" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="1566570290" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style" FONTSIZE="8.5"/>
                <ITEXT FONT="Andika Bold" CH="tenpo pi kulupu Aja"/>
                <breakline/>
                <ITEXT CH="tan jan lili Enta"/>
                <para PARENT="transcript"/>
                <ITEXT CH="ma Aja ([Hayastan]), li"/>
                <nbspace/>
                <ITEXT CH="lon poka pi kulupu nena [Kovkas], li"/>
                <nbspace/>
                <ITEXT CH="lon poka pi nena suli [Ararat]. ma Katelo en ma Tuki en ma Pasi en ma Asepasan li"/>
                <nbspace/>
                <ITEXT CH="lon poka pi ma ni. kulupu jan Aja li"/>
                <nbspace/>
                <ITEXT CH="majuna"/>
                <nbspace/>
                <ITEXT CH="a, sama ma suli [Asorestan], sama kulupu Elin. jan sona la kulupu Aja li"/>
                <nbspace/>
                <ITEXT CH="ken lon tenpo pi ma Pijani ([Vani]), tan ni: nimi pi toki Pijani li"/>
                <nbspace/>
                <ITEXT CH="awen"/>
                <nbspace/>
                <ITEXT CH="a lon toki Aja. toki la ona li"/>
                <nbspace/>
                <ITEXT CH="tan kulupu Into-Elopa, taso ona li"/>
                <nbspace/>
                <ITEXT CH="kama lon ma ni lon nasin seme? jan li"/>
                <nbspace/>
                <ITEXT CH="awen sona pona ala."/>
                <para PARENT="transcript"/>
                <ITEXT CH="kulupu Aja li"/>
                <nbspace/>
                <ITEXT CH="lili tawa kulupu ante. ni la kulupu ante li"/>
                <nbspace/>
                <ITEXT CH="lawa e"/>
                <nbspace/>
                <ITEXT CH="ona lon tenpo mute. mute la kulupu Pasi li"/>
                <nbspace/>
                <ITEXT CH="lawa e"/>
                <nbspace/>
                <ITEXT CH="ona. mute lili la kulupu Loma kin li"/>
                <nbspace/>
                <ITEXT CH="wile e"/>
                <nbspace/>
                <ITEXT CH="ma Aja, li"/>
                <nbspace/>
                <ITEXT CH="utala e"/>
                <nbspace/>
                <ITEXT CH="lawa Pasi tawa ni. taso, nena mute li"/>
                <nbspace/>
                <ITEXT CH="lon ma la, kulupu Aja li"/>
                <nbspace/>
                <ITEXT CH="ken lawa lili lon anpa pi lawa ante, li"/>
                <nbspace/>
                <ITEXT CH="ken lawa pi anpa ala. ona li"/>
                <nbspace/>
                <ITEXT CH="ken awen lon nasin ona."/>
                <para PARENT="transcript"/>
                <ITEXT CH="ni la nasin ona li"/>
                <nbspace/>
                <ITEXT CH="ante lon seme? wan la ona li"/>
                <nbspace/>
                <ITEXT CH="ma nanpa wan pi nasin sewi Kolisu. lawa ona li"/>
                <nbspace/>
                <ITEXT CH="kama lon nasin ni la lawa pi ma ante li"/>
                <nbspace/>
                <ITEXT CH="awen lon nasin ni ala. tenpo lon la, nena li"/>
                <nbspace/>
                <ITEXT CH="weka e"/>
                <nbspace/>
                <ITEXT CH="ona tan kulupu ante pi nasin sewi sama la, kulupu Aja en kulupu ante li"/>
                <nbspace/>
                <ITEXT CH="awen wan ala. ante la nasin sitelen toki li"/>
                <nbspace/>
                <ITEXT CH="lon tawa toki Aja taso. ni li"/>
                <nbspace/>
                <ITEXT CH="tan jan [Mesrop Mashtots], li"/>
                <nbspace/>
                <ITEXT CH="tan pana ona pi nasin sewi. ona li"/>
                <nbspace/>
                <ITEXT CH="wile toki e"/>
                <nbspace/>
                <ITEXT CH="nasin sewi e"/>
                <nbspace/>
                <ITEXT CH="lipu sewi tawa kulupu kepeken toki Aja. ni la ona li"/>
                <nbspace/>
                <ITEXT CH="pali e"/>
                <nbspace/>
                <ITEXT CH="nasin sitelen toki ni! lukin la ona en sitelen Elin li"/>
                <nbspace/>
                <ITEXT CH="sama lili, taso sitelen li"/>
                <nbspace/>
                <ITEXT CH="mute, li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="kalama ante. pali ona li"/>
                <nbspace/>
                <ITEXT CH="open e"/>
                <nbspace/>
                <ITEXT CH="sitelen Aja li"/>
                <nbspace/>
                <ITEXT CH="wawa tenpo e"/>
                <nbspace/>
                <ITEXT CH="toki Aja. ni la ona li"/>
                <nbspace/>
                <ITEXT CH="kama mama pi toki lipu Aja tawa kulupu."/>
                <para PARENT="transcript"/>
                <ITEXT CH="kulupu Aja li"/>
                <nbspace/>
                <ITEXT CH="ken awen e"/>
                <nbspace/>
                <ITEXT CH="toki ona, taso ona li"/>
                <nbspace/>
                <ITEXT CH="awen wawa ala, li"/>
                <nbspace/>
                <ITEXT CH="awen anpa lon mute. kulupu Alapi en lawa Loma sin en kulupu Tuki en lawa Katelo en lawa Pasi sin en lawa Lusi li"/>
                <nbspace/>
                <ITEXT CH="kama lawa e"/>
                <nbspace/>
                <ITEXT CH="ma Aja. tenpo lili taso la kulupu Aja li"/>
                <nbspace/>
                <ITEXT CH="ken lawa e"/>
                <nbspace/>
                <ITEXT CH="ma ona. lawa pi ma suli la ona li"/>
                <nbspace/>
                <ITEXT CH="tawa ma ante kin, tan mani, tan utala ala, tan wile pi pona lon. anpa la weka ma la jan mute li"/>
                <nbspace/>
                <ITEXT CH="awen lon nasin ona."/>
                <para PARENT="transcript"/>
                <ITEXT CH="taso lawa li"/>
                <nbspace/>
                <ITEXT CH="ken wile ala e"/>
                <nbspace/>
                <ITEXT CH="ni. ma pi lawa Tuki la jan li"/>
                <nbspace/>
                <ITEXT CH="kama pilin e"/>
                <nbspace/>
                <ITEXT CH="ni: ma insa Tuki la jan ale o"/>
                <nbspace/>
                <ITEXT CH="lon nasin pi kulupu Tuki. kin la lawa Lusi pi nasin Kolisu li"/>
                <nbspace/>
                <ITEXT CH="utala mute e"/>
                <nbspace/>
                <ITEXT CH="lawa Tuki, la jan mute li"/>
                <nbspace/>
                <ITEXT CH="kama pilin ike tawa jan pi nasin Kolisu, li"/>
                <nbspace/>
                <ITEXT CH="pilin e"/>
                <nbspace/>
                <ITEXT CH="ni: ona"/>
                <nbspace/>
                <ITEXT CH="a li"/>
                <nbspace/>
                <ITEXT CH="utala lon poka pi lawa Lusi! ni la lawa li"/>
                <nbspace/>
                <ITEXT CH="alasa nasin Tuki e"/>
                <nbspace/>
                <ITEXT CH="jan ni lon wile ala ona. jan li"/>
                <nbspace/>
                <ITEXT CH="awen ante ala e"/>
                <nbspace/>
                <ITEXT CH="nasin ona la, lawa li"/>
                <nbspace/>
                <ITEXT CH="lanpan e"/>
                <nbspace/>
                <ITEXT CH="ijo ona, li"/>
                <nbspace/>
                <ITEXT CH="weka e"/>
                <nbspace/>
                <ITEXT CH="ona tan ma ona tawa ma pi telo ala, li"/>
                <nbspace/>
                <ITEXT CH="moli e"/>
                <nbspace/>
                <ITEXT CH="ona mute. ni la kulupu Aja pi ma ni li"/>
                <nbspace/>
                <ITEXT CH="kama lili li"/>
                <nbspace/>
                <ITEXT CH="kama weka. tenpo lon la lawa Tuki li"/>
                <nbspace/>
                <ITEXT CH="awen wile ala toki e"/>
                <nbspace/>
                <ITEXT CH="ike ni."/>
                <para PARENT="transcript"/>
                <ITEXT CH="tenpo poka la lawa Aja en lawa Asepasan li"/>
                <nbspace/>
                <ITEXT CH="utala lon ma [Artsakh]. ma ni la jan mute pi kulupu Aja en jan mute kin pi kulupu Asepasan li"/>
                <nbspace/>
                <ITEXT CH="lon, taso lawa li"/>
                <nbspace/>
                <ITEXT CH="wile weka e"/>
                <nbspace/>
                <ITEXT CH="jan pi kulupu ante lon utala. pini la lawa Asepasan li"/>
                <nbspace/>
                <ITEXT CH="wawa, li"/>
                <nbspace/>
                <ITEXT CH="anpa e"/>
                <nbspace/>
                <ITEXT CH="lawa utala Aja, li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="wile moli pi kulupu Aja. jan pi kulupu Aja li"/>
                <nbspace/>
                <ITEXT CH="wile ala moli la ona li"/>
                <nbspace/>
                <ITEXT CH="weka tan ma ni."/>
                <para PARENT="transcript"/>
                <ITEXT CH="awen la jan pi kulupu ante li"/>
                <nbspace/>
                <ITEXT CH="ike tawa jan pi kulupu Aja, li"/>
                <nbspace/>
                <ITEXT CH="pakala e"/>
                <nbspace/>
                <ITEXT CH="tomo majuna kulupu lon weka ona, li"/>
                <nbspace/>
                <ITEXT CH="awen toki e"/>
                <nbspace/>
                <ITEXT CH="moli kulupu. taso, kulupu Aja li"/>
                <nbspace/>
                <ITEXT CH="awen, lon ma lili Aja, lon ma mute weka. jan mute pi kulupu ni li"/>
                <nbspace/>
                <ITEXT CH="awen"/>
                <nbspace/>
                <ITEXT CH="a lon nasin ona, li"/>
                <nbspace/>
                <ITEXT CH="toki Aja, li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="tenpo pini ona, li"/>
                <nbspace/>
                <ITEXT CH="pona e"/>
                <nbspace/>
                <ITEXT CH="tenpo kama kulupu. ona o"/>
                <nbspace/>
                <ITEXT CH="awen pona"/>
                <nbspace/>
                <ITEXT CH="a!"/>
                <para PARENT="transcript"/>
            </StoryText>
        </PAGEOBJECT>
