        <PAGEOBJECT XPOS="764.007792466678" YPOS="4104.32775590551" OwnPage="12" ItemID="1536727586" PTYPE="4" WIDTH="179.929215407337" HEIGHT="402.758858267719" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L179.929 0 L179.929 402.759 L0 402.759 L0 0 Z" copath="M0 0 L179.929 0 L179.929 402.759 L0 402.759 L0 0 Z" gXpos="764.007792466678" gYpos="2800.39074803149" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT FONT="Andika Bold" CH="suno Miku-Sinku"/>
                <breakline/>
                <ITEXT CH="tan jan Alonola tan jan Siniseli"/>
                <breakline/>
                <ITEXT CH="sitelen li tan jan Ke Tami"/>
                <para PARENT="transcript"/>
                <ITEXT CH="tenpo pini la tenpo suno musi li"/>
                <nbspace/>
                <ITEXT CH="lon. ona li"/>
                <nbspace/>
                <ITEXT CH="suno open pi mun nanpa tu tu. nasa la tenpo suno ni li"/>
                <nbspace/>
                <ITEXT CH="suno Miku-Sinku kin"/>
                <nbspace/>
                <ITEXT CH="a! suno Miku-Sinku li"/>
                <nbspace/>
                <ITEXT CH="tenpo musi lon ma Posuka li"/>
                <nbspace/>
                <ITEXT CH="lon ma ante kin."/>
                <para PARENT="transcript"/>
                <ITEXT CH="tenpo ni en nimi ona li"/>
                <nbspace/>
                <ITEXT CH="musi li"/>
                <nbspace/>
                <ITEXT CH="nasa"/>
                <nbspace/>
                <ITEXT CH="a. jan li"/>
                <nbspace/>
                <ITEXT CH="sona lili e"/>
                <nbspace/>
                <ITEXT CH="ni: nimi Miku-Sinku li"/>
                <nbspace/>
                <ITEXT CH="tan nimi open seme? taso jan mute li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="ni: nimi Miku (Śmigus) li"/>
                <nbspace/>
                <ITEXT CH="tan nimi Makotan (Schmackostern) tan toki Tosi. ken la nimi Sinku li"/>
                <nbspace/>
                <ITEXT CH="tan toki Tosi kin li"/>
                <nbspace/>
                <ITEXT CH="tan nimi Sunku (dünguuss)."/>
                <para PARENT="transcript"/>
                <ITEXT CH="tenpo moli Jesu li"/>
                <nbspace/>
                <ITEXT CH="lon la suno Miku-Sinku li"/>
                <nbspace/>
                <ITEXT CH="lon suno nanpa wan pi tenpo esun kama."/>
                <para PARENT="transcript"/>
                <ITEXT CH="seme li"/>
                <nbspace/>
                <ITEXT CH="lon suno Miku-Sinku? ma Posuka la jan mije li"/>
                <nbspace/>
                <ITEXT CH="telo e"/>
                <nbspace/>
                <ITEXT CH="jan meli. ona li"/>
                <nbspace/>
                <ITEXT CH="kepeken e"/>
                <nbspace/>
                <ITEXT CH="poki telo e"/>
                <nbspace/>
                <ITEXT CH="ilo utala telo. tenpo pini la jan meli li"/>
                <nbspace/>
                <ITEXT CH="telo e"/>
                <nbspace/>
                <ITEXT CH="jan mije lon tenpo suno kama. taso tenpo ni la jan ale li"/>
                <nbspace/>
                <ITEXT CH="utala telo"/>
                <nbspace/>
                <ITEXT CH="a. ken la jan li"/>
                <nbspace/>
                <ITEXT CH="kepeken ala e"/>
                <nbspace/>
                <ITEXT CH="telo li"/>
                <nbspace/>
                <ITEXT CH="kepeken e"/>
                <nbspace/>
                <ITEXT CH="palisa kasi tawa utala."/>
                <para PARENT="transcript"/>
                <ITEXT CH="sina wile ala utala telo la sina o"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="sike mama kule anu suwi tawa jan ante. ni la sina ken awen telo ala."/>
                <para PARENT="transcript"/>
                <ITEXT CH="sina wile telo e"/>
                <nbspace/>
                <ITEXT CH="jan pona sina lon tenpo ni la o"/>
                <nbspace/>
                <ITEXT CH="awen! telo li"/>
                <nbspace/>
                <ITEXT CH="ken pakala e"/>
                <nbspace/>
                <ITEXT CH="ilo."/>
                <para PARENT="transcript"/>
                <ITEXT CH="jan li"/>
                <nbspace/>
                <ITEXT CH="utala telo tan seme? nanpa wan la musi! jan sona li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="ni: tenpo pini la tenpo Miku en tenpo Sinku li"/>
                <nbspace/>
                <ITEXT CH="tenpo tu li"/>
                <nbspace/>
                <ITEXT CH="tenpo wan ala. tenpo Miku la jan li"/>
                <nbspace/>
                <ITEXT CH="utala telo. tenpo Sinku la jan li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="sike mama kule tawa ni: ona li"/>
                <nbspace/>
                <ITEXT CH="kama telo ala. ken la jan li"/>
                <nbspace/>
                <ITEXT CH="utala telo tan ni: jan li"/>
                <nbspace/>
                <ITEXT CH="telo e"/>
                <nbspace/>
                <ITEXT CH="jan la telo en kasi suli li"/>
                <nbspace/>
                <ITEXT CH="kama."/>
                <para PARENT="transcript"/>
            </StoryText>
        </PAGEOBJECT>
