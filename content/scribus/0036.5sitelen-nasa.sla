        <PAGEOBJECT XPOS="773.858464566929" YPOS="708.661417322835" OwnPage="2" ItemID="1528149090" PTYPE="4" WIDTH="170.078606299213" HEIGHT="538.582677165354" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L170.079 0 L170.079 538.583 L0 538.583 L0 0 Z" copath="M0 0 L170.079 0 L170.079 538.583 L0 538.583 L0 0 Z" gXpos="773.858464566929" gYpos="708.661417322835" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT FONT="Andika Bold" CH="kiwen toki pi jan Eja Nasi"/>
                <breakline/>
                <ITEXT CH="tan jan linluwi Mota tan jan lili Enta"/>
                <breakline/>
                <ITEXT CH="sitelen li tan jan Alonola"/>
                <para PARENT="transcript"/>
                <ITEXT CH="jan Eja Nasi"/>
                <nbspace/>
                <ITEXT CH="o: jan Nani li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="toki ni:"/>
                <para PARENT="transcript"/>
                <ITEXT CH="sina kama la, sina toki e"/>
                <nbspace/>
                <ITEXT CH="ni tawa mi: “mi pana e"/>
                <nbspace/>
                <ITEXT CH="kiwen leko mani loje pi pona mute tawa jan Kimi Sin lon kama ona.” taso sina weka lon pini toki la sina pali sama ala toki sina. sina pana e"/>
                <nbspace/>
                <ITEXT CH="leko pi pona ala tawa jan kama mi Si Sin li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="ni: “sina wile jo e"/>
                <nbspace/>
                <ITEXT CH="ona la o"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="ona, sina wile ala jo e"/>
                <nbspace/>
                <ITEXT CH="ona la o"/>
                <nbspace/>
                <ITEXT CH="weka"/>
                <nbspace/>
                <ITEXT CH="a!”"/>
                <para PARENT="transcript"/>
                <ITEXT CH="sina ike pi mute ni tawa mi la mi jan pi suli seme tawa sina? mi pana e"/>
                <nbspace/>
                <ITEXT CH="mije pona sama mi tan wile jo pi poki mani mi tawa tomo sina, taso sina weka sin e"/>
                <nbspace/>
                <ITEXT CH="ona li"/>
                <nbspace/>
                <ITEXT CH="pana ala e"/>
                <nbspace/>
                <ITEXT CH="mani mi. ona li"/>
                <nbspace/>
                <ITEXT CH="tawa mute lon ma ike tan ni, la sina ike ale tawa mi. jan ante li"/>
                <nbspace/>
                <ITEXT CH="esun tan ma Temun la ona seme li"/>
                <nbspace/>
                <ITEXT CH="ni tawa mi? sina taso li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="ike mute tawa jan mi"/>
                <nbspace/>
                <ITEXT CH="a! mi pana ala kin e"/>
                <nbspace/>
                <ITEXT CH="kiwen mani walo pi suli Mina wan taso la sina pilin e"/>
                <nbspace/>
                <ITEXT CH="ni: sina ken toki ike sama ni. taso mi pana e"/>
                <nbspace/>
                <ITEXT CH="kiwen mani loje kin pi suli Teki 1080 tawa tomo suli lawa li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="ni: “jan Eja Nasi li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="ni.” kin la jan Sumi Apun li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="mute sama li"/>
                <nbspace/>
                <ITEXT CH="toki sama. ijo pona ante la mi tu li"/>
                <nbspace/>
                <ITEXT CH="toki sitelen e"/>
                <nbspace/>
                <ITEXT CH="ona lon kiwen li"/>
                <nbspace/>
                <ITEXT CH="awen e"/>
                <nbspace/>
                <ITEXT CH="ona lon tomo sewi Sama."/>
                <para PARENT="transcript"/>
                <ITEXT CH="mi ni ale la sina awen ike tawa mi tan seme? sina awen jo e"/>
                <nbspace/>
                <ITEXT CH="poki mani mi tan ala wile mi lon ma pi jan ike, la o"/>
                <nbspace/>
                <ITEXT CH="pana sin e"/>
                <nbspace/>
                <ITEXT CH="ona ale."/>
                <para PARENT="transcript"/>
                <ITEXT CH="o"/>
                <nbspace/>
                <ITEXT CH="sona e"/>
                <nbspace/>
                <ITEXT CH="ni: tenpo kama la kiwen mani loje li"/>
                <nbspace/>
                <ITEXT CH="pona mute ala la mi wile ala e"/>
                <nbspace/>
                <ITEXT CH="ona. kama la mi wan li"/>
                <nbspace/>
                <ITEXT CH="lukin e"/>
                <nbspace/>
                <ITEXT CH="leko ale li"/>
                <nbspace/>
                <ITEXT CH="kama jo e"/>
                <nbspace/>
                <ITEXT CH="leko pi wile mi lon ma mi. mi kama ken"/>
                <nbspace/>
                <ITEXT CH="a wile ala e"/>
                <nbspace/>
                <ITEXT CH="ijo sina tan ni: sina ike mute tawa mi."/>
                <para PARENT="transcript"/>
                <ITEXT FONTSIZE="7.1" FCOLOR="kapesi" FSHADE="100" CH="¹ toki ni li"/>
                <nbspace FONTSIZE="7.1" FCOLOR="kapesi" FSHADE="100"/>
                <ITEXT FONTSIZE="7.1" FCOLOR="kapesi" FSHADE="100" CH="kepeken pali pi jan"/>
                <nbspace FONTSIZE="7.1" FCOLOR="kapesi" FSHADE="100"/>
                <ITEXT FONTSIZE="7.1" FCOLOR="kapesi" FSHADE="100" CH="A. Leo Oppenheim"/>
                <breakline/>
                <ITEXT FONTSIZE="7.1" FCOLOR="kapesi" FSHADE="100" CH="lon lipu ni "/>
                <ITEXT CPARENT="Text84_Italic" FONTSIZE="7.1" FCOLOR="kapesi" FSHADE="100" CH="Letters From Mesopotamia"/>
                <ITEXT FONTSIZE="7.1" FCOLOR="kapesi" FSHADE="100" CH=": https:"/>
                <breakline/>
                <ITEXT FONTSIZE="7.1" FCOLOR="kapesi" FSHADE="100" CH="//isac.uchicago.edu/research/publications/misc"/>
                <breakline/>
                <ITEXT FONTSIZE="7.1" FCOLOR="kapesi" FSHADE="100" CH="/letters-mesopotamia-official-business-and"/>
                <breakline/>
                <ITEXT FONTSIZE="7.1" FCOLOR="kapesi" FSHADE="100" CH="-private-letters-clay-tablets"/>
                <para PARENT="toki lili poka"/>
            </StoryText>
        </PAGEOBJECT>
