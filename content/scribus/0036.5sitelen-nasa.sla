                <breakline/>
                <ITEXT CH="lon lipu tenpo ni!"/>
                <breakline/>
                <ITEXT CH="mi mu e mu lili"/>
                <breakline/>
                <ITEXT CH="lon open ona:"/>
                <breakline/>
                <ITEXT CH="mu, mu mu mu."/>
                <para ParagraphEffectOffset="0" ParagraphEffectIndent="0" DROP="0" DROPLIN="2" Bullet="0" Numeration="0"/>
                <ITEXT CH="taso mu ni taso ala"/>
                <breakline/>
                <ITEXT CH="li lon! o lukin"/>
                <breakline/>
                <ITEXT CH="e insa pi lipu tenpo ni."/>
                <breakline/>
                <ITEXT CH="jan mute ante"/>
                <breakline/>
                <ITEXT CH="li mu anu toki."/>
                <para ParagraphEffectOffset="0" ParagraphEffectIndent="0" DROP="0" DROPLIN="2" Bullet="0" Numeration="0"/>
                <ITEXT CH="ni la o musi pona"/>
                <breakline/>
                <ITEXT CH="kepeken lipu tenpo!"/>
