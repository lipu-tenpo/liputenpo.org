                <ITEXT FONT="Noto Sans Regular" CH=","/>
                <ITEXT FONT="Noto Sans Armenian Regular" CH=" լի վէկա է ոնա թան մա ոնա թավա մա պի թէլո ալա"/>
                <ITEXT FONT="Noto Sans Regular" CH=","/>
