        <PAGEOBJECT XPOS="629.229529087103" YPOS="4667.57480314961" OwnPage="14" ItemID="741986444" PTYPE="4" WIDTH="130.253481597832" HEIGHT="314.454996735742" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L130.253 0 L130.253 314.455 L0 314.455 L0 0 Z" copath="M0 0 L130.253 0 L130.253 314.455 L0 314.455 L0 0 Z" gXpos="629.229529087103" gYpos="4667.57480314961" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="741957532" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT FONT="Andika Bold" FCOLOR="kapesi pimeja" FSHADE="100" CH="mi supa."/>
                <breakline/>
                <ITEXT CH="kon lete li kama lon lupa."/>
                <breakline/>
                <ITEXT CH="ona li pilin e sinpin mi,"/>
                <breakline/>
                <ITEXT CH="li open e kute mi."/>
                <breakline/>
                <ITEXT CH="tenpo pimeja li weka la,"/>
                <breakline/>
                <ITEXT CH="kalama pi waso mute li wan."/>
                <breakline/>
                <ITEXT CH="tan ni la,"/>
                <breakline/>
                <ITEXT CH="mi ken ala kute e waso wan."/>
                <para/>
                <ITEXT CH="sona mute li kama lon lawa mi."/>
                <breakline/>
                <ITEXT CH="ona li awen ala, li utala."/>
                <breakline/>
                <ITEXT CH="lape li weka."/>
                <breakline/>
                <ITEXT CH="sona li suli."/>
                <breakline/>
                <ITEXT CH="o pilin! mi lon."/>
                <breakline/>
                <ITEXT CH="tenpo suno sin li kama."/>
                <para/>
                <ITEXT CH="mi supa."/>
                <breakline/>
                <ITEXT CH="kon lete li kama lon lupa."/>
                <breakline/>
                <ITEXT CH="ona li uta e len oko mi,"/>
                <breakline/>
                <ITEXT CH="li open e lukin mi."/>
                <breakline/>
                <ITEXT CH="tenpo suno li kama la,"/>
                <breakline/>
                <ITEXT CH="nena suli li jo e len walo."/>
                <breakline/>
                <ITEXT CH="tan ni la,"/>
                <breakline/>
                <ITEXT CH="mi ken ala lukin e sinpin kiwen."/>
                <para/>
                <ITEXT CH="sona mute li kama lon lawa mi."/>
                <breakline/>
                <ITEXT CH="ona li awen ala, li utala."/>
                <breakline/>
                <ITEXT CH="lape li weka."/>
                <breakline/>
                <ITEXT CH="sona li suli."/>
                <breakline/>
                <ITEXT CH="o pilin! mi lon."/>
                <breakline/>
                <ITEXT CH="tenpo suno sin li kama."/>
                <para/>
                <ITEXT CH="mi supa."/>
                <breakline/>
                <ITEXT CH="mi ken ala sona e pini e kama."/>
                <breakline/>
                <ITEXT CH="mi awen taso lon ni: mi lon."/>
                <breakline/>
                <ITEXT CH="jan li toki. mi kute e ona."/>
                <breakline/>
                <ITEXT CH="sama la, toki li kama e pilin mi."/>
                <para/>
                <ITEXT CH="sona mute li kama lon lawa mi."/>
                <breakline/>
                <ITEXT CH="ona li awen ala, li utala."/>
                <breakline/>
                <ITEXT CH="lape li weka. sona li suli."/>
                <breakline/>
                <ITEXT CH="o pilin! mi lon."/>
                <breakline/>
                <ITEXT CH="tenpo suno sin li kama."/>
                <para/>
                <ITEXT CH="sona mute li kama lon lawa mi."/>
                <breakline/>
                <ITEXT CH="ona li lanpan e lape mi."/>
                <breakline/>
                <ITEXT CH="mi kute ala kute e sona ni?"/>
                <breakline/>
                <ITEXT CH="o pilin! mi lon."/>
                <breakline/>
                <ITEXT CH="tenpo suno sin li kama."/>
                <para/>
                <ITEXT CH="mi tawa."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
