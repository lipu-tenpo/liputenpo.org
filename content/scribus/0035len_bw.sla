            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT CPARENT="Text82_Bold" FCOLOR="kapesi pimeja" FSHADE="100" CH="tenpo sike pini li"/>
                <nbspace CPARENT="Text82_Bold" FCOLOR="kapesi pimeja" FSHADE="100"/>
                <ITEXT CPARENT="Text82_Bold" FCOLOR="kapesi pimeja" FSHADE="100" CH="sike soweli."/>
                <ITEXT CH=" ken la sina wile sona. mi toki e"/>
                <nbspace/>
                <ITEXT CH="soweli tan seme"/>
                <nbspace/>
                <ITEXT CH="a? ni li"/>
                <nbspace/>
                <ITEXT CH="tan nasin tenpo pi ma Sonko anu seme? ala"/>
                <nbspace/>
                <ITEXT CH="a! nasin pi ma Sonko la tenpo sike ni li"/>
                <nbspace/>
                <ITEXT CH="tenpo akesi. tenpo sike pi toki mi li"/>
                <nbspace/>
                <ITEXT CH="sike nanpa 2025. nasin nanpa pi toki pona la ni li"/>
                <nbspace/>
                <ITEXT CH="sike nanpa "/>
                <ITEXT FONTFEATURES="-clig,+c2sc,+ss01" CH="MAML"/>
                <ITEXT CH=". kalama pi nimi "/>
                <ITEXT FONTFEATURES="-clig,+c2sc,+ss01" CH="MAML"/>
                <ITEXT CH=" li"/>
                <nbspace/>
                <ITEXT CH="sama nimi soweli pi toki Inli. musi lili toki"/>
                <nbspace/>
                <ITEXT CH="a."/>
                <para/>
                <ITEXT CH="tenpo sike "/>
                <ITEXT FONTFEATURES="-clig,+c2sc,+ss01" CH="MAML"/>
                <ITEXT CH=" li"/>
                <nbspace/>
                <ITEXT CH="suli tawa kulupu pi toki pona. mi kulupu li"/>
                <nbspace/>
                <ITEXT CH="pali mute"/>
                <nbspace/>
                <ITEXT CH="a. tenpo pini poka la, sike li"/>
                <nbspace/>
                <ITEXT CH="pini. ni la mi o"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="ijo suli ale ona!"/>
                <para/>
                <ITEXT CPARENT="Text82_Bold" CH="jan li"/>
                <nbspace CPARENT="Text82_Bold"/>
                <ITEXT CPARENT="Text82_Bold" CH="kulupu li"/>
                <nbspace CPARENT="Text82_Bold"/>
                <ITEXT CPARENT="Text82_Bold" CH="musi lon ma"/>
                <ITEXT CH=". kulupu li"/>
                <nbspace/>
                <ITEXT CH="kama lon ma Sanpansiko, lon ma Ansetan, lon ma Lanten, lon ma Sijato, lon ma Sapu kin. lipu tenpo nanpa kala la, jan Kasape li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="tenpo kulupu pi ma Ansetan. lipu tenpo nanpa lon la, jan Ke Tami li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="tenpo kulupu pi ma Sapu. sina lon ma Mewika anu lon ma Kanata anu lon ma Elopa la, ken suli la, sina kin li"/>
                <nbspace/>
                <ITEXT CH="ken kama lon kulupu! mi lon ma weka li"/>
                <nbspace/>
                <ITEXT CH="ken ala. taso mi sona e"/>
                <nbspace/>
                <ITEXT CH="ni: jan li"/>
                <nbspace/>
                <ITEXT CH="kama lon poka la, tenpo musi li"/>
                <nbspace/>
                <ITEXT CH="pona e"/>
                <nbspace/>
                <ITEXT CH="pilin ona, li"/>
                <nbspace/>
                <ITEXT CH="wawa e"/>
                <nbspace/>
                <ITEXT CH="wile kulupu ona."/>
                <para/>
                <ITEXT CPARENT="Text82_Bold" CH="lipu tenpo luka li"/>
                <nbspace CPARENT="Text82_Bold"/>
                <ITEXT CPARENT="Text82_Bold" CH="kama!"/>
                <ITEXT CH=" ni li"/>
                <nbspace/>
                <ITEXT CH="lipu tenpo nanpa kala, nanpa kokosila, nanpa supa, nanpa pilin, nanpa lon. sike sin la nanpa len kin"/>
                <nbspace/>
                <ITEXT CH="a li"/>
                <nbspace/>
                <ITEXT CH="kama! lipu ale la jan li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="toki, li"/>
                <nbspace/>
                <ITEXT CH="alasa pona e"/>
                <nbspace/>
                <ITEXT CH="pakala toki, li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="sitelen, li"/>
                <nbspace/>
                <ITEXT CH="nasin e"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="sitelen lon lipu. ni ale li"/>
                <nbspace/>
                <ITEXT CH="wile e"/>
                <nbspace/>
                <ITEXT CH="pali suli"/>
                <nbspace/>
                <ITEXT CH="a! taso kulupu li"/>
                <nbspace/>
                <ITEXT CH="awen pali, li"/>
                <nbspace/>
                <ITEXT CH="pini ala. sike ni la mi kin li"/>
                <nbspace/>
                <ITEXT CH="kama pana e"/>
                <nbspace/>
                <ITEXT CH="pali mi tawa kulupu. pali ni li"/>
                <nbspace/>
                <ITEXT CH="musi tawa mi, li"/>
                <nbspace/>
                <ITEXT CH="pona tawa kulupu. jan ale pi toki pona li"/>
                <nbspace/>
                <ITEXT CH="ken pana e"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="sitelen e"/>
                <nbspace/>
                <ITEXT CH="musi e"/>
                <nbspace/>
                <ITEXT CH="pona mute ante tawa lipu!"/>
                <para/>
                <ITEXT CPARENT="Text82_Bold" CH="seme li"/>
                <nbspace CPARENT="Text82_Bold"/>
                <ITEXT CPARENT="Text82_Bold" CH="soweli?"/>
                <ITEXT CH=" mun "/>
                <ITEXT FONTFEATURES="-clig,+c2sc,+ss01" CH="#T"/>
                <ITEXT CH=" la mi en jan Ke Tami li"/>
                <nbspace/>
                <ITEXT CH="kama sona"/>
                <nbspace/>
                <ITEXT CH="a! mi pali e"/>
                <nbspace/>
                <ITEXT CH="lipu. lipu la jan li"/>
                <nbspace/>
                <ITEXT CH="ken lukin e"/>
                <nbspace/>
                <ITEXT CH="sitelen li"/>
                <nbspace/>
                <ITEXT CH="ken toki e"/>
                <nbspace/>
                <ITEXT CH="soweli e"/>
                <nbspace/>
                <ITEXT CH="akesi e"/>
                <nbspace/>
                <ITEXT CH="waso e"/>
                <nbspace/>
                <ITEXT CH="kala e"/>
                <nbspace/>
                <ITEXT CH="pipi e"/>
                <nbspace/>
                <ITEXT CH="kasi e"/>
                <nbspace/>
                <ITEXT CH="ante mute. lipu li"/>
                <nbspace/>
                <ITEXT CH="wan e"/>
                <nbspace/>
                <ITEXT CH="sona ale. tenpo mute la jan li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="nimi ijo lon toki Inli li"/>
                <nbspace/>
                <ITEXT CH="wile sona e"/>
                <nbspace/>
                <ITEXT CH="ni: “a, ijo ni li"/>
                <nbspace/>
                <ITEXT CH="seme lon toki pona?” lipu wawa pi jan Ke Tami la mi ken pana e"/>
                <nbspace/>
                <ITEXT CH="sona kepeken pali lili"/>
                <nbspace/>
                <ITEXT CH="a. ni li"/>
                <nbspace/>
                <ITEXT CH="pona e"/>
                <nbspace/>
                <ITEXT CH="kama sona!¹"/>
                <para/>
                <ITEXT CPARENT="Text82_Bold" CH="sin kulupu ale li"/>
