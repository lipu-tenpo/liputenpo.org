                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="lon poka ante ("/>
                <ITEXT CPARENT="Text127_Italic" FONT="Noto Sans Italic" FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="Ἀντι-"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH=") tan nasin Asiko ("/>
                <ITEXT CPARENT="Text127_Italic" FONT="Noto Sans Italic" FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="Ἄρκτικός"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="). jan li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="wile tawa nasin ni la ona o"/>
