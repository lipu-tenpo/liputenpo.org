                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="kiwen telo ("/>
                <ITEXT CPARENT="Text127_Italic" FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="ice)"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH=" lon toki Inli ona; ni la ko li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="kama kiwen! tenpo mama la kulupu Mali li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="jo ala e"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="nimi tawa kiwen lete. jan mute li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="tawa poka walo lon tenpo sin, li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="lukin ala e"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="ijo jan tan tenpo toki. ken suli la ma Antasika en kiwen walo ona li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="awen len tawa kulupu."/>
                <para/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="jan li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="toki e"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="ni la tomo wawa"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="a li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="tawa ma Antasika lon tenpo sama. open la jan esun taso li"/>
