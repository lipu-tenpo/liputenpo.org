                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="wile ala; kin la ma Antasika li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="suli mute ala. taso nimi ma la toki Elena li"/>
                <nbspace FONTSIZE="8.5" FCOLOR="Black" FSHADE="100"/>
                <ITEXT FONTSIZE="8.5" FCOLOR="Black" FSHADE="100" CH="mama: nasin Antasiko ("/>
