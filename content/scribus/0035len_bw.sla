.23275 0.0103992 6.51485 0.18561 6.64638 C0.621274 6.97344 2.51778 7.00087 3.59462 6.99997 C4.56468 6.99929 5.97819 7.00866 6.36018 6.70842 C6.53982 6.56725 6.51057 6.24309 6.5407 6.15007 C6.51057 6.05702 6.53998 5.73321 6.36018 5.59202 C6.04353 5.34313 5.01979 5.30762 4.12566 5.30207 C4.15195 4.79911 4.13398 4.21352 4.13313 3.7456 C4.13204 3.20302 4.13241 2.46991 4.08266 1.83105 C5.09861 1.79858 6.09273 1.70251 6.37712 1.47938 C6.56419 1.33263 6.51341 1.01512 6.54072 0.922305 C6.51341 0.829496 6.56419 0.512298 6.37712 0.365554 C6.00178 0.0710599 4.39001 -0.00249854 3.12356 6.4026e-05 L3.12354 4.00768e-05 Z" fillRule="0" gXpos="642.355533707172" gYpos="2506.9939844973" gWidth="0" gHeight="0" LAYER="0"/>
        <PAGEOBJECT XPOS="178.582677165353" YPOS="4067.7874015748" OwnPage="11" ItemID="739301548" PTYPE="4" WIDTH="170.078543307087" HEIGHT="439.299212598428" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L170.079 0 L170.079 439.299 L0 439.299 L0 0 Z" copath="M0 0 L170.079 0 L170.079 439.299 L0 439.299 L0 0 Z" gXpos="178.582677165353" gYpos="4067.7874015748" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="740129932" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT CPARENT="Text154_Italic" FONT="Andika Bold" FCOLOR="kapesi pimeja" FSHADE="100" CH="akesi suli li"/>
                <nbspace CPARENT="Text154_Italic" FONT="Andika Bold" FCOLOR="kapesi pimeja" FSHADE="100"/>
                <ITEXT CPARENT="Text154_Italic" FONT="Andika Bold" FCOLOR="kapesi pimeja" FSHADE="100" CH="ken wawa tawa jan."/>
                <ITEXT CH=" jan li"/>
                <nbspace/>
                <ITEXT CH="lukin e"/>
                <nbspace/>
                <ITEXT CH="kiwen moli pi akesi pi tenpo weka mute (Dinosauria) la, ona li"/>
                <nbspace/>
                <ITEXT CH="toki insa: “akesi ni li"/>
                <nbspace/>
                <ITEXT CH="seme tawa lukin? selo ona li"/>
                <nbspace/>
                <ITEXT CH="len seme?” tenpo mute la, sijelo pi akesi moli la, kiwen insa li"/>
                <nbspace/>
                <ITEXT CH="awen taso lon tenpo mute suli."/>
                <para/>
                <ITEXT CH="tenpo pini la, jan sona li"/>
                <nbspace/>
                <ITEXT CH="toki: “kiwen moli ni li"/>
                <nbspace/>
                <ITEXT CH="sama akesi, la selo li"/>
                <nbspace/>
                <ITEXT CH="sama akesi kin! ona li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="nena lili mute"/>
                <nbspace/>
                <ITEXT CH="a!”"/>
                <para/>
                <ITEXT CH="ni la, jan mute li"/>
                <nbspace/>
                <ITEXT CH="sitelen e"/>
                <nbspace/>
                <ITEXT CH="akesi kepeken selo ni. taso selo akesi li"/>
                <nbspace/>
                <ITEXT CH="awen taso lon kiwen pi mute lili, li"/>
                <nbspace/>
                <ITEXT CH="ken suli mute. tenpo sike #"/>
                <ITEXT FONTFEATURES="-clig,+c2sc,+ss01" CH="MALW"/>
                <ITEXT CH=" la, jan sona li"/>
                <nbspace/>
                <ITEXT CH="kama jo e"/>
                <nbspace/>
                <ITEXT CH="kiwen akesi pi awen selo. akesi moli pi moku kasi (Dakota, hadrosaur) li"/>
                <nbspace/>
                <ITEXT CH="kama kiwen la, kiwen li"/>
                <nbspace/>
                <ITEXT CH="awen e"/>
                <nbspace/>
                <ITEXT CH="sijelo ona e"/>
                <nbspace/>
                <ITEXT CH="selo ona. lupa pakala li"/>
                <nbspace/>
                <ITEXT CH="awen kin. nena pi selo ona li"/>
                <nbspace/>
                <ITEXT CH="suli, li"/>
                <nbspace/>
                <ITEXT CH="lili."/>
                <para/>
                <ITEXT CH="tenpo #"/>
                <ITEXT FONTFEATURES="-clig,+c2sc,+ss01" CH="LLLTWAMMMW"/>
                <ITEXT CH=" la, jan sona li"/>
                <nbspace/>
                <ITEXT CH="kama jo e"/>
                <nbspace/>
                <ITEXT CH="kiwen waso (Archeopteryx). ni li"/>
                <nbspace/>
                <ITEXT CH="awen e"/>
                <nbspace/>
                <ITEXT CH="kiwen moli, e"/>
                <nbspace/>
                <ITEXT CH="len waso. jan mute li"/>
                <nbspace/>
                <ITEXT CH="toki: “a! ni li"/>
                <nbspace/>
                <ITEXT CH="waso pi tenpo nanpa wan!” jan sona ante li"/>
                <nbspace/>
                <ITEXT CH="lukin e"/>
                <nbspace/>
                <ITEXT CH="kiwen ni la, ona li"/>
                <nbspace/>
                <ITEXT CH="toki: “sijelo pi akesi ante li"/>
                <nbspace/>
                <ITEXT CH="ken sama sijelo waso. len pi akesi ni li"/>
                <nbspace/>
                <ITEXT CH="ken ala ken sama len waso?”"/>
                <para/>
                <ITEXT CH="tenpo sike #"/>
                <ITEXT FONTFEATURES="-clig,+c2sc,+ss01" CH="LLLTTAMMMMLLLW"/>
                <ITEXT CH=" la, jan sona li"/>
                <nbspace/>
                <ITEXT CH="kama jo e"/>
                <nbspace/>
                <ITEXT CH="kiwen akesi... pi len waso (Sinosauropteryx). sijelo ona li"/>
                <nbspace/>
                <ITEXT CH="sama akesi, taso selo ona li"/>
                <nbspace/>
                <ITEXT CH="sama waso"/>
                <nbspace/>
                <ITEXT CH="a! akesi pi sijelo sama waso li"/>
                <nbspace/>
                <ITEXT CH="ken"/>
                <nbspace/>
                <ITEXT CH="a len sama waso! jan sona li"/>
                <nbspace/>
                <ITEXT CH="kama jo e"/>
                <nbspace/>
                <ITEXT CH="kiwen mute pi len waso kin."/>
                <para/>
                <ITEXT CH="jan sona li"/>
                <nbspace/>
                <ITEXT CH="ken lukin e"/>
                <nbspace/>
                <ITEXT CH="ijo pi kule len kepeken ilo lukin pi ijo lili"/>
                <nbspace/>
                <ITEXT CH="a. ni la, jan li"/>
                <nbspace/>
                <ITEXT CH="sona e"/>
                <nbspace/>
                <ITEXT CH="kule pi akesi ni. akesi waso pi luka waso tu tu (Microraptor) li"/>
                <nbspace/>
                <ITEXT CH="pimeja."/>
                <breakline/>
                <ITEXT CH="akesi Sinosauropteryx li"/>
                <nbspace/>
                <ITEXT CH="kule sama ki­­je­­te­­san­­ta­­ka­­lu loje. len waso li"/>
                <nbspace/>
                <ITEXT CH="ken lon kiwen pi ko kasi kin. tenpo sike #"/>
                <ITEXT FONTFEATURES="-clig,+c2sc,+ss01" CH="MALLLW"/>
                <ITEXT CH=" la, jan sona Lida Xing li"/>
                <nbspace/>
                <ITEXT CH="kama jo e"/>
                <nbspace/>
                <ITEXT CH="kiwen pi ko kasi lon ma esun pi ko kasi lon ma Mijama. kiwen pi ko kasi ni li"/>
                <nbspace/>
                <ITEXT CH="awen e"/>
                <nbspace/>
                <ITEXT CH="linja monsi pi akesi waso, e"/>
                <nbspace/>
                <ITEXT CH="len waso!"/>
                <para/>
                <ITEXT CH="ni la, jan mute li"/>
                <nbspace/>
                <ITEXT CH="sitelen e"/>
                <nbspace/>
                <ITEXT CH="akesi ni kepeken len waso. jan sona li"/>
                <nbspace/>
                <ITEXT CH="toki: “akesi ale"/>
                <nbspace/>
                <ITEXT CH="a pi sijelo sama waso li"/>
                <nbspace/>
                <ITEXT CH="len ala len waso?” tenpo ni la, jan sona li"/>
                <nbspace/>
                <ITEXT CH="toki: ala. selo akesi li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="seli. akesi suli li"/>
                <nbspace/>
                <ITEXT CH="ken len waso lon ma lete tan ni: len li"/>
                <nbspace/>
                <ITEXT CH="awen e"/>
                <nbspace/>
                <ITEXT CH="seli. taso, akesi suli li"/>
                <nbspace/>
                <ITEXT CH="lon ma seli la, len li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="seli mute"/>
                <nbspace/>
                <ITEXT CH="a! seli mute li"/>
                <nbspace/>
                <ITEXT CH="ken moli e"/>
                <nbspace/>
                <ITEXT CH="akesi suli. akesi lili en waso li"/>
                <nbspace/>
                <ITEXT CH="ken len waso tan ni: kon li"/>
                <nbspace/>
                <ITEXT CH="ken lete e"/>
                <nbspace/>
                <ITEXT CH="akesi lili e"/>
                <nbspace/>
                <ITEXT CH="waso. taso, akesi lili mute li"/>
                <nbspace/>
                <ITEXT CH="ken kama suli. akesi pi ma seli li"/>
                <nbspace/>
                <ITEXT CH="kama suli la, len li"/>
                <nbspace/>
                <ITEXT CH="weka. taso selo akesi li"/>
                <nbspace/>
                <ITEXT CH="ken lon ala anpa pi len waso. selo ona li"/>
                <nbspace/>
                <ITEXT CH="len ala, sama jan, sama soweli suli."/>
                <para/>
                <ITEXT CH="tenpo ni la, jan li"/>
                <nbspace/>
                <ITEXT CH="sona e"/>
                <nbspace/>
                <ITEXT CH="ni: akesi pi tenpo weka mute li"/>
                <nbspace/>
                <ITEXT CH="ken sama ijo mute tawa lukin. selo akesi li"/>
                <nbspace/>
                <ITEXT CH="ken sama akesi, li"/>
                <nbspace/>
                <ITEXT CH="ken len waso, li"/>
                <nbspace/>
                <ITEXT CH="ken len ala."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="362.834220472441" YPOS="4162.69606299213" OwnPage="11" ItemID="740129932" PTYPE="4" WIDTH="170.079165354331" HEIGHT="344.390551181103" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L170.079 0 L170.079 344.391 L0 344.391 L0 0 Z" copath="M0 0 L170.079 0 L170.079 344.391 L0 344.391 L0 0 Z" gXpos="362.834220472441" gYpos="4162.69606299213" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="742810188" BACKITEM="739301548"/>
