        <PAGEOBJECT XPOS="178.582677165355" YPOS="3411.4805143028" OwnPage="9" ItemID="739290396" PTYPE="4" WIDTH="170.078543307087" HEIGHT="290.566729791688" FRTYPE="0" CLIPEDIT="1" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L170.079 0 L170.079 290.567 L0 290.567 L0 0 Z" copath="M0 0 L170.079 0 L170.079 290.567 L0 290.567 L0 0 Z" gXpos="178.582677165358" gYpos="3411.4805143028" gWidth="170.078543307087" gHeight="245.52351358111" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="734732780" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT FONT="Andika Bold" FCOLOR="kapesi pimeja" FSHADE="100" CH="musi Toki En Tawa (D&amp;D)"/>
                <ITEXT CH=" li"/>
                <nbspace/>
                <ITEXT CH="musi pi ijo mute. sina ken toki tawa jan ante. sina ken tawa lon ma suli. sina ken utala e"/>
                <nbspace/>
                <ITEXT CH="ijo monsuta. sina ken musi pona!"/>
                <para/>
                <ITEXT CH="musi Toki En Tawa la jan li"/>
                <nbspace/>
                <ITEXT CH="kama kulupu. ona li"/>
                <nbspace/>
                <ITEXT CH="toki."/>
                <para/>
                <ITEXT CH="ona li"/>
                <nbspace/>
                <ITEXT CH="pali e"/>
                <nbspace/>
                <ITEXT CH="jan pi musi ni. nasin mute li"/>
                <nbspace/>
                <ITEXT CH="lon. nanpa wan la o"/>
                <nbspace/>
                <ITEXT CH="lukin e"/>
                <nbspace/>
                <ITEXT CH="kulupu jan. jan akesi en jan pi wawa nasa en jan lili utala en jan suli en jan lili pi utala ala en ante li"/>
                <nbspace/>
                <ITEXT CH="ken lon."/>
                <para/>
                <ITEXT CH="nanpa tu la o"/>
                <nbspace/>
                <ITEXT CH="lukin e"/>
                <nbspace/>
                <ITEXT CH="nasin pi jan sina. jan li"/>
                <nbspace/>
                <ITEXT CH="ken utala li"/>
                <nbspace/>
                <ITEXT CH="ken kepeken wawa nasa li"/>
                <nbspace/>
                <ITEXT CH="ken pali e"/>
                <nbspace/>
                <ITEXT CH="telo wawa li"/>
                <nbspace/>
                <ITEXT CH="ken toki pona tawa jan li"/>
                <nbspace/>
                <ITEXT CH="ken mute!"/>
                <para/>
                <ITEXT CH="tenpo ni la o"/>
                <nbspace/>
                <ITEXT CH="open. jan lawa li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="ma pi musi ni. sina lon tomo pi telo nasa anu tomo pi kama sona anu seme? sina lukin e"/>
                <nbspace/>
                <ITEXT CH="seme?"/>
                <para/>
                <ITEXT CH="sina o"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="wile sina tawa jan lawa la toki pi sina mute li"/>
                <nbspace/>
                <ITEXT CH="kama suli! sina ken tawa li"/>
                <nbspace/>
                <ITEXT CH="ken utala li"/>
                <nbspace/>
                <ITEXT CH="ken toki li"/>
                <nbspace/>
                <ITEXT CH="ken wawa!"/>
                <para/>
                <ITEXT CH="jan sina li"/>
                <nbspace/>
                <ITEXT CH="kama wawa la sina kama jo e"/>
                <nbspace/>
                <ITEXT CH="ijo wawa nanpa tu anu mute! ijo wawa pi sewi nanpa wan li"/>
                <nbspace/>
                <ITEXT CH="nanpa mute, anu luka luka luka luka."/>
                <para/>
                <ITEXT CH="kin la jan sina li"/>
                <nbspace/>
                <ITEXT CH="kama jo e"/>
                <nbspace/>
                <ITEXT CH="mani mute tan jan ante pi musi ni. sina ken kama jo e"/>
                <nbspace/>
                <ITEXT CH="ilo utala wawa!"/>
                <para/>
                <ITEXT CH="ijo monsuta li"/>
                <nbspace/>
                <ITEXT CH="seme? ijo wan li"/>
                <nbspace/>
                <ITEXT CH="ni: ona li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="lawa pi waso alasa, taso ona li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="sijelo pi soweli suli. ijo ante li"/>
                <nbspace/>
                <ITEXT CH="suli mute li"/>
                <nbspace/>
                <ITEXT CH="pakala e"/>
                <nbspace/>
                <ITEXT CH="ma tomo mute!"/>
                <para/>
                <ITEXT CH="o"/>
                <nbspace/>
                <ITEXT CH="kepeken musi Toki En Tawa la sina pilin pona! o"/>
                <nbspace/>
                <ITEXT CH="alasa ni!"/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
