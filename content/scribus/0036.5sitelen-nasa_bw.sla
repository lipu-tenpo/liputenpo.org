        <PAGEOBJECT XPOS="404.256354031695" YPOS="1360.62992125984" OwnPage="3" ItemID="2121578083" PTYPE="4" WIDTH="128.657031795076" HEIGHT="538.582677165357" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L128.657 0 L128.657 538.583 L0 538.583 L0 0 Z" copath="M0 0 L128.657 0 L128.657 538.583 L0 538.583 L0 0 Z" gXpos="404.256354031695" gYpos="1360.62992125984" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="2123151107" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT FONT="Andika Bold" CH="jan majuna pi ma lete"/>
                <breakline/>
                <ITEXT CH="tan jan Tene"/>
                <para PARENT="transcript"/>
                <ITEXT CH="ken suli la sitelen insa sina la jan majuna pi ma lete li"/>
                <nbspace/>
                <ITEXT CH="jo e"/>
                <nbspace/>
                <ITEXT CH="kiwen awen lawa pi palisa tu e"/>
                <nbspace/>
                <ITEXT CH="selo soweli lon sijelo ona. taso ona li"/>
                <nbspace/>
                <ITEXT CH="sama ala"/>
                <nbspace/>
                <ITEXT CH="a ni. mi wile kama sona e"/>
                <nbspace/>
                <ITEXT CH="ona lon la mi o"/>
                <nbspace/>
                <ITEXT CH="lukin e"/>
                <nbspace/>
                <ITEXT CH="tenpo e"/>
                <nbspace/>
                <ITEXT CH="tawa e"/>
                <nbspace/>
                <ITEXT CH="pali ona. tenpo sike nanpa luka tu ale mute mute mute mute luka luka tu wan la ona li"/>
                <nbspace/>
                <ITEXT CH="pakala e"/>
                <nbspace/>
                <ITEXT CH="tomo sewi pi ma Linsipan. ni la jan lawa ante pi ma Elopa li"/>
                <nbspace/>
                <ITEXT CH="kama pilin monsuta tan ona li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="ike monsuta ona. jan Akuwin pi ma tomo Joki li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="ni: sewi li"/>
                <nbspace/>
                <ITEXT CH="ken e"/>
                <nbspace/>
                <ITEXT CH="moli pi jan mute ni tan pali anu kon ike ona."/>
                <para PARENT="transcript"/>
                <ITEXT CH="open la ona li"/>
                <nbspace/>
                <ITEXT CH="tawa ma Piten li"/>
                <nbspace/>
                <ITEXT CH="tawa ma Lusikaja Senja (tenpo ni la ma Ukawina li"/>
                <nbspace/>
                <ITEXT CH="lon sama). taso ona li"/>
                <nbspace/>
                <ITEXT CH="kama tawa ma Nomansi lon ma Panki (tenpo ni la ona lon ma Kanse). ni la lili ona li"/>
                <nbspace/>
                <ITEXT CH="kama kulupu Noman li"/>
                <nbspace/>
                <ITEXT CH="kama lawa e"/>
                <nbspace/>
                <ITEXT CH="ma Inli. taso jan majuna pi ma lete li"/>
                <nbspace/>
                <ITEXT CH="tawa ma ante kin pi ma Elopa. ona li"/>
                <nbspace/>
                <ITEXT CH="utala e"/>
                <nbspace/>
                <ITEXT CH="ma mute"/>
                <nbspace/>
                <ITEXT CH="a: ma Italija en ma Ipelija en ma tomo Kontansinopoli pi ma Pasileja Loma (tenpo ni la ona li"/>
                <nbspace/>
                <ITEXT CH="ma tomo Itanpu pi ma Tukije). jan mute"/>
                <nbspace/>
                <ITEXT CH="a li"/>
                <nbspace/>
                <ITEXT CH="sona e"/>
                <nbspace/>
                <ITEXT CH="ni: ona li"/>
                <nbspace/>
                <ITEXT CH="tawa ma Amelika lon tenpo sike nanpa luka luka ale mute wan. toki ona la ni li"/>
                <nbspace/>
                <ITEXT CH="ma Winlan."/>
                <para PARENT="transcript"/>
                <ITEXT CH="jan sona li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="tan ken mute tawa tenpo ni. ken la ona li"/>
                <nbspace/>
                <ITEXT CH="tan seli anu lili moku anu mute jan anu ante. taso tenpo sike nanpa luka luka ale la pini pi tawa weka ona li"/>
                <nbspace/>
                <ITEXT CH="kama tan nasin pi jan Jesu."/>
                <para PARENT="transcript"/>
                <ITEXT CH="tan nanpa wan pi wawa ona li"/>
                <nbspace/>
                <ITEXT CH="ilo tawa telo suli ona. ni la ona li"/>
                <nbspace/>
                <ITEXT CH="ken tawa wawa li"/>
                <nbspace/>
                <ITEXT CH="ken utala e"/>
                <nbspace/>
                <ITEXT CH="ma weka. ona li"/>
                <nbspace/>
                <ITEXT CH="esun la ona li"/>
                <nbspace/>
                <ITEXT CH="kepeken ilo tawa ante pi wawa ni ala. nasa la jan sona ala li"/>
                <nbspace/>
                <ITEXT CH="sona e"/>
                <nbspace/>
                <ITEXT CH="ni: ona li"/>
                <nbspace/>
                <ITEXT CH="sona e"/>
                <nbspace/>
                <ITEXT CH="tawa ona kepeken nasin seme. utala la ona li"/>
                <nbspace/>
                <ITEXT CH="wan e"/>
                <nbspace/>
                <ITEXT CH="kulupu pi ilo tawa mute kepeken linja. ni la ona li"/>
                <nbspace/>
                <ITEXT CH="sike e"/>
                <nbspace/>
                <ITEXT CH="ilo tawa ante li"/>
                <nbspace/>
                <ITEXT CH="lili e"/>
                <nbspace/>
                <ITEXT CH="sike. tenpo sama la ona li"/>
                <nbspace/>
                <ITEXT CH="pana e"/>
                <nbspace/>
                <ITEXT CH="palisa utala li"/>
                <nbspace/>
                <ITEXT CH="anpa e"/>
                <nbspace/>
                <ITEXT CH="ilo tawa ante. ona li"/>
                <nbspace/>
                <ITEXT CH="tawa ma mute la ona li"/>
                <nbspace/>
                <ITEXT CH="esun mute kin. lon la ona li"/>
                <nbspace/>
                <ITEXT CH="esun e"/>
                <nbspace/>
                <ITEXT CH="ijo pi ma weka"/>
                <nbspace/>
                <ITEXT CH="a kin: ma Pasileja Loma en ma Kilapa Umawija (ma Alapi pi tenpo ni)."/>
                <para PARENT="transcript"/>
                <ITEXT CH="nasin pi jan Jesu li"/>
                <nbspace/>
                <ITEXT CH="kama ala la sitelen li"/>
                <nbspace/>
                <ITEXT CH="suli ala lon nasin kulupu ona. ni la mi sona lili taso e"/>
                <nbspace/>
                <ITEXT CH="ona. tenpo pi tawa weka la sitelen li"/>
                <nbspace/>
                <ITEXT CH="kama suli lili. taso ona li"/>
                <nbspace/>
                <ITEXT CH="suli tawa suli ona pi tenpo pini taso. ona li"/>
                <nbspace/>
                <ITEXT CH="awen lili"/>
                <nbspace/>
                <ITEXT CH="a tawa suli ona pi ma ante. lipu pi mute lili li"/>
                <nbspace/>
                <ITEXT CH="toki e"/>
                <nbspace/>
                <ITEXT CH="nasin sewi li"/>
                <nbspace/>
                <ITEXT CH="toki musi e"/>
                <nbspace/>
                <ITEXT CH="tenpo utala e"/>
                <nbspace/>
                <ITEXT CH="jan suli pini."/>
                <para PARENT="transcript"/>
                <ITEXT CH="kulupu jan ni la jan mute li"/>
                <nbspace/>
                <ITEXT CH="pilin monsuta anu pilin e"/>
                <nbspace/>
                <ITEXT CH="wawa utala ona. taso ni li"/>
                <nbspace/>
                <ITEXT CH="tan nasa kulupu taso. jan ni li"/>
                <nbspace/>
                <ITEXT CH="ken ante mute. mi sona pona e"/>
                <nbspace/>
                <ITEXT CH="utala taso ona tan ni: ona li"/>
                <nbspace/>
                <ITEXT CH="sitelen lili"/>
                <nbspace/>
                <ITEXT CH="a e"/>
                <nbspace/>
                <ITEXT CH="nasin kulupu ona. mi wile sona e"/>
                <nbspace/>
                <ITEXT CH="ona la mi o"/>
                <nbspace/>
                <ITEXT CH="alasa sona wawa."/>
                <para PARENT="transcript"/>
            </StoryText>
        </PAGEOBJECT>
