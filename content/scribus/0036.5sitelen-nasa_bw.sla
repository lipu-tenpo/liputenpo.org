            <StoryText>
                <DefaultStyle PARENT="toki pi lipu open"/>
                <ITEXT CPARENT="toki pi lipu open la nimi open" FCOLOR="kapesi pimeja" CH="tenpo mute pini la"/>
                <breakline/>
                <ITEXT CH="jan li palisa e kiwen."/>
                <breakline/>
                <ITEXT CH="jan ante li kama sona tan ni."/>
                <breakline/>
                <ITEXT CH="ni li sitelen."/>
                <para ParagraphEffectOffset="0" ParagraphEffectIndent="0" DROP="0" DROPLIN="2" Bullet="0" Numeration="0"/>
                <ITEXT CH="tenpo ni la"/>
                <breakline/>
                <ITEXT CH="nasin sitelen mute li lon."/>
                <breakline/>
                <ITEXT CH="jan li sona ala e sitelen"/>
                <breakline/>
                <ITEXT CH="la ona li pilin nasa."/>
                <breakline/>
                <ITEXT CH="jan pi toki pona ala"/>
                <breakline/>
                <ITEXT CH="li ken pilin nasa"/>
                <breakline/>
                <ITEXT CH="tan sitelen pona"/>
                <breakline/>
                <ITEXT CH="anu sitelen sitelen."/>
                <breakline/>
                <ITEXT CH="mi wile e ni:"/>
                <breakline/>
                <ITEXT CH="sina pilin sama. o lukin"/>
                <breakline/>
                <ITEXT CH="e sitelen nasa ante mute"/>
                <breakline/>
                <ITEXT CH="lon lipu tenpo nasa ni."/>
                <para ParagraphEffectOffset="0" ParagraphEffectIndent="0" DROP="0" DROPLIN="2" Bullet="0" Numeration="0"/>
                <ITEXT CPARENT="toki pi lipu open la nimi open" FCOLOR="kapesi pimeja" CH="– jan Sonatan"/>
                <para ParagraphEffectOffset="0" ParagraphEffectIndent="0" DROP="0" DROPLIN="2" Bullet="0" Numeration="0"/>
            </StoryText>
